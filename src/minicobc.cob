        PERFORM EMIT-LINE

        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
            MOVE WS-SYMBOL-INDEX TO WS-SAVED-SYMBOL-INDEX
            PERFORM VARYING WS-WORK-INDEX-2
                FROM SYMBOL-FIRST-CHILD(WS-SAVED-SYMBOL-INDEX) BY 1
                UNTIL WS-WORK-INDEX-2 >
                    SYMBOL-LAST-CHILD(WS-SAVED-SYMBOL-INDEX)
                IF SYMBOL-KIND(WS-WORK-INDEX-2) NOT = "G"
                    MOVE WS-WORK-INDEX-2 TO WS-SYMBOL-INDEX
                    PERFORM LOAD-EFFECTIVE-OCCURS
                    MOVE SPACES TO WS-EMIT-PAYLOAD
                    MOVE 1 TO WS-APPEND-PTR
                    STRING "#define " DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING " " DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    IF WS-EFFECTIVE-OCCURS > 1
                        STRING "(" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                    END-IF
                    IF WS-EFFECTIVE-OCCURS = 1
                        STRING "(*" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                    END-IF
                    STRING FUNCTION TRIM(WS-LINKAGE-BIND-NAME)
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING "->" DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING "m_" DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    IF WS-EFFECTIVE-OCCURS = 1
                        STRING ")" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                    END-IF
                    IF WS-EFFECTIVE-OCCURS > 1
                        STRING ")" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                    END-IF
                    PERFORM EMIT-LINE
                END-IF
            END-PERFORM
            MOVE WS-SAVED-SYMBOL-INDEX TO WS-SYMBOL-INDEX
        ELSE
            PERFORM LOAD-EFFECTIVE-OCCURS
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING "#define " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING " " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            IF WS-EFFECTIVE-OCCURS > 1
                STRING "(" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            IF WS-EFFECTIVE-OCCURS = 1
                STRING "(*" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            STRING FUNCTION TRIM(WS-LINKAGE-BIND-NAME)
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            IF WS-EFFECTIVE-OCCURS = 1
                STRING ")" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            IF WS-EFFECTIVE-OCCURS > 1
                STRING ")" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            PERFORM EMIT-LINE
        END-IF
    END-PERFORM
    .

EMIT-UNIT-INIT-HELPER.
    MOVE "static int minicobc_unit_initialized = 0;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "static void minicobc_unit_init(void)" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "if (minicobc_unit_initialized) return;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "minicobc_unit_initialized = 1;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    IF WS-OVERLAY-ROOT-COUNT > 0
        MOVE "minicobc_overlay_init();" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
    END-IF
    IF WS-HAS-DATA-INIT = "Y"
        MOVE "minicobc_data_init();" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
    END-IF
    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    .

EMIT-UNIT-INIT-CALL.
    MOVE "minicobc_unit_init();" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    .

EMIT-SUBPROGRAM-BINDINGS.
    IF WS-USING-COUNT = 0
        EXIT PARAGRAPH
    END-IF

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-USING-COUNT
        MOVE USING-SYMBOL(WS-WORK-INDEX) TO WS-SYMBOL-INDEX
        PERFORM BUILD-LINKAGE-BIND-NAME
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
            PERFORM BUILD-GROUP-TYPE-NAME
        END-IF
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(WS-LINKAGE-BIND-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " = (" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
            STRING FUNCTION TRIM(WS-GROUP-TYPE-NAME) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING " *) " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        ELSE
            IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                STRING "char (*)[" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                MOVE SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-INDEX)
                    TO WS-PLAIN-NUMERIC
                ADD 1 TO WS-PLAIN-NUMERIC
                PERFORM LOAD-PLAIN-INTEGER-TEXT
                STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING "]) " DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            ELSE
                STRING FUNCTION TRIM(SYMBOL-C-TYPE(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING " *) " DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
        END-IF
        STRING "minicobc_args[" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        MOVE WS-WORK-INDEX TO WS-PLAIN-NUMERIC
        SUBTRACT 1 FROM WS-PLAIN-NUMERIC
        PERFORM LOAD-PLAIN-INTEGER-TEXT
        STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "];" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
    END-PERFORM
    .

EMIT-OVERLAY-REFRESH-CALL.
    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    PERFORM BUILD-OVERLAY-SYNC-NAME
    STRING FUNCTION TRIM(WS-OVERLAY-SYNC-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "();" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    .

EMIT-ALNUM-COPY-CALL.
    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    IF WS-TARGET-HAS-SLICE = "Y"
        STRING "minicobc_copy_span(" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        STRING "minicobc_copy_string(" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ", " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-TARGET-LENGTH-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ", " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-SOURCE-C-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ", " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-SOURCE-LENGTH-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ");" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    .

NORMALIZE-QUALIFIED-TOKENS.
    IF WS-TOKEN-COUNT < 3
        EXIT PARAGRAPH
    END-IF

    MOVE 1 TO WS-WORK-INDEX
    MOVE 1 TO WS-WORK-INDEX-3

    PERFORM UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
        PERFORM FIND-SYMBOL
        IF WS-SYMBOL-INDEX > 0 AND
            WS-WORK-INDEX + 2 <= WS-TOKEN-COUNT AND
            TOKEN-UPPER(WS-WORK-INDEX + 1) = "OF"
            MOVE WS-SYMBOL-INDEX TO WS-SAVED-SYMBOL-INDEX
            PERFORM PARSE-QUALIFIER-REFERENCE
            IF WS-QUAL-SYMBOL-INDEX > 0
                MOVE "Y" TO WS-QUAL-IS-ANCESTOR
            ELSE
                MOVE "N" TO WS-QUAL-IS-ANCESTOR
            END-IF
            IF WS-QUAL-IS-ANCESTOR = "Y"
                MOVE TOKEN-RAW(WS-WORK-INDEX)
                    TO TOKEN-RAW(WS-WORK-INDEX-3)
                MOVE TOKEN-UPPER(WS-WORK-INDEX)
                    TO TOKEN-UPPER(WS-WORK-INDEX-3)
                ADD 1 TO WS-WORK-INDEX-3

                MOVE WS-SAVED-SYMBOL-INDEX TO WS-SYMBOL-INDEX
                PERFORM LOAD-EFFECTIVE-OCCURS
                IF WS-EFFECTIVE-OCCURS > 1 AND
                    SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-INDEX) > 0 AND
                    WS-QUAL-HAS-INDEX = "Y" AND
                    (WS-WORK-INDEX + 1 > WS-TOKEN-COUNT OR
                        TOKEN-RAW(WS-WORK-INDEX + 1) NOT = "(")
                    COMPUTE WS-FOUND-POS = WS-QUAL-START + 1
                    PERFORM UNTIL WS-FOUND-POS > WS-QUAL-CLOSE-POS
                        MOVE TOKEN-RAW(WS-FOUND-POS)
                            TO TOKEN-RAW(WS-WORK-INDEX-3)
                        MOVE TOKEN-UPPER(WS-FOUND-POS)
                            TO TOKEN-UPPER(WS-WORK-INDEX-3)
                        ADD 1 TO WS-WORK-INDEX-3
                        ADD 1 TO WS-FOUND-POS
                    END-PERFORM
                END-IF

                MOVE WS-QUAL-NEXT-POS TO WS-WORK-INDEX
            ELSE
                MOVE TOKEN-RAW(WS-WORK-INDEX)
                    TO TOKEN-RAW(WS-WORK-INDEX-3)
                MOVE TOKEN-UPPER(WS-WORK-INDEX)
                    TO TOKEN-UPPER(WS-WORK-INDEX-3)
                ADD 1 TO WS-WORK-INDEX-3
                ADD 1 TO WS-WORK-INDEX
            END-IF
        ELSE
            MOVE TOKEN-RAW(WS-WORK-INDEX) TO TOKEN-RAW(WS-WORK-INDEX-3)
            MOVE TOKEN-UPPER(WS-WORK-INDEX) TO TOKEN-UPPER(WS-WORK-INDEX-3)
            ADD 1 TO WS-WORK-INDEX-3
            ADD 1 TO WS-WORK-INDEX
        END-IF
    END-PERFORM

    MOVE WS-WORK-INDEX-3 TO WS-FOUND-POS
    COMPUTE WS-TOKEN-COUNT = WS-WORK-INDEX-3 - 1
    PERFORM VARYING WS-WORK-INDEX FROM WS-FOUND-POS BY 1
        UNTIL WS-WORK-INDEX > 128
        MOVE SPACES TO TOKEN-RAW(WS-WORK-INDEX)
        MOVE SPACES TO TOKEN-UPPER(WS-WORK-INDEX)
    END-PERFORM
    .

PARSE-QUALIFIER-REFERENCE.
    MOVE 0 TO WS-QUAL-SYMBOL-INDEX
    MOVE "N" TO WS-QUAL-HAS-INDEX
    MOVE 0 TO WS-QUAL-START
    MOVE 0 TO WS-QUAL-CLOSE-POS
    MOVE 0 TO WS-QUAL-NEXT-POS

    COMPUTE WS-QUAL-START = WS-WORK-INDEX + 2
    IF WS-QUAL-START > WS-TOKEN-COUNT
        EXIT PARAGRAPH
    END-IF

    MOVE TOKEN-UPPER(WS-QUAL-START) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX = 0
        EXIT PARAGRAPH
    END-IF
    MOVE WS-SYMBOL-INDEX TO WS-QUAL-SYMBOL-INDEX
    COMPUTE WS-QUAL-NEXT-POS = WS-QUAL-START + 1

    IF WS-QUAL-NEXT-POS <= WS-TOKEN-COUNT AND
        TOKEN-RAW(WS-QUAL-NEXT-POS) = "("
        MOVE "Y" TO WS-QUAL-HAS-INDEX
        MOVE 0 TO WS-PAREN-DEPTH
        MOVE 0 TO WS-QUAL-CLOSE-POS
        PERFORM VARYING WS-FOUND-POS FROM WS-QUAL-NEXT-POS BY 1
            UNTIL WS-FOUND-POS > WS-TOKEN-COUNT OR WS-QUAL-CLOSE-POS > 0
            EVALUATE TOKEN-RAW(WS-FOUND-POS)
                WHEN "("
                    ADD 1 TO WS-PAREN-DEPTH
                WHEN ")"
                    IF WS-PAREN-DEPTH = 1
                        MOVE WS-FOUND-POS TO WS-QUAL-CLOSE-POS
                    END-IF
                    IF WS-PAREN-DEPTH > 0
                        SUBTRACT 1 FROM WS-PAREN-DEPTH
                    END-IF
                WHEN OTHER
                    CONTINUE
            END-EVALUATE
        END-PERFORM
        IF WS-QUAL-CLOSE-POS = 0
            MOVE 0 TO WS-QUAL-SYMBOL-INDEX
            EXIT PARAGRAPH
        END-IF
        COMPUTE WS-QUAL-NEXT-POS = WS-QUAL-CLOSE-POS + 1
    END-IF
    .

BUILD-QUALIFIER-INDEX-TOKEN.
    MOVE SPACES TO WS-REF-INDEX-TOKEN
    IF WS-QUAL-HAS-INDEX NOT = "Y"
        EXIT PARAGRAPH
    END-IF

    IF WS-QUAL-CLOSE-POS = WS-QUAL-START + 3
        COMPUTE WS-WORK-INDEX = WS-QUAL-START + 2
        PERFORM RESOLVE-SIMPLE-INDEX-TOKEN
        MOVE WS-REF-BUILD-RESULT TO WS-REF-INDEX-TOKEN
    ELSE
        COMPUTE WS-EXPR-START = WS-QUAL-START + 2
        COMPUTE WS-EXPR-END = WS-QUAL-CLOSE-POS - 1
        PERFORM PUSH-REF-BUILD-STATE
        PERFORM TRY-RESOLVE-INDEX-REFERENCE
        PERFORM POP-REF-BUILD-STATE
        IF WS-INDEX-RESOLVE-OK NOT = "Y"
            PERFORM PUSH-REF-BUILD-STATE
            PERFORM BUILD-EXPRESSION
            MOVE WS-EXPR TO WS-REF-BUILD-RESULT
            PERFORM POP-REF-BUILD-STATE
        END-IF
        MOVE WS-REF-BUILD-RESULT TO WS-REF-INDEX-TOKEN
    END-IF
    .

CHECK-QUALIFIER-ANCESTOR.
    MOVE "N" TO WS-QUAL-IS-ANCESTOR
    MOVE WS-SAVED-SYMBOL-INDEX TO WS-SYMBOL-INDEX
    PERFORM UNTIL WS-SYMBOL-INDEX = 0 OR WS-QUAL-IS-ANCESTOR = "Y"
        IF WS-SYMBOL-INDEX = WS-QUAL-SYMBOL-INDEX
            MOVE "Y" TO WS-QUAL-IS-ANCESTOR
        ELSE
            MOVE SYMBOL-PARENT(WS-SYMBOL-INDEX) TO WS-SYMBOL-INDEX
        END-IF
    END-PERFORM
    .

HANDLE-PROCEDURE-LINE.
    PERFORM NORMALIZE-QUALIFIED-TOKENS
    IF WS-HAS-PARAGRAPHS = "Y" AND WS-PROCEDURE-FUNC-OPEN NOT = "Y"
        PERFORM OPEN-ENTRY-PROCEDURE-FUNCTION
    END-IF

    IF TOKEN-UPPER(1) NOT = "MOVE" AND TOKEN-UPPER(1) NOT = "COMPUTE"
        PERFORM FLUSH-PENDING-ASSIGNMENT
    END-IF

    IF TOKEN-UPPER(1) = "END-IF" AND WS-TOKEN-COUNT > 1
        PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
            UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
            IF TOKEN-UPPER(WS-WORK-INDEX) NOT = "END-IF"
                MOVE "mixed END-IF statement is not supported"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
            PERFORM COMPILE-END-IF
        END-PERFORM
        EXIT PARAGRAPH
    END-IF

    EVALUATE TOKEN-UPPER(1)
        WHEN "DISPLAY"
            PERFORM COMPILE-DISPLAY
        WHEN "ACCEPT"
            PERFORM COMPILE-ACCEPT
        WHEN "MOVE"
            PERFORM COMPILE-MOVE
        WHEN "ADD"
            PERFORM COMPILE-ADD
        WHEN "SUBTRACT"
            MOVE "FROM" TO WS-UPDATE-KEYWORD
            MOVE "-=" TO WS-UPDATE-OP
            PERFORM COMPILE-ARITHMETIC-UPDATE
        WHEN "MULTIPLY"
            MOVE "BY" TO WS-UPDATE-KEYWORD
            MOVE "*=" TO WS-UPDATE-OP
            PERFORM COMPILE-ARITHMETIC-UPDATE
        WHEN "DIVIDE"
            PERFORM COMPILE-DIVIDE
        WHEN "COMPUTE"
            PERFORM COMPILE-COMPUTE
        WHEN "IF"
            PERFORM COMPILE-IF
        WHEN "ELSE"
            PERFORM COMPILE-ELSE
        WHEN "END-IF"
            PERFORM COMPILE-END-IF
        WHEN "EVALUATE"
            PERFORM COMPILE-EVALUATE
        WHEN "WHEN"
            PERFORM COMPILE-WHEN
        WHEN "END-EVALUATE"
            PERFORM COMPILE-END-EVALUATE
        WHEN "PERFORM"
            PERFORM COMPILE-PERFORM
        WHEN "END-PERFORM"
            PERFORM COMPILE-END-PERFORM
        WHEN "CALL"
            PERFORM COMPILE-CALL
        WHEN "INITIALIZE"
            PERFORM COMPILE-INITIALIZE
        WHEN "UNSTRING"
            PERFORM COMPILE-UNSTRING
        WHEN "CONTINUE"
            CONTINUE
        WHEN "EXIT"
            PERFORM COMPILE-EXIT
        WHEN "GOBACK"
            PERFORM COMPILE-GOBACK
        WHEN "STOP"
            PERFORM COMPILE-STOP
        WHEN OTHER
            MOVE "unsupported procedure statement" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
    END-EVALUATE
    .

COMPILE-DISPLAY.
    IF WS-TOKEN-COUNT < 2
        MOVE "DISPLAY needs at least one operand" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
        MOVE WS-TOKEN-WORK(1:1) TO WS-CHAR
        IF WS-CHAR = QUOTE
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING 'printf("%s", ' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(WS-TOKEN-WORK) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ");" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-LINE
        ELSE
            IF TOKEN-UPPER(WS-WORK-INDEX) = "FUNCTION"
                PERFORM COMPILE-DISPLAY-FUNCTION
            ELSE
                MOVE WS-WORK-INDEX TO WS-REF-START
                PERFORM RESOLVE-REFERENCE
                IF WS-REF-OK = "Y"
                    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                        PERFORM SAVE-GROUP-REF-AS-SOURCE
                        PERFORM SET-CURRENT-GROUP-INDEX-FROM-SOURCE
                        IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
                            PERFORM EMIT-OVERLAY-GROUP-DISPLAY
                        ELSE
                            PERFORM EMIT-GROUP-DISPLAY
                        END-IF
                    ELSE
                        PERFORM EMIT-DISPLAY-REFERENCE
                    END-IF
                ELSE
                    MOVE SPACES TO WS-EMIT-PAYLOAD
                    MOVE 1 TO WS-APPEND-PTR
                    STRING 'printf("%lld", (long long) ' DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING FUNCTION TRIM(TOKEN-RAW(WS-WORK-INDEX))
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING ");" DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    PERFORM EMIT-LINE
                END-IF
                IF WS-REF-OK = "Y"
                    COMPUTE WS-WORK-INDEX = WS-REF-NEXT-POS - 1
                END-IF
            END-IF
        END-IF
    END-PERFORM

    MOVE "putchar('\n');" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    .

EMIT-DISPLAY-REFERENCE.
    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
        STRING 'printf("%-*s", ' DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ", " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-REF-C-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        IF SYMBOL-ZERO-FILL(WS-SYMBOL-INDEX) = "Y"
            STRING 'printf("%0' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING 'lld", (long long) ' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        ELSE
            STRING 'printf("%' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING 'lld", (long long) ' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        END-IF
        STRING FUNCTION TRIM(WS-REF-C-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    STRING ");" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    IF WS-CALL-RETURNING-POS > 0 AND SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
        PERFORM EMIT-OVERLAY-SYNC-CALL
    END-IF
    .

COMPILE-DISPLAY-FUNCTION.
    IF WS-WORK-INDEX + 4 > WS-TOKEN-COUNT
        MOVE "DISPLAY FUNCTION call is incomplete" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF TOKEN-UPPER(WS-WORK-INDEX + 1) NOT = "TRIM" OR
        TOKEN-RAW(WS-WORK-INDEX + 2) NOT = "("
        MOVE "DISPLAY only supports FUNCTION TRIM(...) for now"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    COMPUTE WS-REF-START = WS-WORK-INDEX + 3
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS > WS-TOKEN-COUNT
        MOVE "DISPLAY FUNCTION TRIM currently expects one declared item"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

