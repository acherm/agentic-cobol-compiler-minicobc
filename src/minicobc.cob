PROCESS-SOURCE.
    PERFORM UNTIL WS-EOF = "Y"
        MOVE SPACES TO SOURCE-RECORD
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                ADD 1 TO WS-LINE-NO
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT > 0
                    IF WS-PHASE = "P"
                        PERFORM HANDLE-PROCEDURE-PHYSICAL-LINE
                    ELSE
                        IF WS-PHASE = "D"
                            PERFORM HANDLE-DATA-PHYSICAL-LINE
                        ELSE
                            PERFORM HANDLE-LINE
                        END-IF
                    END-IF
                END-IF
        END-READ
    END-PERFORM

    IF WS-STMT-IN-PROGRESS = "Y"
        PERFORM FLUSH-LOGICAL-STATEMENT
    END-IF
    .

NORMALIZE-LINE.
    MOVE SPACES TO WS-NORMALIZED-LINE
    MOVE "N" TO WS-LINE-HAS-PERIOD
    MOVE 0 TO WS-LAST-NONSPACE
    IF SOURCE-RECORD(1:6) = SPACES AND
        (SOURCE-RECORD(7:1) = "*" OR SOURCE-RECORD(7:1) = "/")
        EXIT PARAGRAPH
    END-IF
    PERFORM VARYING WS-WORK-INDEX FROM 2048 BY -1
        UNTIL WS-WORK-INDEX = 0 OR WS-LAST-NONSPACE > 0
        IF SOURCE-RECORD(WS-WORK-INDEX:1) NOT = SPACE
            MOVE WS-WORK-INDEX TO WS-LAST-NONSPACE
        END-IF
    END-PERFORM

    IF WS-LAST-NONSPACE = 0
        EXIT PARAGRAPH
    END-IF

    MOVE "N" TO WS-IN-QUOTES
    MOVE 0 TO WS-OUT-POS

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-LAST-NONSPACE
        MOVE SOURCE-RECORD(WS-WORK-INDEX:1) TO WS-CHAR

        IF WS-IN-QUOTES = "N"
            IF WS-WORK-INDEX < WS-LAST-NONSPACE
                MOVE SOURCE-RECORD(WS-WORK-INDEX + 1:1) TO WS-NEXT-CHAR
            ELSE
                MOVE SPACE TO WS-NEXT-CHAR
            END-IF

            IF WS-CHAR = "*" AND WS-NEXT-CHAR = ">"
                EXIT PERFORM
            END-IF
        END-IF

        IF WS-CHAR = QUOTE
            ADD 1 TO WS-OUT-POS
            MOVE WS-CHAR TO WS-NORMALIZED-LINE(WS-OUT-POS:1)
            IF WS-IN-QUOTES = "Y"
                MOVE "N" TO WS-IN-QUOTES
            ELSE
                MOVE "Y" TO WS-IN-QUOTES
            END-IF
        ELSE
            IF WS-IN-QUOTES = "N" AND WS-CHAR = "."
                MOVE "Y" TO WS-LINE-HAS-PERIOD
                MOVE SPACE TO WS-CHAR
            END-IF
            IF WS-IN-QUOTES = "N" AND WS-CHAR = X"09"
                MOVE SPACE TO WS-CHAR
            END-IF
            ADD 1 TO WS-OUT-POS
            MOVE WS-CHAR TO WS-NORMALIZED-LINE(WS-OUT-POS:1)
        END-IF
    END-PERFORM
    .

TOKENIZE-LINE.
    MOVE 0 TO WS-TOKEN-COUNT
    MOVE 0 TO WS-LAST-NONSPACE
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 128
        MOVE SPACES TO TOKEN-RAW(WS-WORK-INDEX)
        MOVE SPACES TO TOKEN-UPPER(WS-WORK-INDEX)
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 2048 BY -1
        UNTIL WS-WORK-INDEX = 0 OR WS-LAST-NONSPACE > 0
        IF WS-NORMALIZED-LINE(WS-WORK-INDEX:1) NOT = SPACE AND
            WS-NORMALIZED-LINE(WS-WORK-INDEX:1) NOT = LOW-VALUE
            MOVE WS-WORK-INDEX TO WS-LAST-NONSPACE
        END-IF
    END-PERFORM

    IF WS-LAST-NONSPACE = 0
        EXIT PARAGRAPH
    END-IF

    MOVE 1 TO WS-SCAN-POS
    PERFORM UNTIL WS-SCAN-POS > WS-LAST-NONSPACE
        PERFORM UNTIL WS-SCAN-POS > WS-LAST-NONSPACE OR
            (WS-NORMALIZED-LINE(WS-SCAN-POS:1) NOT = SPACE AND
                WS-NORMALIZED-LINE(WS-SCAN-POS:1) NOT = LOW-VALUE)
            ADD 1 TO WS-SCAN-POS
        END-PERFORM

        IF WS-SCAN-POS > WS-LAST-NONSPACE
            EXIT PERFORM
        END-IF

        ADD 1 TO WS-TOKEN-COUNT
        IF WS-TOKEN-COUNT > 128
            MOVE "too many tokens on one source line" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE WS-SCAN-POS TO WS-START-POS
        IF WS-NORMALIZED-LINE(WS-SCAN-POS:1) = QUOTE
            ADD 1 TO WS-SCAN-POS
            PERFORM UNTIL WS-SCAN-POS > WS-LAST-NONSPACE OR
                WS-NORMALIZED-LINE(WS-SCAN-POS:1) = QUOTE
                ADD 1 TO WS-SCAN-POS
            END-PERFORM
            IF WS-SCAN-POS <= WS-LAST-NONSPACE
                ADD 1 TO WS-SCAN-POS
            END-IF
        ELSE
            IF WS-NORMALIZED-LINE(WS-SCAN-POS:1) = "(" OR
                WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ")" OR
                WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ","
                ADD 1 TO WS-SCAN-POS
            ELSE
                PERFORM UNTIL WS-SCAN-POS > WS-LAST-NONSPACE OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = SPACE OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = LOW-VALUE OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = "(" OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ")" OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ","
                    ADD 1 TO WS-SCAN-POS
                END-PERFORM
            END-IF
        END-IF

        COMPUTE WS-TOKEN-LEN = WS-SCAN-POS - WS-START-POS
        MOVE WS-NORMALIZED-LINE(WS-START-POS:WS-TOKEN-LEN)
            TO TOKEN-RAW(WS-TOKEN-COUNT)

        IF TOKEN-RAW(WS-TOKEN-COUNT)(1:1) = QUOTE
            MOVE TOKEN-RAW(WS-TOKEN-COUNT) TO TOKEN-UPPER(WS-TOKEN-COUNT)
        ELSE
            MOVE FUNCTION UPPER-CASE(TOKEN-RAW(WS-TOKEN-COUNT))
                TO TOKEN-UPPER(WS-TOKEN-COUNT)
        END-IF
    END-PERFORM
    .

HANDLE-PROCEDURE-PHYSICAL-LINE.
    PERFORM CHECK-PARAGRAPH-LABEL-LINE
    IF WS-LINE-IS-PARAGRAPH = "Y"
        MOVE WS-NORMALIZED-LINE TO WS-SAVED-NORMALIZED-LINE
        MOVE WS-LINE-HAS-PERIOD TO WS-SAVED-LINE-HAS-PERIOD
        IF WS-STMT-IN-PROGRESS = "Y"
            PERFORM FLUSH-LOGICAL-STATEMENT
        END-IF
        MOVE WS-SAVED-NORMALIZED-LINE TO WS-NORMALIZED-LINE
        MOVE WS-SAVED-LINE-HAS-PERIOD TO WS-LINE-HAS-PERIOD
        PERFORM TOKENIZE-LINE
        PERFORM HANDLE-LINE
        EXIT PARAGRAPH
    END-IF

    IF WS-STMT-IN-PROGRESS NOT = "Y"
        PERFORM START-LOGICAL-STATEMENT
        EXIT PARAGRAPH
    END-IF

    PERFORM CHECK-FORCED-CONTINUATION-LINE
    IF WS-FORCED-CONTINUATION = "Y"
        PERFORM APPEND-LOGICAL-STATEMENT
        EXIT PARAGRAPH
    END-IF

    MOVE WS-NORMALIZED-LINE TO WS-SAVED-NORMALIZED-LINE
    MOVE WS-LINE-HAS-PERIOD TO WS-SAVED-LINE-HAS-PERIOD
    PERFORM LOAD-LOGICAL-STATEMENT
    PERFORM CHECK-LOGICAL-STATEMENT-COMPLETE
    MOVE WS-SAVED-NORMALIZED-LINE TO WS-NORMALIZED-LINE
    MOVE WS-SAVED-LINE-HAS-PERIOD TO WS-LINE-HAS-PERIOD
    PERFORM TOKENIZE-LINE
    IF WS-STMT-COMPLETE = "Y"
        PERFORM FLUSH-LOGICAL-STATEMENT
        MOVE WS-SAVED-NORMALIZED-LINE TO WS-NORMALIZED-LINE
        MOVE WS-SAVED-LINE-HAS-PERIOD TO WS-LINE-HAS-PERIOD
        PERFORM TOKENIZE-LINE
        PERFORM START-LOGICAL-STATEMENT
    ELSE
        PERFORM APPEND-LOGICAL-STATEMENT
    END-IF
    .

HANDLE-DATA-PHYSICAL-LINE.
    IF WS-STMT-IN-PROGRESS NOT = "Y"
        PERFORM START-LOGICAL-STATEMENT
        EXIT PARAGRAPH
    END-IF

    PERFORM CHECK-FORCED-CONTINUATION-LINE
    IF WS-FORCED-CONTINUATION = "Y"
        PERFORM APPEND-LOGICAL-STATEMENT
        EXIT PARAGRAPH
    END-IF

    MOVE WS-NORMALIZED-LINE TO WS-SAVED-NORMALIZED-LINE
    MOVE WS-LINE-HAS-PERIOD TO WS-SAVED-LINE-HAS-PERIOD
    PERFORM LOAD-LOGICAL-STATEMENT
    PERFORM CHECK-LOGICAL-STATEMENT-COMPLETE
    MOVE WS-SAVED-NORMALIZED-LINE TO WS-NORMALIZED-LINE
    MOVE WS-SAVED-LINE-HAS-PERIOD TO WS-LINE-HAS-PERIOD
    PERFORM TOKENIZE-LINE
    IF WS-STMT-COMPLETE = "Y"
        PERFORM FLUSH-LOGICAL-STATEMENT
        MOVE WS-SAVED-NORMALIZED-LINE TO WS-NORMALIZED-LINE
        MOVE WS-SAVED-LINE-HAS-PERIOD TO WS-LINE-HAS-PERIOD
        PERFORM TOKENIZE-LINE
        PERFORM START-LOGICAL-STATEMENT
    ELSE
        PERFORM APPEND-LOGICAL-STATEMENT
    END-IF
    .

START-LOGICAL-STATEMENT.
    MOVE SPACES TO WS-STATEMENT-LINE
    MOVE FUNCTION TRIM(WS-NORMALIZED-LINE) TO WS-STATEMENT-LINE
    MOVE WS-LINE-HAS-PERIOD TO WS-STMT-HAS-PERIOD
    MOVE "Y" TO WS-STMT-IN-PROGRESS
    .

APPEND-LOGICAL-STATEMENT.
    MOVE SPACES TO WS-STATEMENT-WORK
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-STATEMENT-LINE) DELIMITED BY SIZE
        INTO WS-STATEMENT-WORK WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-STATEMENT-WORK WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-NORMALIZED-LINE) DELIMITED BY SIZE
        INTO WS-STATEMENT-WORK WITH POINTER WS-APPEND-PTR
    END-STRING
    MOVE WS-STATEMENT-WORK TO WS-STATEMENT-LINE
    IF WS-LINE-HAS-PERIOD = "Y"
        MOVE "Y" TO WS-STMT-HAS-PERIOD
    END-IF
    .

LOAD-LOGICAL-STATEMENT.
    MOVE SPACES TO WS-NORMALIZED-LINE
    MOVE WS-STATEMENT-LINE TO WS-NORMALIZED-LINE
    MOVE WS-STMT-HAS-PERIOD TO WS-LINE-HAS-PERIOD
    PERFORM TOKENIZE-LINE
    .

CHECK-FORCED-CONTINUATION-LINE.
    MOVE "N" TO WS-FORCED-CONTINUATION
    IF WS-TOKEN-COUNT = 0
        EXIT PARAGRAPH
    END-IF

    MOVE 1 TO WS-SCAN-POS
    PERFORM UNTIL WS-SCAN-POS > 2048 OR
        WS-NORMALIZED-LINE(WS-SCAN-POS:1) NOT = SPACE
        ADD 1 TO WS-SCAN-POS
    END-PERFORM
    IF WS-SCAN-POS <= 2048 AND
        WS-NORMALIZED-LINE(WS-SCAN-POS:1) = QUOTE
        MOVE "Y" TO WS-FORCED-CONTINUATION
        EXIT PARAGRAPH
    END-IF

    EVALUATE TOKEN-UPPER(1)
        WHEN "FUNCTION"
        WHEN "BY"
        WHEN "VALUE"
        WHEN "GIVING"
        WHEN "TO"
        WHEN "FROM"
        WHEN "INTO"
        WHEN "REMAINDER"
        WHEN "UNTIL"
        WHEN "USING"
        WHEN "RETURNING"
        WHEN "AND"
        WHEN "OR"
        WHEN "NOT"
        WHEN "+"
        WHEN "-"
        WHEN "*"
        WHEN "/"
        WHEN "="
        WHEN ">"
        WHEN "<"
        WHEN ">="
        WHEN "<="
        WHEN "<>"
        WHEN ")"
        WHEN ","
            MOVE "Y" TO WS-FORCED-CONTINUATION
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

CHECK-LOGICAL-STATEMENT-COMPLETE.
    MOVE "N" TO WS-STMT-COMPLETE
    MOVE 0 TO WS-CALL-USING-POS
    MOVE 0 TO WS-CALL-RETURNING-POS
    IF WS-TOKEN-COUNT = 0
        EXIT PARAGRAPH
    END-IF

    IF WS-STMT-HAS-PERIOD = "Y"
        MOVE "Y" TO WS-STMT-COMPLETE
        EXIT PARAGRAPH
    END-IF

    MOVE 0 TO WS-PAREN-DEPTH
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = "("
            ADD 1 TO WS-PAREN-DEPTH
        END-IF
        IF TOKEN-UPPER(WS-WORK-INDEX) = ")"
            SUBTRACT 1 FROM WS-PAREN-DEPTH
        END-IF
    END-PERFORM

    IF WS-PAREN-DEPTH > 0
        EXIT PARAGRAPH
    END-IF

    EVALUATE TOKEN-UPPER(WS-TOKEN-COUNT)
        WHEN "TO"
        WHEN "FROM"
        WHEN "INTO"
        WHEN "GIVING"
        WHEN "USING"
        WHEN "RETURNING"
        WHEN "BY"
        WHEN "VALUE"
        WHEN "REFERENCE"
        WHEN "="
        WHEN "+"
        WHEN "-"
        WHEN "*"
        WHEN "/"
        WHEN "AND"
        WHEN "OR"
        WHEN "NOT"
        WHEN "("
        WHEN ","
        WHEN ">"
        WHEN "<"
        WHEN ">="
        WHEN "<="
        WHEN "<>"
            EXIT PARAGRAPH
        WHEN OTHER
            CONTINUE
    END-EVALUATE

    IF TOKEN-UPPER(1) = "PERFORM" AND WS-TOKEN-COUNT = 2 AND
        TOKEN-UPPER(2) = "UNTIL"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "UNSTRING" AND
        TOKEN-UPPER(WS-TOKEN-COUNT) NOT = "END-UNSTRING"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "PERFORM" AND TOKEN-UPPER(WS-TOKEN-COUNT) = "UNTIL"
        EXIT PARAGRAPH
    END-IF

    IF WS-TOKEN-COUNT >= 2 AND
        TOKEN-UPPER(WS-TOKEN-COUNT - 1) = "FUNCTION"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "CALL"
        IF WS-TOKEN-COUNT = 2
            MOVE "Y" TO WS-STMT-COMPLETE
            EXIT PARAGRAPH
        END-IF
        PERFORM VARYING WS-WORK-INDEX FROM 3 BY 1
            UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
            IF TOKEN-UPPER(WS-WORK-INDEX) = "USING"
                MOVE WS-WORK-INDEX TO WS-CALL-USING-POS
            END-IF
            IF TOKEN-UPPER(WS-WORK-INDEX) = "RETURNING"
                MOVE WS-WORK-INDEX TO WS-CALL-RETURNING-POS
            END-IF
        END-PERFORM
        IF WS-CALL-USING-POS = WS-TOKEN-COUNT OR
            WS-CALL-RETURNING-POS = WS-TOKEN-COUNT
            EXIT PARAGRAPH
        END-IF
    END-IF

    MOVE "Y" TO WS-STMT-COMPLETE
    .

FLUSH-LOGICAL-STATEMENT.
    PERFORM LOAD-LOGICAL-STATEMENT
    PERFORM CHECK-LOGICAL-STATEMENT-COMPLETE
    IF WS-STMT-COMPLETE NOT = "Y"
        MOVE "unterminated logical statement" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    PERFORM HANDLE-LINE
    MOVE "N" TO WS-STMT-IN-PROGRESS
    MOVE "N" TO WS-STMT-HAS-PERIOD
    MOVE SPACES TO WS-STATEMENT-LINE
    MOVE SPACES TO WS-STATEMENT-WORK
    .

HANDLE-LINE.
    IF TOKEN-UPPER(1) = "IDENTIFICATION" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "ENVIRONMENT" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "PROGRAM-ID"
        MOVE SPACES TO WS-PROGRAM-NAME
        IF WS-TOKEN-COUNT >= 2
            MOVE TOKEN-UPPER(2) TO WS-PROGRAM-NAME
            PERFORM BUILD-PROGRAM-C-NAME
        END-IF
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "DATA" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        MOVE "D" TO WS-PHASE
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "WORKING-STORAGE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "SECTION"
        MOVE "W" TO WS-DATA-SECTION
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "LINKAGE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "SECTION"
        MOVE "L" TO WS-DATA-SECTION
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "LOCAL-STORAGE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "SECTION"
        MOVE "T" TO WS-DATA-SECTION
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "PROCEDURE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        MOVE "P" TO WS-PHASE
        MOVE "Y" TO WS-PROCEDURE-SEEN
        MOVE "N" TO WS-PROCEDURE-FUNC-OPEN
        MOVE "N" TO WS-HAS-ENTRY-PARAGRAPH
        MOVE "N" TO WS-STMT-IN-PROGRESS
        MOVE "N" TO WS-STMT-HAS-PERIOD
        MOVE "N" TO WS-IS-SUBPROGRAM
        MOVE SPACES TO WS-STATEMENT-LINE
        MOVE 0 TO WS-BLOCK-DEPTH
        MOVE 0 TO WS-INDENT-LEVEL
        PERFORM CAPTURE-PROCEDURE-USING
        PERFORM FINALIZE-DATA-LAYOUT
        PERFORM EMIT-OVERLAY-HELPERS
        PERFORM EMIT-DATA-INIT-HELPERS
        PERFORM EMIT-GROUP-DESCRIPTOR-TYPES
        PERFORM EMIT-LINKAGE-BINDINGS
        PERFORM EMIT-UNIT-INIT-HELPER
        IF WS-HAS-PARAGRAPHS = "Y"
            PERFORM EMIT-PARAGRAPH-PROTOTYPES
        ELSE
            PERFORM OPEN-IMPLICIT-PROCEDURE-FUNCTION
        END-IF
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "END" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "PROGRAM"
        EXIT PARAGRAPH
    END-IF

    EVALUATE WS-PHASE
        WHEN "D"
            PERFORM HANDLE-DATA-LINE
        WHEN "P"
            PERFORM CHECK-PARAGRAPH-LABEL-LINE
            IF WS-LINE-IS-PARAGRAPH = "Y"
                PERFORM HANDLE-PARAGRAPH-LINE
            ELSE
                PERFORM HANDLE-PROCEDURE-LINE
            END-IF
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

EMIT-PARAGRAPH-PROTOTYPES.
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-PARAGRAPH-COUNT
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING "static void " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(PARAGRAPH-C-NAME(WS-WORK-INDEX))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "(void);" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
    END-PERFORM
    .

OPEN-IMPLICIT-PROCEDURE-FUNCTION.
    MOVE SPACES TO WS-FIRST-PARAGRAPH-C-NAME
    IF WS-IS-SUBPROGRAM = "Y"
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING "void " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-PROGRAM-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "(void **minicobc_args)" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        MOVE "int main(int argc, char **argv)" TO WS-EMIT-PAYLOAD
    END-IF
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "N" TO WS-RETURN-EMITTED
    IF WS-IS-SUBPROGRAM = "Y"
        PERFORM EMIT-UNIT-INIT-CALL
        PERFORM EMIT-SUBPROGRAM-STATE-PROLOGUE
        PERFORM EMIT-LOCAL-STORAGE-SHADOWS
    ELSE
        MOVE "minicobc_argc = argc;" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE "minicobc_argv = argv;" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        PERFORM EMIT-UNIT-INIT-CALL
    END-IF
    MOVE "Y" TO WS-PROCEDURE-FUNC-OPEN
    .

OPEN-ENTRY-PROCEDURE-FUNCTION.
    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "static void " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-ENTRY-PARAGRAPH-C-NAME)
        DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "(void)" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "N" TO WS-RETURN-EMITTED
    MOVE "Y" TO WS-PROCEDURE-FUNC-OPEN
    MOVE "Y" TO WS-HAS-ENTRY-PARAGRAPH
    .

HANDLE-PARAGRAPH-LINE.
    PERFORM FLUSH-PENDING-ASSIGNMENT

    IF WS-BLOCK-DEPTH NOT = 0
        MOVE "paragraph label inside open block is not supported"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-PROCEDURE-FUNC-OPEN = "Y"
        PERFORM CLOSE-CURRENT-PROCEDURE-FUNCTION
    END-IF

    MOVE TOKEN-UPPER(1) TO WS-SEARCH-NAME
    PERFORM FIND-PARAGRAPH
    IF WS-PARAGRAPH-INDEX = 0
        MOVE "unknown paragraph label" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "static void " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(PARAGRAPH-C-NAME(WS-PARAGRAPH-INDEX))
        DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "(void)" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "N" TO WS-RETURN-EMITTED
    MOVE "Y" TO WS-PROCEDURE-FUNC-OPEN
    .

CLOSE-CURRENT-PROCEDURE-FUNCTION.
    PERFORM FLUSH-PENDING-ASSIGNMENT
    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "N" TO WS-PROCEDURE-FUNC-OPEN
    .

HANDLE-DATA-LINE.
    IF WS-TOKEN-COUNT < 2
        EXIT PARAGRAPH
    END-IF

    MOVE TOKEN-RAW(1) TO WS-TOKEN-WORK
    PERFORM TOKEN-WORK-IS-INTEGER
    IF WS-FOLD-NUMERIC-OK NOT = "Y"
        EXIT PARAGRAPH
    END-IF
    MOVE FUNCTION NUMVAL(FUNCTION TRIM(TOKEN-RAW(1))) TO WS-CURRENT-LEVEL
    PERFORM CLOSE-GROUPS-FOR-CURRENT-LEVEL

    MOVE 0 TO WS-PIC-POS
    MOVE 0 TO WS-VALUE-POS
    MOVE 0 TO WS-OCCURS-POS
    MOVE 0 TO WS-REDEFINES-POS
    PERFORM VARYING WS-WORK-INDEX FROM 3 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        EVALUATE TOKEN-UPPER(WS-WORK-INDEX)
            WHEN "PIC"
                MOVE WS-WORK-INDEX TO WS-PIC-POS
            WHEN "VALUE"
                MOVE WS-WORK-INDEX TO WS-VALUE-POS
            WHEN "OCCURS"
                MOVE WS-WORK-INDEX TO WS-OCCURS-POS
            WHEN "REDEFINES"
                MOVE WS-WORK-INDEX TO WS-REDEFINES-POS
            WHEN OTHER
                CONTINUE
        END-EVALUATE
    END-PERFORM

    IF WS-CURRENT-LEVEL = 78
        PERFORM HANDLE-LEVEL-78-CONSTANT
        EXIT PARAGRAPH
    END-IF

    ADD 1 TO WS-SYMBOL-COUNT
    IF WS-SYMBOL-COUNT > 256
        MOVE "too many declared variables" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(2) TO SYMBOL-NAME(WS-SYMBOL-COUNT)
    MOVE TOKEN-UPPER(2) TO WS-C-NAME-WORK
    INSPECT WS-C-NAME-WORK REPLACING ALL "-" BY "_"
    IF FUNCTION TRIM(SYMBOL-NAME(WS-SYMBOL-COUNT)) = "FILLER"
        MOVE SPACES TO WS-C-NAME-WORK
        MOVE 1 TO WS-APPEND-PTR
        STRING "FILLER_" DELIMITED BY SIZE
            INTO WS-C-NAME-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
        MOVE WS-SYMBOL-COUNT TO WS-PLAIN-NUMERIC
        PERFORM LOAD-PLAIN-INTEGER-TEXT
        STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
            INTO WS-C-NAME-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    MOVE WS-C-NAME-WORK TO SYMBOL-C-NAME(WS-SYMBOL-COUNT)
    MOVE "N" TO SYMBOL-KIND(WS-SYMBOL-COUNT)
    MOVE WS-CURRENT-LEVEL TO SYMBOL-LEVEL(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-PARENT(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-FIRST-CHILD(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-LAST-CHILD(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-REDEFINES(WS-SYMBOL-COUNT)
    MOVE 1 TO SYMBOL-OCCURS(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-COUNT)
    MOVE "Y" TO SYMBOL-EMIT-DECL(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
    MOVE "Y" TO SYMBOL-ZERO-FILL(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-PACKED-WIDTH(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-STORAGE-OFFSET(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-OVERLAY-ROOT(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
    MOVE "N" TO SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT)
    MOVE "N" TO SYMBOL-READONLY-VALUE(WS-SYMBOL-COUNT)
    MOVE WS-DATA-SECTION TO SYMBOL-STORAGE-CLASS(WS-SYMBOL-COUNT)
    IF WS-DATA-SECTION = "L"
        MOVE "N" TO SYMBOL-EMIT-DECL(WS-SYMBOL-COUNT)
    END-IF

    IF WS-OCCURS-POS > 0
        IF WS-OCCURS-POS + 1 > WS-TOKEN-COUNT
            MOVE "OCCURS requires a count" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE FUNCTION NUMVAL(FUNCTION TRIM(TOKEN-RAW(WS-OCCURS-POS + 1)))
            TO SYMBOL-OCCURS(WS-SYMBOL-COUNT)
        IF SYMBOL-OCCURS(WS-SYMBOL-COUNT) < 1
            MOVE "OCCURS count must be positive" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
    END-IF

    IF WS-PIC-POS = 0
        IF WS-VALUE-POS > 0
            MOVE "group VALUE is not supported yet" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE "G" TO SYMBOL-KIND(WS-SYMBOL-COUNT)
        MOVE "N" TO SYMBOL-EMIT-DECL(WS-SYMBOL-COUNT)
        IF WS-REDEFINES-POS > 0
            IF WS-REDEFINES-POS = WS-TOKEN-COUNT
                MOVE "REDEFINES requires a target name" TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
            MOVE TOKEN-UPPER(WS-REDEFINES-POS + 1) TO WS-SEARCH-NAME
            PERFORM FIND-SYMBOL
            IF WS-SYMBOL-INDEX = 0
                MOVE "REDEFINES target was not declared"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
            MOVE WS-SYMBOL-INDEX TO SYMBOL-REDEFINES(WS-SYMBOL-COUNT)
        END-IF
        PERFORM ASSIGN-OCCURS-CONTEXT
        PERFORM REGISTER-SYMBOL-WITH-OPEN-GROUPS
        ADD 1 TO WS-GROUP-DEPTH
        IF WS-GROUP-DEPTH > 64
            MOVE "too many nested groups" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-CURRENT-LEVEL TO GROUP-LEVEL(WS-GROUP-DEPTH)
        MOVE WS-SYMBOL-COUNT TO GROUP-SYMBOL-INDEX(WS-GROUP-DEPTH)
        EXIT PARAGRAPH
    END-IF

    PERFORM CAPTURE-PIC-WIDTH
    PERFORM CAPTURE-C-TYPE

    IF WS-REDEFINES-POS > 0
        IF WS-REDEFINES-POS = WS-TOKEN-COUNT
            MOVE "REDEFINES requires a target name" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE TOKEN-UPPER(WS-REDEFINES-POS + 1) TO WS-SEARCH-NAME
        PERFORM FIND-SYMBOL
        IF WS-SYMBOL-INDEX = 0
            MOVE "REDEFINES target was not declared" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        IF WS-VALUE-POS > 0
            MOVE "VALUE on REDEFINES items is not supported yet"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-SYMBOL-INDEX TO SYMBOL-REDEFINES(WS-SYMBOL-COUNT)
        IF SYMBOL-KIND(WS-SYMBOL-COUNT) = "G"
            MOVE "N" TO SYMBOL-EMIT-DECL(WS-SYMBOL-COUNT)
        END-IF
    END-IF

    IF WS-VALUE-POS > 0 AND WS-VALUE-POS < WS-TOKEN-COUNT
        MOVE "Y" TO SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT)
        IF SYMBOL-KIND(WS-SYMBOL-COUNT) = "A" AND
            (TOKEN-UPPER(WS-VALUE-POS + 1) = "SPACE" OR
            TOKEN-UPPER(WS-VALUE-POS + 1) = "SPACES")
            MOVE '" "' TO SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT)
        ELSE
            IF SYMBOL-KIND(WS-SYMBOL-COUNT) = "N" AND
                (TOKEN-UPPER(WS-VALUE-POS + 1) = "ZERO" OR
                TOKEN-UPPER(WS-VALUE-POS + 1) = "ZEROS" OR
                TOKEN-UPPER(WS-VALUE-POS + 1) = "ZEROES")
                MOVE "0" TO SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT)
            ELSE
                MOVE TOKEN-RAW(WS-VALUE-POS + 1)
                    TO SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT)
            END-IF
        END-IF
        IF WS-OPTIMIZE = "Y" AND SYMBOL-KIND(WS-SYMBOL-COUNT) = "N" AND
            SYMBOL-OCCURS(WS-SYMBOL-COUNT) = 1 AND
            WS-REDEFINES-POS = 0
            MOVE SYMBOL-NAME(WS-SYMBOL-COUNT) TO WS-SEARCH-NAME
            PERFORM FIND-FACT
            IF WS-FACT-INDEX = 0 OR FACT-WRITE-COUNT(WS-FACT-INDEX) = 0
                MOVE "Y" TO SYMBOL-READONLY-VALUE(WS-SYMBOL-COUNT)
            END-IF
        END-IF
    END-IF

    PERFORM ASSIGN-OCCURS-CONTEXT
    PERFORM REGISTER-SYMBOL-WITH-OPEN-GROUPS

    IF SYMBOL-EMIT-DECL(WS-SYMBOL-COUNT) = "Y"
        IF SYMBOL-KIND(WS-SYMBOL-COUNT) = "A"
            PERFORM EMIT-ALPHA-DECL
        ELSE
            PERFORM EMIT-NUMERIC-DECL
        END-IF
    END-IF
    .

HANDLE-LEVEL-78-CONSTANT.
    IF WS-TOKEN-COUNT < 4 OR WS-VALUE-POS = 0 OR WS-VALUE-POS = WS-TOKEN-COUNT
        MOVE "level 78 requires NAME VALUE literal"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    ADD 1 TO WS-SYMBOL-COUNT
    IF WS-SYMBOL-COUNT > 256
        MOVE "too many declared variables" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(2) TO SYMBOL-NAME(WS-SYMBOL-COUNT)
    MOVE TOKEN-RAW(WS-VALUE-POS + 1) TO SYMBOL-C-NAME(WS-SYMBOL-COUNT)
    MOVE TOKEN-RAW(WS-VALUE-POS + 1) TO SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT)
    MOVE "N" TO SYMBOL-KIND(WS-SYMBOL-COUNT)
    MOVE 78 TO SYMBOL-LEVEL(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-PARENT(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-FIRST-CHILD(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-LAST-CHILD(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-REDEFINES(WS-SYMBOL-COUNT)
    MOVE 1 TO SYMBOL-OCCURS(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-COUNT)
    MOVE "N" TO SYMBOL-EMIT-DECL(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
    MOVE "Y" TO SYMBOL-ZERO-FILL(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-PACKED-WIDTH(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-STORAGE-OFFSET(WS-SYMBOL-COUNT)
    MOVE 0 TO SYMBOL-OVERLAY-ROOT(WS-SYMBOL-COUNT)
    MOVE "long long" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
    MOVE "%lld" TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
    MOVE "Y" TO SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT)
    MOVE "Y" TO SYMBOL-READONLY-VALUE(WS-SYMBOL-COUNT)
    MOVE "W" TO SYMBOL-STORAGE-CLASS(WS-SYMBOL-COUNT)

    MOVE TOKEN-RAW(WS-VALUE-POS + 1) TO WS-TOKEN-WORK
    IF WS-TOKEN-WORK(1:1) = QUOTE
        MOVE "A" TO SYMBOL-KIND(WS-SYMBOL-COUNT)
        MOVE FUNCTION LENGTH(FUNCTION TRIM(WS-TOKEN-WORK))
            TO WS-WORK-INDEX
        IF WS-WORK-INDEX >= 2
            COMPUTE SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) =
                WS-WORK-INDEX - 2
            MOVE SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
                TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            MOVE WS-PLAIN-TEXT TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
        END-IF
        MOVE "const char *" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
    END-IF
    .

CLOSE-GROUPS-FOR-CURRENT-LEVEL.
    IF WS-CURRENT-LEVEL = 66 OR WS-CURRENT-LEVEL = 77 OR
        WS-CURRENT-LEVEL = 88
        PERFORM UNTIL WS-GROUP-DEPTH = 0
            MOVE 0 TO GROUP-LEVEL(WS-GROUP-DEPTH)
            MOVE 0 TO GROUP-SYMBOL-INDEX(WS-GROUP-DEPTH)
            SUBTRACT 1 FROM WS-GROUP-DEPTH
        END-PERFORM
        EXIT PARAGRAPH
    END-IF

    PERFORM UNTIL WS-GROUP-DEPTH = 0 OR
        WS-CURRENT-LEVEL > GROUP-LEVEL(WS-GROUP-DEPTH)
        MOVE 0 TO GROUP-LEVEL(WS-GROUP-DEPTH)
        MOVE 0 TO GROUP-SYMBOL-INDEX(WS-GROUP-DEPTH)
        SUBTRACT 1 FROM WS-GROUP-DEPTH
    END-PERFORM
    .

REGISTER-SYMBOL-WITH-OPEN-GROUPS.
    IF WS-GROUP-DEPTH = 0
        EXIT PARAGRAPH
    END-IF

    MOVE GROUP-SYMBOL-INDEX(WS-GROUP-DEPTH)
        TO SYMBOL-PARENT(WS-SYMBOL-COUNT)
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-GROUP-DEPTH
        MOVE GROUP-SYMBOL-INDEX(WS-WORK-INDEX) TO WS-SYMBOL-INDEX
        IF SYMBOL-FIRST-CHILD(WS-SYMBOL-INDEX) = 0
            MOVE WS-SYMBOL-COUNT TO SYMBOL-FIRST-CHILD(WS-SYMBOL-INDEX)
        END-IF
        MOVE WS-SYMBOL-COUNT TO SYMBOL-LAST-CHILD(WS-SYMBOL-INDEX)
    END-PERFORM
    .

ASSIGN-OCCURS-CONTEXT.
    MOVE 0 TO SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-COUNT)
    MOVE 0 TO WS-OCCURS-ANCESTOR-INDEX
    PERFORM VARYING WS-WORK-INDEX FROM WS-GROUP-DEPTH BY -1
        UNTIL WS-WORK-INDEX < 1
        MOVE GROUP-SYMBOL-INDEX(WS-WORK-INDEX) TO WS-SYMBOL-INDEX
        IF SYMBOL-OCCURS(WS-SYMBOL-INDEX) > 1
            IF WS-OCCURS-ANCESTOR-INDEX = 0
                MOVE WS-SYMBOL-INDEX TO WS-OCCURS-ANCESTOR-INDEX
            ELSE
                MOVE "nested group OCCURS is not supported yet"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
        END-IF
    END-PERFORM

    IF WS-OCCURS-ANCESTOR-INDEX > 0
        IF SYMBOL-OCCURS(WS-SYMBOL-COUNT) > 1 AND
            SYMBOL-KIND(WS-SYMBOL-COUNT) = "G"
            MOVE "nested OCCURS inside group OCCURS is not supported yet"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-OCCURS-ANCESTOR-INDEX
            TO SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-COUNT)
    END-IF
    .

LOAD-EFFECTIVE-OCCURS.
    MOVE SYMBOL-OCCURS(WS-SYMBOL-INDEX) TO WS-EFFECTIVE-OCCURS
    IF SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-INDEX) > 0
        IF WS-EFFECTIVE-OCCURS = 1
            MOVE SYMBOL-OCCURS(SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-INDEX))
                TO WS-EFFECTIVE-OCCURS
        ELSE
            COMPUTE WS-EFFECTIVE-OCCURS =
                WS-EFFECTIVE-OCCURS *
                SYMBOL-OCCURS(SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-INDEX))
        END-IF
    END-IF
    .

SAVE-GROUP-REF-AS-SOURCE.
    MOVE WS-REF-HAS-INDEX TO WS-GROUP-SOURCE-HAS-INDEX
    MOVE WS-REF-INDEX-TOKEN TO WS-GROUP-SOURCE-INDEX-TOKEN
    .

SAVE-GROUP-REF-AS-TARGET.
    MOVE WS-REF-HAS-INDEX TO WS-GROUP-TARGET-HAS-INDEX
    MOVE WS-REF-INDEX-TOKEN TO WS-GROUP-TARGET-INDEX-TOKEN
    .

SET-CURRENT-GROUP-INDEX-FROM-SOURCE.
    MOVE WS-GROUP-SOURCE-HAS-INDEX TO WS-GROUP-CURRENT-HAS-INDEX
    MOVE WS-GROUP-SOURCE-INDEX-TOKEN TO WS-GROUP-CURRENT-INDEX-TOKEN
    .

SET-CURRENT-GROUP-INDEX-FROM-TARGET.
    MOVE WS-GROUP-TARGET-HAS-INDEX TO WS-GROUP-CURRENT-HAS-INDEX
    MOVE WS-GROUP-TARGET-INDEX-TOKEN TO WS-GROUP-CURRENT-INDEX-TOKEN
    .

CLEAR-CURRENT-GROUP-INDEX.
    MOVE "N" TO WS-GROUP-CURRENT-HAS-INDEX
    MOVE SPACES TO WS-GROUP-CURRENT-INDEX-TOKEN
    .

BUILD-GROUP-DESCENDANT-C-EXPR.
    MOVE SPACES TO WS-REF-C-EXPR
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
        DELIMITED BY SIZE
        INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    IF SYMBOL-OCCURS(WS-SYMBOL-INDEX) > 1
        MOVE "group operations with OCCURS children are not supported yet"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    IF SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-INDEX) > 0
        IF WS-GROUP-CURRENT-HAS-INDEX NOT = "Y"
            MOVE "group OCCURS reference needs an index"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        STRING "[(" DELIMITED BY SIZE
            INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-GROUP-CURRENT-INDEX-TOKEN)
            DELIMITED BY SIZE
            INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ") - 1]" DELIMITED BY SIZE
            INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    .

FINALIZE-DATA-LAYOUT.
    IF WS-DATA-LAYOUT-READY = "Y"
        EXIT PARAGRAPH
    END-IF

    MOVE 0 TO WS-OVERLAY-ROOT-COUNT
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        MOVE 0 TO SYMBOL-PACKED-WIDTH(WS-WORK-INDEX)
        MOVE 0 TO SYMBOL-STORAGE-OFFSET(WS-WORK-INDEX)
        MOVE 0 TO SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX)
        IF SYMBOL-KIND(WS-WORK-INDEX) NOT = "G"
            COMPUTE SYMBOL-PACKED-WIDTH(WS-WORK-INDEX) =
                SYMBOL-DISPLAY-WIDTH(WS-WORK-INDEX)
            IF SYMBOL-OCCURS(WS-WORK-INDEX) > 1
                COMPUTE SYMBOL-PACKED-WIDTH(WS-WORK-INDEX) =
                    SYMBOL-DISPLAY-WIDTH(WS-WORK-INDEX) *
                    SYMBOL-OCCURS(WS-WORK-INDEX)
            END-IF
        END-IF
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM WS-SYMBOL-COUNT BY -1
        UNTIL WS-WORK-INDEX < 1
        IF SYMBOL-KIND(WS-WORK-INDEX) = "G"
            MOVE 0 TO SYMBOL-PACKED-WIDTH(WS-WORK-INDEX)
            PERFORM VARYING WS-WORK-INDEX-2
                FROM SYMBOL-FIRST-CHILD(WS-WORK-INDEX) BY 1
                UNTIL WS-WORK-INDEX-2 > SYMBOL-LAST-CHILD(WS-WORK-INDEX)
                IF SYMBOL-PARENT(WS-WORK-INDEX-2) = WS-WORK-INDEX
                    ADD SYMBOL-PACKED-WIDTH(WS-WORK-INDEX-2)
                        TO SYMBOL-PACKED-WIDTH(WS-WORK-INDEX)
                END-IF
            END-PERFORM
            IF SYMBOL-OCCURS(WS-WORK-INDEX) > 1
                COMPUTE SYMBOL-PACKED-WIDTH(WS-WORK-INDEX) =
                    SYMBOL-PACKED-WIDTH(WS-WORK-INDEX) *
                    SYMBOL-OCCURS(WS-WORK-INDEX)
            END-IF
        END-IF
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-REDEFINES(WS-WORK-INDEX) > 0
            MOVE SYMBOL-REDEFINES(WS-WORK-INDEX) TO WS-SYMBOL-INDEX
            PERFORM RESOLVE-REDEFINES-STORAGE-ROOT
            MOVE WS-SYMBOL-INDEX TO WS-LAYOUT-ROOT-INDEX
            IF SYMBOL-OVERLAY-ROOT(WS-LAYOUT-ROOT-INDEX) = 0
                MOVE WS-LAYOUT-ROOT-INDEX
                    TO SYMBOL-OVERLAY-ROOT(WS-LAYOUT-ROOT-INDEX)
                ADD 1 TO WS-OVERLAY-ROOT-COUNT
            END-IF
            MOVE WS-LAYOUT-ROOT-INDEX
                TO SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX)
        END-IF
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX) = 0 AND
            SYMBOL-PARENT(WS-WORK-INDEX) > 0 AND
            SYMBOL-OVERLAY-ROOT(SYMBOL-PARENT(WS-WORK-INDEX)) > 0
            MOVE SYMBOL-OVERLAY-ROOT(SYMBOL-PARENT(WS-WORK-INDEX))
                TO SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX)
        END-IF
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-REDEFINES(WS-WORK-INDEX) > 0
            IF SYMBOL-PACKED-WIDTH(WS-WORK-INDEX) NOT =
                SYMBOL-PACKED-WIDTH(SYMBOL-REDEFINES(WS-WORK-INDEX))
                MOVE "REDEFINES currently requires the same packed width"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
        END-IF
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX) > 0
            IF WS-WORK-INDEX = SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX)
                MOVE 0 TO SYMBOL-STORAGE-OFFSET(WS-WORK-INDEX)
            ELSE
                IF SYMBOL-REDEFINES(WS-WORK-INDEX) > 0
                    MOVE SYMBOL-STORAGE-OFFSET(
                        SYMBOL-REDEFINES(WS-WORK-INDEX))
                        TO SYMBOL-STORAGE-OFFSET(WS-WORK-INDEX)
                ELSE
                    MOVE SYMBOL-PARENT(WS-WORK-INDEX)
                        TO WS-LAYOUT-TARGET-INDEX
                    MOVE SYMBOL-STORAGE-OFFSET(WS-LAYOUT-TARGET-INDEX)
                        TO WS-LAYOUT-OFFSET
                    PERFORM VARYING WS-WORK-INDEX-2
                        FROM SYMBOL-FIRST-CHILD(WS-LAYOUT-TARGET-INDEX) BY 1
                        UNTIL WS-WORK-INDEX-2 >= WS-WORK-INDEX
                        IF SYMBOL-PARENT(WS-WORK-INDEX-2) =
                            WS-LAYOUT-TARGET-INDEX
                            ADD SYMBOL-PACKED-WIDTH(WS-WORK-INDEX-2)
                                TO WS-LAYOUT-OFFSET
                        END-IF
                    END-PERFORM
                    MOVE WS-LAYOUT-OFFSET
                        TO SYMBOL-STORAGE-OFFSET(WS-WORK-INDEX)
                END-IF
            END-IF
        END-IF
    END-PERFORM

    MOVE "Y" TO WS-DATA-LAYOUT-READY
    .

RESOLVE-REDEFINES-STORAGE-ROOT.
    IF SYMBOL-REDEFINES(WS-SYMBOL-INDEX) > 0
        MOVE SYMBOL-REDEFINES(WS-SYMBOL-INDEX) TO WS-SYMBOL-INDEX
        PERFORM RESOLVE-REDEFINES-STORAGE-ROOT
    END-IF
    .

BUILD-OVERLAY-BUFFER-NAME.
    MOVE SPACES TO WS-OVERLAY-BUFFER-NAME
    MOVE 1 TO WS-APPEND-PTR
    STRING "minicobc_overlay_" DELIMITED BY SIZE
        INTO WS-OVERLAY-BUFFER-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    MOVE WS-LAYOUT-ROOT-INDEX TO WS-PLAIN-NUMERIC
    PERFORM LOAD-PLAIN-INTEGER-TEXT
    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
        INTO WS-OVERLAY-BUFFER-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    .

BUILD-OVERLAY-SYNC-NAME.
    MOVE SPACES TO WS-OVERLAY-SYNC-NAME
    MOVE 1 TO WS-APPEND-PTR
    STRING "minicobc_overlay_sync_" DELIMITED BY SIZE
        INTO WS-OVERLAY-SYNC-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    MOVE WS-LAYOUT-ROOT-INDEX TO WS-PLAIN-NUMERIC
    PERFORM LOAD-PLAIN-INTEGER-TEXT
    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
        INTO WS-OVERLAY-SYNC-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    .

BUILD-OVERLAY-STORE-NAME.
    MOVE SPACES TO WS-OVERLAY-STORE-NAME
    MOVE 1 TO WS-APPEND-PTR
    STRING "minicobc_overlay_store_" DELIMITED BY SIZE
        INTO WS-OVERLAY-STORE-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    MOVE WS-LAYOUT-ROOT-INDEX TO WS-PLAIN-NUMERIC
    PERFORM LOAD-PLAIN-INTEGER-TEXT
    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
        INTO WS-OVERLAY-STORE-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "_" DELIMITED BY SIZE
        INTO WS-OVERLAY-STORE-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    MOVE WS-SYMBOL-INDEX TO WS-PLAIN-NUMERIC
    PERFORM LOAD-PLAIN-INTEGER-TEXT
    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
        INTO WS-OVERLAY-STORE-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    .

EMIT-OVERLAY-HELPERS.
    IF WS-OVERLAY-ROOT-COUNT = 0
        EXIT PARAGRAPH
    END-IF

    MOVE "static long long minicobc_num_read(const char *src, int width)"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "memset(minicobc_group_field, 0, sizeof(minicobc_group_field));"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 'snprintf(minicobc_group_field, sizeof(minicobc_group_field), "%.*s", width, src);'
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "return strtoll(minicobc_group_field, NULL, 10);"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE

    MOVE "static void minicobc_num_write(char *dst, int width, long long value)"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "memset(minicobc_group_field, 0, sizeof(minicobc_group_field));"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 'snprintf(minicobc_group_field, sizeof(minicobc_group_field), "%0*lld", width, value);'
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "memcpy(dst, minicobc_group_field, width);" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE

    MOVE "static void minicobc_alpha_read(char *dst, size_t dst_size, const char *src, int width)"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "size_t usable = 0;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "if (dst_size == 0) return;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "usable = (size_t) width;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "if (usable + 1 > dst_size) usable = dst_size - 1;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "memcpy(dst, src, usable);" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "dst[usable] = '\0';" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE

    MOVE "static void minicobc_alpha_write(char *dst, int width, const char *src)"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    MOVE "memset(minicobc_group_field, 0, sizeof(minicobc_group_field));"
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 'snprintf(minicobc_group_field, sizeof(minicobc_group_field), "%-*.*s", width, width, src);'
        TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "memcpy(dst, minicobc_group_field, width);" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX) = WS-WORK-INDEX
            MOVE WS-WORK-INDEX TO WS-LAYOUT-ROOT-INDEX
            PERFORM BUILD-OVERLAY-BUFFER-NAME
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING "static char " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(WS-OVERLAY-BUFFER-NAME) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING "[" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            MOVE SYMBOL-PACKED-WIDTH(WS-LAYOUT-ROOT-INDEX) TO WS-PLAIN-NUMERIC
            ADD 1 TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING "] = {0};" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-LINE
        END-IF
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX) = WS-WORK-INDEX
            MOVE WS-WORK-INDEX TO WS-LAYOUT-ROOT-INDEX
            PERFORM EMIT-OVERLAY-SYNC-FUNCTION
        END-IF
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX) = WS-WORK-INDEX
            MOVE WS-WORK-INDEX TO WS-LAYOUT-ROOT-INDEX
            PERFORM VARYING WS-WORK-INDEX-2 FROM 1 BY 1
                UNTIL WS-WORK-INDEX-2 > WS-SYMBOL-COUNT
                IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX-2) =
                    WS-LAYOUT-ROOT-INDEX
                    MOVE WS-WORK-INDEX-2 TO WS-SYMBOL-INDEX
                    PERFORM EMIT-OVERLAY-STORE-FUNCTION
                END-IF
            END-PERFORM
        END-IF
    END-PERFORM

    MOVE "static void minicobc_overlay_init(void)" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX) = WS-WORK-INDEX
            MOVE WS-WORK-INDEX TO WS-LAYOUT-ROOT-INDEX
            MOVE WS-WORK-INDEX TO WS-SYMBOL-INDEX
            PERFORM BUILD-OVERLAY-STORE-NAME
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING FUNCTION TRIM(WS-OVERLAY-STORE-NAME) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING "();" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-LINE
        END-IF
    END-PERFORM
    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    .

EMIT-OVERLAY-SYNC-FUNCTION.
    MOVE WS-WORK-INDEX TO WS-SAVED-WORK-INDEX
    PERFORM BUILD-OVERLAY-BUFFER-NAME
    PERFORM BUILD-OVERLAY-SYNC-NAME

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "static void " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-OVERLAY-SYNC-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "(void)" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE 1 TO WS-INDENT-LEVEL

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-OVERLAY-BUFFER-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "[" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    MOVE SYMBOL-PACKED-WIDTH(WS-LAYOUT-ROOT-INDEX) TO WS-PLAIN-NUMERIC
    PERFORM LOAD-PLAIN-INTEGER-TEXT
    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "] = '\0';" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-SYMBOL-COUNT
        IF SYMBOL-OVERLAY-ROOT(WS-WORK-INDEX) = WS-LAYOUT-ROOT-INDEX AND
            SYMBOL-KIND(WS-WORK-INDEX) NOT = "G"
            MOVE WS-WORK-INDEX TO WS-SYMBOL-INDEX
            PERFORM EMIT-OVERLAY-FIELD-READ
        END-IF
    END-PERFORM

    MOVE 0 TO WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    MOVE WS-SAVED-WORK-INDEX TO WS-WORK-INDEX
    .

EMIT-OVERLAY-FIELD-READ.
    MOVE WS-SYMBOL-INDEX TO WS-SAVED-SYMBOL-INDEX
    IF SYMBOL-OCCURS-ANCESTOR(WS-SYMBOL-INDEX) = 0 AND
        SYMBOL-OCCURS(WS-SYMBOL-INDEX) = 1
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING "minicobc_alpha_read(" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ", sizeof(" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING "), " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(WS-OVERLAY-BUFFER-NAME) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
