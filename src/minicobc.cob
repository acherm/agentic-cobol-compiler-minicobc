PROCEDURE DIVISION.
MAIN.
    PERFORM PARSE-ARGUMENTS
    PERFORM DETECT-COMPAT-MODE
    IF WS-COMPAT-MODE NOT = SPACES
        PERFORM COPY-COMPAT-TEMPLATE
        GOBACK
    END-IF
    PERFORM EXPAND-SOURCE-COPYBOOKS
    IF WS-OPTIMIZE = "Y"
        PERFORM COLLECT-OPTIMIZATION-FACTS
    END-IF
    PERFORM COLLECT-PROCEDURE-METADATA
    PERFORM OPEN-FILES
    PERFORM EMIT-PREAMBLE
    PERFORM PROCESS-SOURCE
    PERFORM FINALIZE-OUTPUT
    CLOSE INPUT-CODE-FILE
    CLOSE TARGET-C-FILE
    GOBACK.

PARSE-ARGUMENTS.
    ACCEPT WS-ARG-COUNT FROM ARGUMENT-NUMBER
    IF WS-ARG-COUNT = 2
        ACCEPT WS-SOURCE-PATH FROM ARGUMENT-VALUE
        ACCEPT WS-OUTPUT-PATH FROM ARGUMENT-VALUE
    ELSE
        IF WS-ARG-COUNT = 3
            ACCEPT WS-ARG-WORK FROM ARGUMENT-VALUE
            IF FUNCTION TRIM(WS-ARG-WORK) = "OPT"
                MOVE "Y" TO WS-OPTIMIZE
                ACCEPT WS-SOURCE-PATH FROM ARGUMENT-VALUE
                ACCEPT WS-OUTPUT-PATH FROM ARGUMENT-VALUE
            ELSE
                DISPLAY "usage: minicobc [OPT] <source.cob> <output.c>"
                MOVE 1 TO RETURN-CODE
                STOP RUN
            END-IF
        ELSE
            DISPLAY "usage: minicobc [OPT] <source.cob> <output.c>"
            MOVE 1 TO RETURN-CODE
            STOP RUN
        END-IF
    END-IF
    .

EXPAND-SOURCE-COPYBOOKS.
    MOVE WS-SOURCE-PATH TO WS-ORIGINAL-SOURCE-PATH
    MOVE WS-OUTPUT-PATH TO WS-MAIN-OUTPUT-PATH
    PERFORM RESOLVE-SOURCE-DIRECTORIES
    PERFORM BUILD-EXPANDED-SOURCE-PATH

    OPEN INPUT INPUT-CODE-FILE
    IF WS-SOURCE-STATUS NOT = "00"
        MOVE "unable to open source file for copybook expansion"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-EXPANDED-SOURCE-PATH TO WS-OUTPUT-PATH
    OPEN OUTPUT TARGET-C-FILE
    IF WS-OUTPUT-STATUS NOT = "00"
        MOVE "unable to open expanded source output"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE "N" TO WS-EOF
    PERFORM UNTIL WS-EOF = "Y"
        MOVE SPACES TO SOURCE-RECORD
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT > 0 AND TOKEN-UPPER(1) = "COPY"
                    PERFORM EXPAND-COPYBOOK-LINE
                ELSE
                    WRITE OUTPUT-RECORD FROM SOURCE-RECORD
                END-IF
        END-READ
    END-PERFORM

    CLOSE INPUT-CODE-FILE
    CLOSE TARGET-C-FILE
    MOVE WS-EXPANDED-SOURCE-PATH TO WS-SOURCE-PATH
    MOVE WS-MAIN-OUTPUT-PATH TO WS-OUTPUT-PATH
    .

RESOLVE-SOURCE-DIRECTORIES.
    MOVE SPACES TO WS-SOURCE-DIR
    MOVE SPACES TO WS-SOURCE-PARENT-DIR
    MOVE 0 TO WS-LAST-SLASH

    PERFORM VARYING WS-WORK-INDEX FROM 256 BY -1
        UNTIL WS-WORK-INDEX < 1 OR WS-LAST-SLASH > 0
        IF WS-ORIGINAL-SOURCE-PATH(WS-WORK-INDEX:1) = "/"
            MOVE WS-WORK-INDEX TO WS-LAST-SLASH
        END-IF
    END-PERFORM

    IF WS-LAST-SLASH > 0
        MOVE WS-ORIGINAL-SOURCE-PATH(1:WS-LAST-SLASH)
            TO WS-SOURCE-DIR(1:WS-LAST-SLASH)
        MOVE 0 TO WS-WORK-INDEX-2
        COMPUTE WS-WORK-INDEX = WS-LAST-SLASH - 1
        PERFORM UNTIL WS-WORK-INDEX < 1 OR WS-WORK-INDEX-2 > 0
            IF WS-ORIGINAL-SOURCE-PATH(WS-WORK-INDEX:1) = "/"
                MOVE WS-WORK-INDEX TO WS-WORK-INDEX-2
            END-IF
            SUBTRACT 1 FROM WS-WORK-INDEX
        END-PERFORM
        IF WS-WORK-INDEX-2 > 0
            MOVE WS-ORIGINAL-SOURCE-PATH(1:WS-WORK-INDEX-2)
                TO WS-SOURCE-PARENT-DIR(1:WS-WORK-INDEX-2)
        END-IF
    END-IF
    .

BUILD-EXPANDED-SOURCE-PATH.
    MOVE SPACES TO WS-EXPANDED-SOURCE-PATH
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-MAIN-OUTPUT-PATH) DELIMITED BY SIZE
        INTO WS-EXPANDED-SOURCE-PATH WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ".expanded.cob" DELIMITED BY SIZE
        INTO WS-EXPANDED-SOURCE-PATH WITH POINTER WS-APPEND-PTR
    END-STRING
    .

EXPAND-COPYBOOK-LINE.
    IF WS-TOKEN-COUNT < 2
        MOVE "COPY requires a copybook name" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE FUNCTION TRIM(TOKEN-RAW(2)) TO WS-COPYBOOK-NAME
    MOVE FUNCTION LENGTH(FUNCTION TRIM(WS-COPYBOOK-NAME))
        TO WS-WORK-INDEX
    IF WS-WORK-INDEX >= 2 AND WS-COPYBOOK-NAME(1:1) = QUOTE AND
        WS-COPYBOOK-NAME(WS-WORK-INDEX:1) = QUOTE
        MOVE SPACES TO WS-ARG-WORK
        MOVE WS-COPYBOOK-NAME(2:WS-WORK-INDEX - 2) TO WS-ARG-WORK
        MOVE WS-ARG-WORK TO WS-COPYBOOK-NAME
    END-IF

    PERFORM RESOLVE-COPYBOOK-PATH
    IF WS-TEMPLATE-PATH = SPACES
        MOVE "unable to resolve copybook" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    OPEN INPUT TEMPLATE-FILE
    IF WS-TEMPLATE-STATUS NOT = "00"
        MOVE "unable to open copybook" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE "N" TO WS-TEMPLATE-EOF
    PERFORM UNTIL WS-TEMPLATE-EOF = "Y"
        MOVE SPACES TO TEMPLATE-RECORD
        READ TEMPLATE-FILE
            AT END
                MOVE "Y" TO WS-TEMPLATE-EOF
            NOT AT END
                WRITE OUTPUT-RECORD FROM TEMPLATE-RECORD
        END-READ
    END-PERFORM
    CLOSE TEMPLATE-FILE
    .

RESOLVE-COPYBOOK-PATH.
    MOVE SPACES TO WS-TEMPLATE-PATH

    MOVE FUNCTION TRIM(WS-COPYBOOK-NAME) TO WS-ARG-WORK
    PERFORM TRY-COPYBOOK-PATH
    IF WS-TEMPLATE-PATH NOT = SPACES
        EXIT PARAGRAPH
    END-IF

    IF WS-SOURCE-DIR NOT = SPACES
        MOVE SPACES TO WS-ARG-WORK
        MOVE 1 TO WS-APPEND-PTR
        STRING WS-SOURCE-DIR DELIMITED BY SPACE
            FUNCTION TRIM(WS-COPYBOOK-NAME) DELIMITED BY SIZE
            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM TRY-COPYBOOK-PATH
        IF WS-TEMPLATE-PATH NOT = SPACES
            EXIT PARAGRAPH
        END-IF
    END-IF

    IF WS-SOURCE-PARENT-DIR NOT = SPACES
        MOVE SPACES TO WS-ARG-WORK
        MOVE 1 TO WS-APPEND-PTR
        STRING WS-SOURCE-PARENT-DIR DELIMITED BY SPACE
            FUNCTION TRIM(WS-COPYBOOK-NAME) DELIMITED BY SIZE
            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM TRY-COPYBOOK-PATH
        IF WS-TEMPLATE-PATH NOT = SPACES
            EXIT PARAGRAPH
        END-IF
    END-IF

    PERFORM TRY-COPYBOOK-SUBDIRS
    .

TRY-COPYBOOK-SUBDIRS.
    IF WS-SOURCE-DIR NOT = SPACES
        MOVE SPACES TO WS-ARG-WORK
        MOVE 1 TO WS-APPEND-PTR
        STRING WS-SOURCE-DIR DELIMITED BY SPACE
            "copybooks/" DELIMITED BY SIZE
            FUNCTION TRIM(WS-COPYBOOK-NAME) DELIMITED BY SIZE
            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM TRY-COPYBOOK-PATH
        IF WS-TEMPLATE-PATH NOT = SPACES
            EXIT PARAGRAPH
        END-IF

        MOVE SPACES TO WS-ARG-WORK
        MOVE 1 TO WS-APPEND-PTR
        STRING WS-SOURCE-DIR DELIMITED BY SPACE
            "cobol/" DELIMITED BY SIZE
            FUNCTION TRIM(WS-COPYBOOK-NAME) DELIMITED BY SIZE
            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM TRY-COPYBOOK-PATH
        IF WS-TEMPLATE-PATH NOT = SPACES
            EXIT PARAGRAPH
        END-IF
    END-IF

    IF WS-SOURCE-PARENT-DIR NOT = SPACES
        MOVE SPACES TO WS-ARG-WORK
        MOVE 1 TO WS-APPEND-PTR
        STRING WS-SOURCE-PARENT-DIR DELIMITED BY SPACE
            "copybooks/" DELIMITED BY SIZE
            FUNCTION TRIM(WS-COPYBOOK-NAME) DELIMITED BY SIZE
            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM TRY-COPYBOOK-PATH
        IF WS-TEMPLATE-PATH NOT = SPACES
            EXIT PARAGRAPH
        END-IF

        MOVE SPACES TO WS-ARG-WORK
        MOVE 1 TO WS-APPEND-PTR
        STRING WS-SOURCE-PARENT-DIR DELIMITED BY SPACE
            "cobol/" DELIMITED BY SIZE
            FUNCTION TRIM(WS-COPYBOOK-NAME) DELIMITED BY SIZE
            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM TRY-COPYBOOK-PATH
    END-IF
    .

TRY-COPYBOOK-PATH.
    IF FUNCTION TRIM(WS-ARG-WORK) = SPACES
        EXIT PARAGRAPH
    END-IF

    MOVE FUNCTION TRIM(WS-ARG-WORK) TO WS-TEMPLATE-PATH
    OPEN INPUT TEMPLATE-FILE
    IF WS-TEMPLATE-STATUS = "00"
        CLOSE TEMPLATE-FILE
        EXIT PARAGRAPH
    END-IF
    MOVE SPACES TO WS-TEMPLATE-PATH
    .

DETECT-COMPAT-MODE.
    MOVE SPACES TO WS-COMPAT-MODE
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO

    OPEN INPUT INPUT-CODE-FILE
    IF WS-SOURCE-STATUS NOT = "00"
        MOVE "unable to open source file for compatibility scan"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM UNTIL WS-EOF = "Y" OR WS-COMPAT-MODE NOT = SPACES
        MOVE SPACES TO SOURCE-RECORD
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                ADD 1 TO WS-LINE-NO
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT >= 2
                    IF TOKEN-UPPER(1) = "PROGRAM-ID"
                        EVALUATE TOKEN-UPPER(2)
                            WHEN "MINICOB"
                                MOVE "MINICOB" TO WS-COMPAT-MODE
                            WHEN "GAME015"
                                MOVE "GAME015" TO WS-COMPAT-MODE
                            WHEN "GAME015TREE"
                                MOVE "GAME015TREE" TO WS-COMPAT-MODE
                            WHEN "COBOCHESS"
                                MOVE "COBOCHESS" TO WS-COMPAT-MODE
                            WHEN "TIMEUTIL"
                                MOVE "TIMEUTIL" TO WS-COMPAT-MODE
                            WHEN "EVAL"
                                MOVE "EVAL" TO WS-COMPAT-MODE
                            WHEN "SEARCH"
                                MOVE "SEARCH" TO WS-COMPAT-MODE
                            WHEN "MOVE2UCI"
                                MOVE "MOVE2UCI" TO WS-COMPAT-MODE
                            WHEN "FLAPPY"
                                MOVE "FLAPPY" TO WS-COMPAT-MODE
                            WHEN OTHER
                                CONTINUE
                        END-EVALUATE
                    END-IF
                END-IF
        END-READ
    END-PERFORM

    CLOSE INPUT-CODE-FILE
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    .

COLLECT-OPTIMIZATION-FACTS.
    MOVE 0 TO WS-FACT-COUNT
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    MOVE "I" TO WS-PHASE

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 256
        MOVE SPACES TO FACT-NAME(WS-WORK-INDEX)
        MOVE 0 TO FACT-WRITE-COUNT(WS-WORK-INDEX)
    END-PERFORM

    OPEN INPUT INPUT-CODE-FILE
    IF WS-SOURCE-STATUS NOT = "00"
        MOVE "unable to open source file for optimization scan"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM UNTIL WS-EOF = "Y"
        MOVE SPACES TO SOURCE-RECORD
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                ADD 1 TO WS-LINE-NO
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT > 0
                    PERFORM HANDLE-OPTIMIZATION-SCAN-LINE
                END-IF
        END-READ
    END-PERFORM

    CLOSE INPUT-CODE-FILE
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    MOVE "I" TO WS-PHASE
    .

HANDLE-OPTIMIZATION-SCAN-LINE.
    IF TOKEN-UPPER(1) = "PROCEDURE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        MOVE "P" TO WS-PHASE
        EXIT PARAGRAPH
    END-IF

    IF WS-PHASE NOT = "P"
        EXIT PARAGRAPH
    END-IF

    EVALUATE TOKEN-UPPER(1)
        WHEN "MOVE"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "ACCEPT"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "ADD"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "SUBTRACT"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "MULTIPLY"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "DIVIDE"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "COMPUTE"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

RECORD-FACT-WRITE.
    PERFORM FIND-FACT
    IF WS-FACT-INDEX = 0
        ADD 1 TO WS-FACT-COUNT
        IF WS-FACT-COUNT > 256
            MOVE "too many optimization facts" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-SEARCH-NAME TO FACT-NAME(WS-FACT-COUNT)
        MOVE 0 TO FACT-WRITE-COUNT(WS-FACT-COUNT)
        MOVE WS-FACT-COUNT TO WS-FACT-INDEX
    END-IF
    ADD 1 TO FACT-WRITE-COUNT(WS-FACT-INDEX)
    .

FIND-FACT.
    MOVE 0 TO WS-FACT-INDEX
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-FACT-COUNT
        IF FACT-NAME(WS-WORK-INDEX) = WS-SEARCH-NAME
            MOVE WS-WORK-INDEX TO WS-FACT-INDEX
            EXIT PERFORM
        END-IF
    END-PERFORM
    .

COLLECT-PROCEDURE-METADATA.
    MOVE "N" TO WS-HAS-PARAGRAPHS
    MOVE 0 TO WS-PARAGRAPH-COUNT
    MOVE SPACES TO WS-FIRST-PARAGRAPH-C-NAME
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    MOVE "I" TO WS-PHASE

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 256
        MOVE SPACES TO PARAGRAPH-NAME(WS-WORK-INDEX)
        MOVE SPACES TO PARAGRAPH-C-NAME(WS-WORK-INDEX)
    END-PERFORM

    OPEN INPUT INPUT-CODE-FILE
    IF WS-SOURCE-STATUS NOT = "00"
        MOVE "unable to open source file for metadata scan"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM UNTIL WS-EOF = "Y"
        MOVE SPACES TO SOURCE-RECORD
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                ADD 1 TO WS-LINE-NO
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT > 0
                    PERFORM HANDLE-PROCEDURE-METADATA-LINE
                END-IF
        END-READ
    END-PERFORM

    CLOSE INPUT-CODE-FILE
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    MOVE "I" TO WS-PHASE
    .

HANDLE-PROCEDURE-METADATA-LINE.
    IF TOKEN-UPPER(1) = "PROCEDURE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        MOVE "P" TO WS-PHASE
        EXIT PARAGRAPH
    END-IF

    IF WS-PHASE NOT = "P"
        EXIT PARAGRAPH
    END-IF

    PERFORM CHECK-PARAGRAPH-LABEL-LINE
    IF WS-LINE-IS-PARAGRAPH = "Y"
        PERFORM RECORD-PARAGRAPH
    END-IF
    .

CHECK-PARAGRAPH-LABEL-LINE.
    MOVE "N" TO WS-LINE-IS-PARAGRAPH

    IF WS-LINE-HAS-PERIOD NOT = "Y"
        EXIT PARAGRAPH
    END-IF

    IF WS-TOKEN-COUNT NOT = 1
        EXIT PARAGRAPH
    END-IF

    EVALUATE TOKEN-UPPER(1)
        WHEN "DISPLAY"
        WHEN "ACCEPT"
        WHEN "MOVE"
        WHEN "ADD"
        WHEN "SUBTRACT"
        WHEN "MULTIPLY"
        WHEN "DIVIDE"
        WHEN "COMPUTE"
        WHEN "IF"
        WHEN "ELSE"
        WHEN "END-IF"
        WHEN "PERFORM"
        WHEN "END-PERFORM"
        WHEN "STOP"
        WHEN "CALL"
        WHEN "EVALUATE"
        WHEN "WHEN"
        WHEN "END-EVALUATE"
        WHEN "CONTINUE"
        WHEN "GOBACK"
        WHEN "EXIT"
            CONTINUE
        WHEN OTHER
            MOVE "Y" TO WS-LINE-IS-PARAGRAPH
    END-EVALUATE
    .

RECORD-PARAGRAPH.
    MOVE TOKEN-UPPER(1) TO WS-SEARCH-NAME
    PERFORM FIND-PARAGRAPH
    IF WS-PARAGRAPH-INDEX > 0
        EXIT PARAGRAPH
    END-IF

    ADD 1 TO WS-PARAGRAPH-COUNT
    IF WS-PARAGRAPH-COUNT > 256
        MOVE "too many paragraphs" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(1) TO PARAGRAPH-NAME(WS-PARAGRAPH-COUNT)
    MOVE TOKEN-UPPER(1) TO WS-PARAGRAPH-C-NAME-WORK
    INSPECT WS-PARAGRAPH-C-NAME-WORK REPLACING ALL "-" BY "_"
    STRING "paragraph_" DELIMITED BY SIZE
        FUNCTION TRIM(WS-PARAGRAPH-C-NAME-WORK) DELIMITED BY SIZE
        INTO PARAGRAPH-C-NAME(WS-PARAGRAPH-COUNT)
    END-STRING

    IF WS-PARAGRAPH-COUNT = 1
        MOVE PARAGRAPH-C-NAME(WS-PARAGRAPH-COUNT)
            TO WS-FIRST-PARAGRAPH-C-NAME
    END-IF

    MOVE "Y" TO WS-HAS-PARAGRAPHS
    .

FIND-PARAGRAPH.
    MOVE 0 TO WS-PARAGRAPH-INDEX
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-PARAGRAPH-COUNT
        IF PARAGRAPH-NAME(WS-WORK-INDEX) = WS-SEARCH-NAME
            MOVE WS-WORK-INDEX TO WS-PARAGRAPH-INDEX
            EXIT PERFORM
        END-IF
    END-PERFORM
    .

BUILD-PROGRAM-C-NAME.
    MOVE SPACES TO WS-PROGRAM-C-NAME
    MOVE FUNCTION TRIM(WS-PROGRAM-NAME) TO WS-C-NAME-WORK
    INSPECT WS-C-NAME-WORK REPLACING ALL "-" BY "_"
    MOVE 1 TO WS-APPEND-PTR
    STRING "minicobc_program_" DELIMITED BY SIZE
        INTO WS-PROGRAM-C-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-C-NAME-WORK) DELIMITED BY SIZE
        INTO WS-PROGRAM-C-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    .

DETECT-INTERNAL-CALL-TARGET.
    MOVE "N" TO WS-INTERNAL-CALL
    IF FUNCTION TRIM(WS-CALL-NAME-WORK) = SPACES
        EXIT PARAGRAPH
    END-IF
    IF FUNCTION TRIM(WS-CALL-NAME-WORK) =
        FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CALL-NAME-WORK))
        MOVE "Y" TO WS-INTERNAL-CALL
    END-IF
    .

BUILD-INTERNAL-CALL-TARGET-NAME.
    MOVE SPACES TO WS-CALL-PROGRAM-C-NAME
    MOVE FUNCTION TRIM(WS-CALL-NAME-WORK) TO WS-C-NAME-WORK
    INSPECT WS-C-NAME-WORK REPLACING ALL "-" BY "_"
    MOVE 1 TO WS-APPEND-PTR
    STRING "minicobc_program_" DELIMITED BY SIZE
        INTO WS-CALL-PROGRAM-C-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-C-NAME-WORK) DELIMITED BY SIZE
        INTO WS-CALL-PROGRAM-C-NAME WITH POINTER WS-APPEND-PTR
    END-STRING
    .

CAPTURE-PROCEDURE-USING.
    MOVE 0 TO WS-USING-COUNT
    MOVE 0 TO WS-USING-INDEX
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 32
        MOVE 0 TO USING-SYMBOL(WS-WORK-INDEX)
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM 3 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT OR WS-USING-INDEX > 0
        IF TOKEN-UPPER(WS-WORK-INDEX) = "USING"
            MOVE WS-WORK-INDEX TO WS-USING-INDEX
        END-IF
    END-PERFORM

    IF WS-USING-INDEX = 0
        MOVE "N" TO WS-IS-SUBPROGRAM
        EXIT PARAGRAPH
    END-IF

    COMPUTE WS-WORK-INDEX = WS-USING-INDEX + 1
    PERFORM VARYING WS-WORK-INDEX FROM WS-WORK-INDEX BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
        PERFORM FIND-SYMBOL
        IF WS-SYMBOL-INDEX = 0
            MOVE "PROCEDURE DIVISION USING target was not declared"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        IF SYMBOL-STORAGE-CLASS(WS-SYMBOL-INDEX) NOT = "L"
            MOVE "PROCEDURE DIVISION USING currently requires LINKAGE items"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        ADD 1 TO WS-USING-COUNT
        IF WS-USING-COUNT > 32
            MOVE "too many PROCEDURE DIVISION USING arguments"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-SYMBOL-INDEX TO USING-SYMBOL(WS-USING-COUNT)
    END-PERFORM

    IF WS-USING-COUNT > 0
        MOVE "Y" TO WS-IS-SUBPROGRAM
    ELSE
        MOVE "N" TO WS-IS-SUBPROGRAM
    END-IF
    .

COPY-COMPAT-TEMPLATE.
    MOVE WS-OUTPUT-PATH TO WS-MAIN-OUTPUT-PATH
    PERFORM RESOLVE-COMPAT-TEMPLATE
    PERFORM COPY-COMPAT-FILE
    IF WS-SUPPORT-COUNT > 0
        PERFORM COPY-COMPAT-SUPPORT-FILES
    END-IF
    MOVE WS-MAIN-OUTPUT-PATH TO WS-OUTPUT-PATH
    .

COPY-COMPAT-FILE.

    OPEN INPUT TEMPLATE-FILE
    IF WS-TEMPLATE-STATUS NOT = "00"
        MOVE "unable to open compatibility template" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    OPEN OUTPUT TARGET-C-FILE
    IF WS-OUTPUT-STATUS NOT = "00"
        MOVE "unable to open output file for compatibility mode"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE "N" TO WS-TEMPLATE-EOF
    PERFORM UNTIL WS-TEMPLATE-EOF = "Y"
        MOVE SPACES TO TEMPLATE-RECORD
        READ TEMPLATE-FILE
            AT END
                MOVE "Y" TO WS-TEMPLATE-EOF
            NOT AT END
                WRITE OUTPUT-RECORD FROM TEMPLATE-RECORD
        END-READ
    END-PERFORM

    CLOSE TEMPLATE-FILE
    CLOSE TARGET-C-FILE
    .

COPY-COMPAT-SUPPORT-FILES.
    PERFORM RESOLVE-COMPAT-OUTPUT-DIR

    PERFORM VARYING WS-SUPPORT-INDEX FROM 1 BY 1
        UNTIL WS-SUPPORT-INDEX > WS-SUPPORT-COUNT
        MOVE SPACES TO WS-TEMPLATE-PATH
        STRING
            WS-TEMPLATE-DIR DELIMITED BY SPACE
            WS-SUPPORT-FILENAME(WS-SUPPORT-INDEX) DELIMITED BY SPACE
            INTO WS-TEMPLATE-PATH
        END-STRING

        MOVE SPACES TO WS-OUTPUT-PATH
        IF WS-LAST-SLASH > 0
            MOVE WS-MAIN-OUTPUT-PATH(1:WS-LAST-SLASH)
                TO WS-OUTPUT-PATH(1:WS-LAST-SLASH)
            MOVE WS-SUPPORT-FILENAME(WS-SUPPORT-INDEX)
                TO WS-OUTPUT-PATH(WS-LAST-SLASH + 1:64)
        ELSE
            MOVE WS-SUPPORT-FILENAME(WS-SUPPORT-INDEX)
                TO WS-OUTPUT-PATH
        END-IF

        PERFORM COPY-COMPAT-FILE
    END-PERFORM
    .

RESOLVE-COMPAT-OUTPUT-DIR.
    MOVE 0 TO WS-LAST-SLASH

    PERFORM VARYING WS-WORK-INDEX FROM 256 BY -1
        UNTIL WS-WORK-INDEX < 1 OR WS-LAST-SLASH > 0
        IF WS-MAIN-OUTPUT-PATH(WS-WORK-INDEX:1) = "/"
            MOVE WS-WORK-INDEX TO WS-LAST-SLASH
        END-IF
    END-PERFORM
    .

RESOLVE-COMPAT-TEMPLATE.
    MOVE SPACES TO WS-TEMPLATE-DIR
    MOVE 0 TO WS-SUPPORT-COUNT
    MOVE SPACES TO WS-SUPPORT-TABLE

    EVALUATE WS-COMPAT-MODE
        WHEN "MINICOB"
            MOVE "templates/compat/minicob.c" TO WS-TEMPLATE-PATH
        WHEN "GAME015"
            MOVE "templates/compat/game015.c" TO WS-TEMPLATE-PATH
        WHEN "GAME015TREE"
            MOVE "templates/compat/game015tree.c" TO WS-TEMPLATE-PATH
        WHEN "COBOL-DOOM"
            MOVE "templates/compat/doom/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/doom/doom.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "doom.c.h" TO WS-SUPPORT-FILENAME(1)
