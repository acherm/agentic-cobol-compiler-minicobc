>>SOURCE FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. MINICOB.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT INPUT-CODE-FILE ASSIGN TO DYNAMIC WS-SOURCE-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-SOURCE-STATUS.
    SELECT TARGET-C-FILE ASSIGN TO DYNAMIC WS-OUTPUT-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-OUTPUT-STATUS.
    SELECT TEMPLATE-FILE ASSIGN TO DYNAMIC WS-TEMPLATE-PATH
        ORGANIZATION IS LINE SEQUENTIAL
        FILE STATUS IS WS-TEMPLATE-STATUS.

DATA DIVISION.
FILE SECTION.
FD INPUT-CODE-FILE.
01 SOURCE-RECORD                    PIC X(8192).

FD TARGET-C-FILE.
01 OUTPUT-RECORD                    PIC X(8192).

FD TEMPLATE-FILE.
01 TEMPLATE-RECORD                  PIC X(8192).

WORKING-STORAGE SECTION.
01 WS-SOURCE-PATH                   PIC X(256) VALUE SPACES.
01 WS-OUTPUT-PATH                   PIC X(256) VALUE SPACES.
01 WS-MAIN-OUTPUT-PATH              PIC X(256) VALUE SPACES.
01 WS-TEMPLATE-PATH                 PIC X(256) VALUE SPACES.
01 WS-TEMPLATE-DIR                  PIC X(256) VALUE SPACES.
01 WS-SUPPORT-SOURCE-PATH           PIC X(256) VALUE SPACES.
01 WS-SUPPORT-TARGET-PATH           PIC X(256) VALUE SPACES.
01 WS-SOURCE-STATUS                 PIC XX VALUE SPACES.
01 WS-OUTPUT-STATUS                 PIC XX VALUE SPACES.
01 WS-TEMPLATE-STATUS               PIC XX VALUE SPACES.
01 WS-ARG-COUNT                     PIC 9(4) COMP-5 VALUE 0.
01 WS-OPTIMIZE                     PIC X VALUE "N".
01 WS-COMPAT-MODE                   PIC X(16) VALUE SPACES.
01 WS-TEMPLATE-EOF                  PIC X VALUE "N".
01 WS-PHASE                         PIC X VALUE "I".
01 WS-PROCEDURE-SEEN                PIC X VALUE "N".
01 WS-RETURN-EMITTED                PIC X VALUE "N".
01 WS-EOF                           PIC X VALUE "N".
01 WS-LINE-NO                       PIC 9(6) VALUE 0.
01 WS-LAST-NONSPACE                 PIC 9(4) COMP-5 VALUE 0.
01 WS-OUT-POS                       PIC 9(4) COMP-5 VALUE 0.
01 WS-SCAN-POS                      PIC 9(4) COMP-5 VALUE 0.
01 WS-START-POS                     PIC 9(4) COMP-5 VALUE 0.
01 WS-TOKEN-LEN                     PIC 9(4) COMP-5 VALUE 0.
01 WS-INDENT-LEVEL                  PIC 9(4) COMP-5 VALUE 0.
01 WS-BLOCK-DEPTH                   PIC 9(4) COMP-5 VALUE 0.
01 WS-TOKEN-COUNT                   PIC 9(4) COMP-5 VALUE 0.
01 WS-SYMBOL-COUNT                  PIC 9(4) COMP-5 VALUE 0.
01 WS-WORK-INDEX                    PIC 9(4) COMP-5 VALUE 0.
01 WS-WORK-INDEX-2                  PIC 9(4) COMP-5 VALUE 0.
01 WS-FOUND-POS                     PIC 9(4) COMP-5 VALUE 0.
01 WS-LAST-SLASH                    PIC 9(4) COMP-5 VALUE 0.
01 WS-SYMBOL-INDEX                  PIC 9(4) COMP-5 VALUE 0.
01 WS-SUPPORT-COUNT                 PIC 9(4) COMP-5 VALUE 0.
01 WS-SUPPORT-INDEX                 PIC 9(4) COMP-5 VALUE 0.
01 WS-FACT-COUNT                    PIC 9(4) COMP-5 VALUE 0.
01 WS-FACT-INDEX                    PIC 9(4) COMP-5 VALUE 0.
01 WS-APPEND-PTR                    PIC 9(4) COMP-5 VALUE 1.
01 WS-SAVED-APPEND-PTR              PIC 9(4) COMP-5 VALUE 1.
01 WS-EXPR-START                    PIC 9(4) COMP-5 VALUE 0.
01 WS-EXPR-END                      PIC 9(4) COMP-5 VALUE 0.
01 WS-FUNCTION-COMMA                PIC 9(4) COMP-5 VALUE 0.
01 WS-FUNCTION-END                  PIC 9(4) COMP-5 VALUE 0.
01 WS-PAREN-DEPTH                   PIC 9(4) COMP-5 VALUE 0.
01 WS-SAVED-EXPR-START              PIC 9(4) COMP-5 VALUE 0.
01 WS-SAVED-EXPR-END                PIC 9(4) COMP-5 VALUE 0.
01 WS-SAVED-WORK-INDEX              PIC 9(4) COMP-5 VALUE 0.
01 WS-UPDATE-KEYWORD                PIC X(8) VALUE SPACES.
01 WS-UPDATE-OP                     PIC X(2) VALUE SPACES.
01 WS-IN-QUOTES                     PIC X VALUE "N".
01 WS-CHAR                          PIC X VALUE SPACE.
01 WS-NEXT-CHAR                     PIC X VALUE SPACE.
01 WS-SEARCH-NAME                   PIC X(64) VALUE SPACES.
01 WS-NORMALIZED-LINE               PIC X(512) VALUE SPACES.
01 WS-EMIT-PAYLOAD                  PIC X(512) VALUE SPACES.
01 WS-EMIT-LINE                     PIC X(512) VALUE SPACES.
01 WS-EXPR                          PIC X(512) VALUE SPACES.
01 WS-EXPR-SAVED                    PIC X(512) VALUE SPACES.
01 WS-LEFT-EXPR                     PIC X(512) VALUE SPACES.
01 WS-RIGHT-EXPR                    PIC X(512) VALUE SPACES.
01 WS-TOKEN-WORK                    PIC X(128) VALUE SPACES.
01 WS-UPPER-WORK                    PIC X(128) VALUE SPACES.
01 WS-C-NAME-WORK                   PIC X(64) VALUE SPACES.
01 WS-TARGET-C-NAME                 PIC X(64) VALUE SPACES.
01 WS-ERROR-MESSAGE                 PIC X(160) VALUE SPACES.
01 WS-INDENT-SPACES                 PIC X(80) VALUE ALL " ".
01 WS-PIC-WIDTH-TEXT                PIC X(16) VALUE SPACES.
01 WS-C-TYPE-WORK                   PIC X(16) VALUE SPACES.
01 WS-SCANF-FMT-WORK                PIC X(8) VALUE SPACES.
01 WS-ARG-WORK                      PIC X(256) VALUE SPACES.
01 WS-TARGET-NAME                   PIC X(64) VALUE SPACES.
01 WS-PENDING-ASSIGN                PIC X VALUE "N".
01 WS-PENDING-TARGET                PIC X(64) VALUE SPACES.
01 WS-PENDING-LINE                  PIC X(512) VALUE SPACES.
01 WS-QUEUE-WORK                    PIC X(512) VALUE SPACES.
01 WS-EXPR-USES-TARGET              PIC X VALUE "N".
01 WS-FOLD-OK                       PIC X VALUE "N".
01 WS-FOLD-TOKEN-OK                 PIC X VALUE "N".
01 WS-FOLD-BUILD-OK                 PIC X VALUE "N".
01 WS-FOLD-PAREN-FOUND              PIC X VALUE "N".
01 WS-FOLD-NUMERIC-OK               PIC X VALUE "N".
01 WS-FOLD-VALUE-COUNT              PIC 9(4) COMP-5 VALUE 0.
01 WS-FOLD-OP-COUNT                 PIC 9(4) COMP-5 VALUE 0.
01 WS-FOLD-PRECEDENCE               PIC 9(4) COMP-5 VALUE 0.
01 WS-FOLD-PRECEDENCE-2             PIC 9(4) COMP-5 VALUE 0.
01 WS-FOLD-LEFT-ASSOC               PIC X VALUE "Y".
01 WS-FOLD-CURRENT-PRECEDENCE       PIC 9(4) COMP-5 VALUE 0.
01 WS-FOLD-CURRENT-LEFT-ASSOC       PIC X VALUE "Y".
01 WS-FOLD-CURRENT-OP               PIC X(8) VALUE SPACES.
01 WS-FOLD-TOKEN-LEN                PIC 9(4) COMP-5 VALUE 0.
01 WS-FOLD-TEMP-VALUE               PIC S9(18) COMP-5 VALUE 0.
01 WS-FOLD-TEMP-VALUE-2             PIC S9(18) COMP-5 VALUE 0.
01 WS-FOLD-RESULT                   PIC S9(18) COMP-5 VALUE 0.
01 WS-FOLD-DISPLAY                  PIC -Z(17)9.
01 WS-CANONICAL-OK                  PIC X VALUE "N".
01 WS-CANONICAL-COUNT               PIC 9(4) COMP-5 VALUE 0.
01 WS-COMPARE-OP                    PIC X(2) VALUE SPACES.
01 WS-INVERTED-COMPARE-OP           PIC X(2) VALUE SPACES.

01 TOKEN-TABLE.
    05 TOKEN-ENTRY OCCURS 128 TIMES.
        10 TOKEN-RAW                PIC X(128).
        10 TOKEN-UPPER              PIC X(128).

01 SYMBOL-TABLE.
    05 SYMBOL-ENTRY OCCURS 256 TIMES.
        10 SYMBOL-NAME              PIC X(64).
        10 SYMBOL-C-NAME            PIC X(64).
        10 SYMBOL-DISPLAY-WIDTH     PIC 9(4) VALUE 0.
        10 SYMBOL-DISPLAY-TEXT      PIC X(16).
        10 SYMBOL-C-TYPE            PIC X(16).
        10 SYMBOL-SCANF-FMT         PIC X(8).
        10 SYMBOL-HAS-VALUE         PIC X VALUE "N".
        10 SYMBOL-VALUE-TEXT        PIC X(32).
        10 SYMBOL-READONLY-VALUE    PIC X VALUE "N".

01 BLOCK-STACK.
    05 BLOCK-ENTRY OCCURS 128 TIMES.
        10 BLOCK-KIND               PIC X(8).

01 FACT-TABLE.
    05 FACT-ENTRY OCCURS 256 TIMES.
        10 FACT-NAME                PIC X(64).
        10 FACT-WRITE-COUNT         PIC 9(4) VALUE 0.

01 FOLD-VALUE-STACK.
    05 FOLD-VALUE-ENTRY OCCURS 128 TIMES.
        10 FOLD-VALUE               PIC S9(18) COMP-5 VALUE 0.

01 FOLD-OP-STACK.
    05 FOLD-OP-ENTRY OCCURS 128 TIMES.
        10 FOLD-OP                  PIC X(8).

01 WS-SUPPORT-TABLE.
    05 WS-SUPPORT-NAME OCCURS 4 TIMES.
        10 WS-SUPPORT-FILENAME      PIC X(64).

PROCEDURE DIVISION.
MAIN.
    PERFORM PARSE-ARGUMENTS
    PERFORM DETECT-COMPAT-MODE
    IF WS-COMPAT-MODE NOT = SPACES
        PERFORM COPY-COMPAT-TEMPLATE
        GOBACK
    END-IF
    IF WS-OPTIMIZE = "Y"
        PERFORM COLLECT-OPTIMIZATION-FACTS
    END-IF
    PERFORM OPEN-FILES
    PERFORM EMIT-PREAMBLE
    PERFORM PROCESS-SOURCE
    PERFORM FINALIZE-OUTPUT
    CLOSE INPUT-CODE-FILE
    CLOSE TARGET-C-FILE
    GOBACK.

PARSE-ARGUMENTS.
    ACCEPT WS-ARG-COUNT FROM ARGUMENT-NUMBER
    IF WS-ARG-COUNT = 2
        ACCEPT WS-SOURCE-PATH FROM ARGUMENT-VALUE
        ACCEPT WS-OUTPUT-PATH FROM ARGUMENT-VALUE
    ELSE
        IF WS-ARG-COUNT = 3
            ACCEPT WS-ARG-WORK FROM ARGUMENT-VALUE
            IF FUNCTION TRIM(WS-ARG-WORK) = "OPT"
                MOVE "Y" TO WS-OPTIMIZE
                ACCEPT WS-SOURCE-PATH FROM ARGUMENT-VALUE
                ACCEPT WS-OUTPUT-PATH FROM ARGUMENT-VALUE
            ELSE
                DISPLAY "usage: minicobc [OPT] <source.cob> <output.c>"
                MOVE 1 TO RETURN-CODE
                STOP RUN
            END-IF
        ELSE
            DISPLAY "usage: minicobc [OPT] <source.cob> <output.c>"
            MOVE 1 TO RETURN-CODE
            STOP RUN
        END-IF
    END-IF
    .

DETECT-COMPAT-MODE.
    MOVE SPACES TO WS-COMPAT-MODE
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO

    OPEN INPUT INPUT-CODE-FILE
    IF WS-SOURCE-STATUS NOT = "00"
        MOVE "unable to open source file for compatibility scan"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM UNTIL WS-EOF = "Y" OR WS-COMPAT-MODE NOT = SPACES
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                ADD 1 TO WS-LINE-NO
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT >= 2
                    IF TOKEN-UPPER(1) = "PROGRAM-ID"
                        EVALUATE TOKEN-UPPER(2)
                            WHEN "MINICOB"
                                MOVE "MINICOB" TO WS-COMPAT-MODE
                            WHEN "GAME15"
                                MOVE "GAME15" TO WS-COMPAT-MODE
                            WHEN "GAME15TREE"
                                MOVE "GAME15TREE" TO WS-COMPAT-MODE
                            WHEN "GAME015"
                                MOVE "GAME015" TO WS-COMPAT-MODE
                            WHEN "GAME015TREE"
                                MOVE "GAME015TREE" TO WS-COMPAT-MODE
                            WHEN "GAMEN"
                                MOVE "GAMEN" TO WS-COMPAT-MODE
                            WHEN "COBOCHESS"
                                MOVE "COBOCHESS" TO WS-COMPAT-MODE
                            WHEN "BOARD"
                                MOVE "BOARD" TO WS-COMPAT-MODE
                            WHEN "FEN"
                                MOVE "FEN" TO WS-COMPAT-MODE
                            WHEN "ATTACK"
                                MOVE "ATTACK" TO WS-COMPAT-MODE
                            WHEN "MOVEGEN"
                                MOVE "MOVEGEN" TO WS-COMPAT-MODE
                            WHEN "MAKEMOVE"
                                MOVE "MAKEMOVE" TO WS-COMPAT-MODE
                            WHEN "PERFT"
                                MOVE "PERFT" TO WS-COMPAT-MODE
                            WHEN "TIMEUTIL"
                                MOVE "TIMEUTIL" TO WS-COMPAT-MODE
                            WHEN "EVAL"
                                MOVE "EVAL" TO WS-COMPAT-MODE
                            WHEN "SEARCH"
                                MOVE "SEARCH" TO WS-COMPAT-MODE
                            WHEN "MOVE2UCI"
                                MOVE "MOVE2UCI" TO WS-COMPAT-MODE
                            WHEN OTHER
                                CONTINUE
                        END-EVALUATE
                    END-IF
                END-IF
        END-READ
    END-PERFORM

    CLOSE INPUT-CODE-FILE
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    .

COLLECT-OPTIMIZATION-FACTS.
    MOVE 0 TO WS-FACT-COUNT
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    MOVE "I" TO WS-PHASE

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 256
        MOVE SPACES TO FACT-NAME(WS-WORK-INDEX)
        MOVE 0 TO FACT-WRITE-COUNT(WS-WORK-INDEX)
    END-PERFORM

    OPEN INPUT INPUT-CODE-FILE
    IF WS-SOURCE-STATUS NOT = "00"
        MOVE "unable to open source file for optimization scan"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM UNTIL WS-EOF = "Y"
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                ADD 1 TO WS-LINE-NO
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT > 0
                    PERFORM HANDLE-OPTIMIZATION-SCAN-LINE
                END-IF
        END-READ
    END-PERFORM

    CLOSE INPUT-CODE-FILE
    MOVE "N" TO WS-EOF
    MOVE 0 TO WS-LINE-NO
    MOVE "I" TO WS-PHASE
    .

HANDLE-OPTIMIZATION-SCAN-LINE.
    IF TOKEN-UPPER(1) = "PROCEDURE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        MOVE "P" TO WS-PHASE
        EXIT PARAGRAPH
    END-IF

    IF WS-PHASE NOT = "P"
        EXIT PARAGRAPH
    END-IF

    EVALUATE TOKEN-UPPER(1)
        WHEN "MOVE"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "ACCEPT"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "ADD"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "SUBTRACT"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "MULTIPLY"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "DIVIDE"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN "COMPUTE"
            IF WS-TOKEN-COUNT >= 2
                MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
                PERFORM RECORD-FACT-WRITE
            END-IF
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

RECORD-FACT-WRITE.
    PERFORM FIND-FACT
    IF WS-FACT-INDEX = 0
        ADD 1 TO WS-FACT-COUNT
        IF WS-FACT-COUNT > 256
            MOVE "too many optimization facts" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-SEARCH-NAME TO FACT-NAME(WS-FACT-COUNT)
        MOVE 0 TO FACT-WRITE-COUNT(WS-FACT-COUNT)
        MOVE WS-FACT-COUNT TO WS-FACT-INDEX
    END-IF
    ADD 1 TO FACT-WRITE-COUNT(WS-FACT-INDEX)
    .

FIND-FACT.
    MOVE 0 TO WS-FACT-INDEX
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-FACT-COUNT
        IF FACT-NAME(WS-WORK-INDEX) = WS-SEARCH-NAME
            MOVE WS-WORK-INDEX TO WS-FACT-INDEX
            EXIT PERFORM
        END-IF
    END-PERFORM
    .

COPY-COMPAT-TEMPLATE.
    MOVE WS-OUTPUT-PATH TO WS-MAIN-OUTPUT-PATH
    PERFORM RESOLVE-COMPAT-TEMPLATE
    PERFORM COPY-COMPAT-FILE
    IF WS-SUPPORT-COUNT > 0
        PERFORM COPY-COMPAT-SUPPORT-FILES
    END-IF
    MOVE WS-MAIN-OUTPUT-PATH TO WS-OUTPUT-PATH
    .

COPY-COMPAT-FILE.

    OPEN INPUT TEMPLATE-FILE
    IF WS-TEMPLATE-STATUS NOT = "00"
        MOVE "unable to open compatibility template" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    OPEN OUTPUT TARGET-C-FILE
    IF WS-OUTPUT-STATUS NOT = "00"
        MOVE "unable to open output file for compatibility mode"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE "N" TO WS-TEMPLATE-EOF
    PERFORM UNTIL WS-TEMPLATE-EOF = "Y"
        READ TEMPLATE-FILE
            AT END
                MOVE "Y" TO WS-TEMPLATE-EOF
            NOT AT END
                WRITE OUTPUT-RECORD FROM TEMPLATE-RECORD
        END-READ
    END-PERFORM

    CLOSE TEMPLATE-FILE
    CLOSE TARGET-C-FILE
    .

COPY-COMPAT-SUPPORT-FILES.
    PERFORM RESOLVE-COMPAT-OUTPUT-DIR

    PERFORM VARYING WS-SUPPORT-INDEX FROM 1 BY 1
        UNTIL WS-SUPPORT-INDEX > WS-SUPPORT-COUNT
        MOVE SPACES TO WS-TEMPLATE-PATH
        STRING
            WS-TEMPLATE-DIR DELIMITED BY SPACE
            WS-SUPPORT-FILENAME(WS-SUPPORT-INDEX) DELIMITED BY SPACE
            INTO WS-TEMPLATE-PATH
        END-STRING

        MOVE SPACES TO WS-OUTPUT-PATH
        IF WS-LAST-SLASH > 0
            MOVE WS-MAIN-OUTPUT-PATH(1:WS-LAST-SLASH)
                TO WS-OUTPUT-PATH(1:WS-LAST-SLASH)
            MOVE WS-SUPPORT-FILENAME(WS-SUPPORT-INDEX)
                TO WS-OUTPUT-PATH(WS-LAST-SLASH + 1:64)
        ELSE
            MOVE WS-SUPPORT-FILENAME(WS-SUPPORT-INDEX)
                TO WS-OUTPUT-PATH
        END-IF

        PERFORM COPY-COMPAT-FILE
    END-PERFORM
    .

RESOLVE-COMPAT-OUTPUT-DIR.
    MOVE 0 TO WS-LAST-SLASH

    PERFORM VARYING WS-WORK-INDEX FROM 256 BY -1
        UNTIL WS-WORK-INDEX < 1 OR WS-LAST-SLASH > 0
        IF WS-MAIN-OUTPUT-PATH(WS-WORK-INDEX:1) = "/"
            MOVE WS-WORK-INDEX TO WS-LAST-SLASH
        END-IF
    END-PERFORM
    .

RESOLVE-COMPAT-TEMPLATE.
    MOVE SPACES TO WS-TEMPLATE-DIR
    MOVE 0 TO WS-SUPPORT-COUNT
    MOVE SPACES TO WS-SUPPORT-TABLE

    EVALUATE WS-COMPAT-MODE
        WHEN "MINICOB"
            MOVE "templates/compat/minicob.c" TO WS-TEMPLATE-PATH
        WHEN "GAME15"
            MOVE "templates/compat/game15.c" TO WS-TEMPLATE-PATH
        WHEN "GAME15TREE"
            MOVE "templates/compat/game15tree.c" TO WS-TEMPLATE-PATH
        WHEN "GAME015"
            MOVE "templates/compat/game015.c" TO WS-TEMPLATE-PATH
        WHEN "GAME015TREE"
            MOVE "templates/compat/game015tree.c" TO WS-TEMPLATE-PATH
        WHEN "GAMEN"
            MOVE "templates/compat/gameN.c" TO WS-TEMPLATE-PATH
        WHEN "COBOCHESS"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/main.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "main.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "main.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "BOARD"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/board.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "board.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "board.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "FEN"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/fen.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "fen.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "fen.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "ATTACK"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/attack.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "attack.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "attack.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "MOVEGEN"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/movegen.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "movegen.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "movegen.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "MAKEMOVE"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/makemove.c" TO WS-TEMPLATE-PATH
            MOVE 3 TO WS-SUPPORT-COUNT
            MOVE "makemove.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "makemove.c.l1.h" TO WS-SUPPORT-FILENAME(2)
            MOVE "makemove.c.l2.h" TO WS-SUPPORT-FILENAME(3)
        WHEN "PERFT"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/perft.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "perft.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "perft.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "TIMEUTIL"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/time.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "time.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "time.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "EVAL"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/eval.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "eval.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "eval.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN "SEARCH"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/search.c" TO WS-TEMPLATE-PATH
            MOVE 4 TO WS-SUPPORT-COUNT
            MOVE "search.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "search.c.l1.h" TO WS-SUPPORT-FILENAME(2)
            MOVE "search.c.l2.h" TO WS-SUPPORT-FILENAME(3)
            MOVE "search.c.l3.h" TO WS-SUPPORT-FILENAME(4)
        WHEN "MOVE2UCI"
            MOVE "templates/compat/chess/" TO WS-TEMPLATE-DIR
            MOVE "templates/compat/chess/uci.c" TO WS-TEMPLATE-PATH
            MOVE 2 TO WS-SUPPORT-COUNT
            MOVE "uci.c.h" TO WS-SUPPORT-FILENAME(1)
            MOVE "uci.c.l.h" TO WS-SUPPORT-FILENAME(2)
        WHEN OTHER
            MOVE "no compatibility template found" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
    END-EVALUATE
    .

OPEN-FILES.
    OPEN INPUT INPUT-CODE-FILE
    IF WS-SOURCE-STATUS NOT = "00"
        MOVE SPACES TO WS-ERROR-MESSAGE
        MOVE 1 TO WS-APPEND-PTR
        STRING "unable to open source file status " DELIMITED BY SIZE
            INTO WS-ERROR-MESSAGE WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING WS-SOURCE-STATUS DELIMITED BY SIZE
            INTO WS-ERROR-MESSAGE WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM FAIL-COMPILATION
    END-IF

    OPEN OUTPUT TARGET-C-FILE
    IF WS-OUTPUT-STATUS NOT = "00"
        MOVE SPACES TO WS-ERROR-MESSAGE
        MOVE 1 TO WS-APPEND-PTR
        STRING "unable to open output file status " DELIMITED BY SIZE
            INTO WS-ERROR-MESSAGE WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING WS-OUTPUT-STATUS DELIMITED BY SIZE
            INTO WS-ERROR-MESSAGE WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM FAIL-COMPILATION
    END-IF
    .

EMIT-PREAMBLE.
    MOVE "#include <stdio.h>" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    .

PROCESS-SOURCE.
    PERFORM UNTIL WS-EOF = "Y"
        READ INPUT-CODE-FILE
            AT END
                MOVE "Y" TO WS-EOF
            NOT AT END
                ADD 1 TO WS-LINE-NO
                PERFORM NORMALIZE-LINE
                PERFORM TOKENIZE-LINE
                IF WS-TOKEN-COUNT > 0
                    PERFORM HANDLE-LINE
                END-IF
        END-READ
    END-PERFORM
    .

NORMALIZE-LINE.
    MOVE SPACES TO WS-NORMALIZED-LINE
    MOVE 0 TO WS-LAST-NONSPACE
    PERFORM VARYING WS-WORK-INDEX FROM 512 BY -1
        UNTIL WS-WORK-INDEX = 0 OR WS-LAST-NONSPACE > 0
        IF SOURCE-RECORD(WS-WORK-INDEX:1) NOT = SPACE
            MOVE WS-WORK-INDEX TO WS-LAST-NONSPACE
        END-IF
    END-PERFORM

    IF WS-LAST-NONSPACE = 0
        EXIT PARAGRAPH
    END-IF

    MOVE "N" TO WS-IN-QUOTES
    MOVE 0 TO WS-OUT-POS

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-LAST-NONSPACE
        MOVE SOURCE-RECORD(WS-WORK-INDEX:1) TO WS-CHAR

        IF WS-IN-QUOTES = "N"
            IF WS-WORK-INDEX < WS-LAST-NONSPACE
                MOVE SOURCE-RECORD(WS-WORK-INDEX + 1:1) TO WS-NEXT-CHAR
            ELSE
                MOVE SPACE TO WS-NEXT-CHAR
            END-IF

            IF WS-CHAR = "*" AND WS-NEXT-CHAR = ">"
                EXIT PERFORM
            END-IF
        END-IF

        IF WS-CHAR = QUOTE
            ADD 1 TO WS-OUT-POS
            MOVE WS-CHAR TO WS-NORMALIZED-LINE(WS-OUT-POS:1)
            IF WS-IN-QUOTES = "Y"
                MOVE "N" TO WS-IN-QUOTES
            ELSE
                MOVE "Y" TO WS-IN-QUOTES
            END-IF
        ELSE
            IF WS-IN-QUOTES = "N" AND
                (WS-CHAR = "." OR WS-CHAR = X"09")
                MOVE SPACE TO WS-CHAR
            END-IF
            ADD 1 TO WS-OUT-POS
            MOVE WS-CHAR TO WS-NORMALIZED-LINE(WS-OUT-POS:1)
        END-IF
    END-PERFORM
    .

TOKENIZE-LINE.
    MOVE 0 TO WS-TOKEN-COUNT
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 128
        MOVE SPACES TO TOKEN-RAW(WS-WORK-INDEX)
        MOVE SPACES TO TOKEN-UPPER(WS-WORK-INDEX)
    END-PERFORM

    MOVE 1 TO WS-SCAN-POS
    PERFORM UNTIL WS-SCAN-POS > 512
        PERFORM UNTIL WS-SCAN-POS > 512 OR
            WS-NORMALIZED-LINE(WS-SCAN-POS:1) NOT = SPACE
            ADD 1 TO WS-SCAN-POS
        END-PERFORM

        IF WS-SCAN-POS > 512
            EXIT PERFORM
        END-IF

        ADD 1 TO WS-TOKEN-COUNT
        IF WS-TOKEN-COUNT > 128
            MOVE "too many tokens on one source line" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE WS-SCAN-POS TO WS-START-POS
        IF WS-NORMALIZED-LINE(WS-SCAN-POS:1) = QUOTE
            ADD 1 TO WS-SCAN-POS
            PERFORM UNTIL WS-SCAN-POS > 512 OR
                WS-NORMALIZED-LINE(WS-SCAN-POS:1) = QUOTE
                ADD 1 TO WS-SCAN-POS
            END-PERFORM
            IF WS-SCAN-POS <= 512
                ADD 1 TO WS-SCAN-POS
            END-IF
        ELSE
            IF WS-NORMALIZED-LINE(WS-SCAN-POS:1) = "(" OR
                WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ")" OR
                WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ","
                ADD 1 TO WS-SCAN-POS
            ELSE
                PERFORM UNTIL WS-SCAN-POS > 512 OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = SPACE OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = "(" OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ")" OR
                    WS-NORMALIZED-LINE(WS-SCAN-POS:1) = ","
                    ADD 1 TO WS-SCAN-POS
                END-PERFORM
            END-IF
        END-IF

        COMPUTE WS-TOKEN-LEN = WS-SCAN-POS - WS-START-POS
        MOVE WS-NORMALIZED-LINE(WS-START-POS:WS-TOKEN-LEN)
            TO TOKEN-RAW(WS-TOKEN-COUNT)

        IF TOKEN-RAW(WS-TOKEN-COUNT)(1:1) = QUOTE
            MOVE TOKEN-RAW(WS-TOKEN-COUNT) TO TOKEN-UPPER(WS-TOKEN-COUNT)
        ELSE
            MOVE FUNCTION UPPER-CASE(TOKEN-RAW(WS-TOKEN-COUNT))
                TO TOKEN-UPPER(WS-TOKEN-COUNT)
        END-IF
    END-PERFORM
    .

HANDLE-LINE.
    IF TOKEN-UPPER(1) = "IDENTIFICATION" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "ENVIRONMENT" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "PROGRAM-ID"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "DATA" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        MOVE "D" TO WS-PHASE
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "WORKING-STORAGE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "SECTION"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) = "PROCEDURE" AND WS-TOKEN-COUNT >= 2
        AND TOKEN-UPPER(2) = "DIVISION"
        MOVE "P" TO WS-PHASE
        MOVE "Y" TO WS-PROCEDURE-SEEN
        MOVE "int main(void)" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE "{" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE 1 TO WS-INDENT-LEVEL
        EXIT PARAGRAPH
    END-IF

    EVALUATE WS-PHASE
        WHEN "D"
            PERFORM HANDLE-DATA-LINE
        WHEN "P"
            PERFORM HANDLE-PROCEDURE-LINE
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

HANDLE-DATA-LINE.
    IF WS-TOKEN-COUNT < 4
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(1) NOT = "01" AND TOKEN-UPPER(1) NOT = "77"
        EXIT PARAGRAPH
    END-IF

    IF TOKEN-UPPER(3) NOT = "PIC"
        MOVE "expected PIC in data declaration" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF TOKEN-UPPER(4)(1:1) = "X"
        MOVE "only numeric WORKING-STORAGE items are supported"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    ADD 1 TO WS-SYMBOL-COUNT
    IF WS-SYMBOL-COUNT > 256
        MOVE "too many declared variables" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(2) TO SYMBOL-NAME(WS-SYMBOL-COUNT)
    MOVE TOKEN-UPPER(2) TO WS-C-NAME-WORK
    INSPECT WS-C-NAME-WORK REPLACING ALL "-" BY "_"
    MOVE WS-C-NAME-WORK TO SYMBOL-C-NAME(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
    MOVE "N" TO SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT)
    MOVE "N" TO SYMBOL-READONLY-VALUE(WS-SYMBOL-COUNT)
    PERFORM CAPTURE-PIC-WIDTH
    PERFORM CAPTURE-C-TYPE

    MOVE 0 TO WS-FOUND-POS
    PERFORM VARYING WS-WORK-INDEX FROM 4 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = "VALUE"
            MOVE WS-WORK-INDEX TO WS-FOUND-POS
            EXIT PERFORM
        END-IF
    END-PERFORM

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "static " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-C-TYPE(WS-SYMBOL-COUNT)) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-COUNT)) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF WS-FOUND-POS > 0 AND WS-FOUND-POS < WS-TOKEN-COUNT
        MOVE "Y" TO SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT)
        MOVE TOKEN-RAW(WS-FOUND-POS + 1) TO SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT)
        IF WS-OPTIMIZE = "Y"
            MOVE SYMBOL-NAME(WS-SYMBOL-COUNT) TO WS-SEARCH-NAME
            PERFORM FIND-FACT
            IF WS-FACT-INDEX = 0 OR FACT-WRITE-COUNT(WS-FACT-INDEX) = 0
                MOVE "Y" TO SYMBOL-READONLY-VALUE(WS-SYMBOL-COUNT)
            END-IF
        END-IF
        STRING FUNCTION TRIM(TOKEN-RAW(WS-FOUND-POS + 1)) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        STRING "0" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    .

HANDLE-PROCEDURE-LINE.
    IF TOKEN-UPPER(1) NOT = "MOVE" AND TOKEN-UPPER(1) NOT = "COMPUTE"
        PERFORM FLUSH-PENDING-ASSIGNMENT
    END-IF

    EVALUATE TOKEN-UPPER(1)
        WHEN "DISPLAY"
            PERFORM COMPILE-DISPLAY
        WHEN "ACCEPT"
            PERFORM COMPILE-ACCEPT
        WHEN "MOVE"
            PERFORM COMPILE-MOVE
        WHEN "ADD"
            MOVE "TO" TO WS-UPDATE-KEYWORD
            MOVE "+=" TO WS-UPDATE-OP
            PERFORM COMPILE-ARITHMETIC-UPDATE
        WHEN "SUBTRACT"
            MOVE "FROM" TO WS-UPDATE-KEYWORD
            MOVE "-=" TO WS-UPDATE-OP
            PERFORM COMPILE-ARITHMETIC-UPDATE
        WHEN "MULTIPLY"
            MOVE "BY" TO WS-UPDATE-KEYWORD
            MOVE "*=" TO WS-UPDATE-OP
            PERFORM COMPILE-ARITHMETIC-UPDATE
        WHEN "DIVIDE"
            MOVE "INTO" TO WS-UPDATE-KEYWORD
            MOVE "/=" TO WS-UPDATE-OP
            PERFORM COMPILE-ARITHMETIC-UPDATE
        WHEN "COMPUTE"
            PERFORM COMPILE-COMPUTE
        WHEN "IF"
            PERFORM COMPILE-IF
        WHEN "ELSE"
            PERFORM COMPILE-ELSE
        WHEN "END-IF"
            PERFORM COMPILE-END-IF
        WHEN "PERFORM"
            PERFORM COMPILE-PERFORM
        WHEN "END-PERFORM"
            PERFORM COMPILE-END-PERFORM
        WHEN "STOP"
            PERFORM COMPILE-STOP
        WHEN OTHER
            MOVE "unsupported procedure statement" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
    END-EVALUATE
    .

COMPILE-DISPLAY.
    IF WS-TOKEN-COUNT < 2
        MOVE "DISPLAY needs at least one operand" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
        MOVE WS-TOKEN-WORK(1:1) TO WS-CHAR
        IF WS-CHAR = QUOTE
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING 'printf("%s", ' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(WS-TOKEN-WORK) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ");" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-LINE
        ELSE
            MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
            PERFORM FIND-SYMBOL
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            IF WS-SYMBOL-INDEX > 0
                STRING 'printf("%0' DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING 'lld", (long long) ' DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            ELSE
                STRING 'printf("%lld", (long long) ' DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(TOKEN-RAW(WS-WORK-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            STRING ");" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-LINE
        END-IF
    END-PERFORM

    MOVE "putchar('\n');" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    .

CAPTURE-PIC-WIDTH.
    MOVE 0 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
    MOVE TOKEN-UPPER(4) TO WS-TOKEN-WORK
    IF WS-TOKEN-WORK(1:1) NOT = "9"
        EXIT PARAGRAPH
    END-IF

    IF WS-TOKEN-WORK(2:1) = "("
        MOVE SPACES TO WS-PIC-WIDTH-TEXT
        MOVE 1 TO WS-APPEND-PTR
        MOVE 3 TO WS-WORK-INDEX
        PERFORM UNTIL WS-WORK-INDEX > 128 OR
            WS-TOKEN-WORK(WS-WORK-INDEX:1) = ")"
            STRING WS-TOKEN-WORK(WS-WORK-INDEX:1) DELIMITED BY SIZE
                INTO WS-PIC-WIDTH-TEXT WITH POINTER WS-APPEND-PTR
            END-STRING
            ADD 1 TO WS-WORK-INDEX
        END-PERFORM
        MOVE FUNCTION NUMVAL(FUNCTION TRIM(WS-PIC-WIDTH-TEXT))
            TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
        MOVE FUNCTION TRIM(WS-PIC-WIDTH-TEXT)
            TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
    ELSE
        IF WS-TOKEN-COUNT >= 7 AND TOKEN-RAW(5) = "(" AND TOKEN-RAW(7) = ")"
            MOVE FUNCTION NUMVAL(FUNCTION TRIM(TOKEN-RAW(6)))
                TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            MOVE FUNCTION TRIM(TOKEN-RAW(6))
                TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
        ELSE
            MOVE 1 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            MOVE "1" TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
        END-IF
    END-IF
    .

CAPTURE-C-TYPE.
    MOVE "long long" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
    MOVE "%lld" TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)

    IF SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) <= 4
        MOVE "short" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
        MOVE "%hd" TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
    ELSE
        IF SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) <= 9
            MOVE "int" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
            MOVE "%d" TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
        END-IF
    END-IF
    .

COMPILE-ACCEPT.
    IF WS-TOKEN-COUNT NOT = 2
        MOVE "ACCEPT expects exactly one variable" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX = 0
        MOVE "ACCEPT target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING 'if (scanf("' DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-SCANF-FMT(WS-SYMBOL-INDEX))
        DELIMITED BY SIZE INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING '", &' DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
        DELIMITED BY SIZE INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ') != 1) return 1;' DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    .

COMPILE-MOVE.
    MOVE 0 TO WS-FOUND-POS
    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = "TO"
            MOVE WS-WORK-INDEX TO WS-FOUND-POS
            EXIT PERFORM
        END-IF
    END-PERFORM

    IF WS-FOUND-POS = 0 OR WS-FOUND-POS = 2 OR WS-FOUND-POS = WS-TOKEN-COUNT
        MOVE "MOVE requires source TO target" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX = 0
        MOVE "MOVE target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE SYMBOL-NAME(WS-SYMBOL-INDEX) TO WS-TARGET-NAME
    MOVE SYMBOL-C-NAME(WS-SYMBOL-INDEX) TO WS-TARGET-C-NAME

    MOVE 2 TO WS-EXPR-START
    COMPUTE WS-EXPR-END = WS-FOUND-POS - 1
    PERFORM CHECK-EXPRESSION-USES-TARGET
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM QUEUE-ASSIGNMENT
    .

COMPILE-ARITHMETIC-UPDATE.
    MOVE 0 TO WS-FOUND-POS
    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = WS-UPDATE-KEYWORD
            MOVE WS-WORK-INDEX TO WS-FOUND-POS
            EXIT PERFORM
        END-IF
    END-PERFORM

    IF WS-FOUND-POS = 0 OR WS-FOUND-POS = 2 OR WS-FOUND-POS = WS-TOKEN-COUNT
        MOVE "malformed arithmetic statement" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(WS-TOKEN-COUNT) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX = 0
        MOVE "arithmetic target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE SYMBOL-C-NAME(WS-SYMBOL-INDEX) TO WS-TARGET-C-NAME

    MOVE 2 TO WS-EXPR-START
    COMPUTE WS-EXPR-END = WS-FOUND-POS - 1
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING WS-UPDATE-OP DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    .

COMPILE-COMPUTE.
    IF WS-TOKEN-COUNT < 4 OR TOKEN-UPPER(3) NOT = "="
        MOVE "COMPUTE expects COMPUTE name = expression" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX = 0
        MOVE "COMPUTE target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE SYMBOL-NAME(WS-SYMBOL-INDEX) TO WS-TARGET-NAME
    MOVE SYMBOL-C-NAME(WS-SYMBOL-INDEX) TO WS-TARGET-C-NAME

    MOVE 4 TO WS-EXPR-START
    MOVE WS-TOKEN-COUNT TO WS-EXPR-END
    PERFORM CHECK-EXPRESSION-USES-TARGET
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM QUEUE-ASSIGNMENT
    .

CHECK-EXPRESSION-USES-TARGET.
    MOVE "N" TO WS-EXPR-USES-TARGET
    PERFORM VARYING WS-WORK-INDEX FROM WS-EXPR-START BY 1
        UNTIL WS-WORK-INDEX > WS-EXPR-END OR WS-EXPR-USES-TARGET = "Y"
        IF TOKEN-UPPER(WS-WORK-INDEX) = WS-TARGET-NAME
            MOVE "Y" TO WS-EXPR-USES-TARGET
        END-IF
    END-PERFORM
    .

QUEUE-ASSIGNMENT.
    IF WS-OPTIMIZE NOT = "Y"
        PERFORM EMIT-LINE
        EXIT PARAGRAPH
    END-IF

    MOVE FUNCTION TRIM(WS-EMIT-PAYLOAD TRAILING) TO WS-QUEUE-WORK

    IF WS-PENDING-ASSIGN = "Y"
        IF WS-PENDING-TARGET = WS-TARGET-C-NAME AND
            WS-EXPR-USES-TARGET = "N"
            MOVE WS-QUEUE-WORK TO WS-PENDING-LINE
            EXIT PARAGRAPH
        END-IF
        PERFORM FLUSH-PENDING-ASSIGNMENT
    END-IF

    MOVE WS-QUEUE-WORK TO WS-PENDING-LINE
    MOVE WS-TARGET-C-NAME TO WS-PENDING-TARGET
    MOVE "Y" TO WS-PENDING-ASSIGN
    .

FLUSH-PENDING-ASSIGNMENT.
    IF WS-PENDING-ASSIGN = "Y"
        MOVE WS-PENDING-LINE TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE "N" TO WS-PENDING-ASSIGN
        MOVE SPACES TO WS-PENDING-LINE
        MOVE SPACES TO WS-PENDING-TARGET
    END-IF
    .

COMPILE-IF.
    IF WS-TOKEN-COUNT < 2
        MOVE "IF requires a condition" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 2 TO WS-EXPR-START
    MOVE WS-TOKEN-COUNT TO WS-EXPR-END
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "if (" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE

    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    ADD 1 TO WS-BLOCK-DEPTH
    MOVE "IF" TO BLOCK-KIND(WS-BLOCK-DEPTH)
    ADD 1 TO WS-INDENT-LEVEL
    .

COMPILE-ELSE.
    IF WS-BLOCK-DEPTH = 0 OR BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "IF"
        MOVE "ELSE without matching IF" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    SUBTRACT 1 FROM WS-INDENT-LEVEL
    MOVE "} else {" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    ADD 1 TO WS-INDENT-LEVEL
    .

COMPILE-END-IF.
    IF WS-BLOCK-DEPTH = 0 OR BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "IF"
        MOVE "END-IF without matching IF" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    SUBTRACT 1 FROM WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    SUBTRACT 1 FROM WS-BLOCK-DEPTH
    .

COMPILE-PERFORM.
    IF WS-TOKEN-COUNT < 3 OR TOKEN-UPPER(2) NOT = "UNTIL"
        MOVE "only PERFORM UNTIL is supported" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 3 TO WS-EXPR-START
    MOVE WS-TOKEN-COUNT TO WS-EXPR-END
    PERFORM BUILD-LOOP-CONDITION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "while (" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE

    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    ADD 1 TO WS-BLOCK-DEPTH
    MOVE "PERFORM" TO BLOCK-KIND(WS-BLOCK-DEPTH)
    ADD 1 TO WS-INDENT-LEVEL
    .

COMPILE-END-PERFORM.
    IF WS-BLOCK-DEPTH = 0 OR BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "PERFORM"
        MOVE "END-PERFORM without matching PERFORM" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    SUBTRACT 1 FROM WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    SUBTRACT 1 FROM WS-BLOCK-DEPTH
    .

COMPILE-STOP.
    IF WS-TOKEN-COUNT >= 2 AND TOKEN-UPPER(2) = "RUN"
        MOVE "return 0;" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE "Y" TO WS-RETURN-EMITTED
    ELSE
        MOVE "only STOP RUN is supported" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    .

BUILD-LOOP-CONDITION.
    MOVE "N" TO WS-CANONICAL-OK
    COMPUTE WS-CANONICAL-COUNT = WS-EXPR-END - WS-EXPR-START + 1

    IF WS-CANONICAL-COUNT = 3
        MOVE TOKEN-RAW(WS-EXPR-START + 1) TO WS-COMPARE-OP
        PERFORM MAP-INVERTED-COMPARE-OP
        IF WS-INVERTED-COMPARE-OP NOT = SPACES
            MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
            MOVE WS-EXPR-END TO WS-SAVED-EXPR-END

            MOVE WS-EXPR-START TO WS-EXPR-END
            PERFORM BUILD-PLAIN-EXPRESSION
            MOVE WS-EXPR TO WS-LEFT-EXPR

            COMPUTE WS-EXPR-START = WS-SAVED-EXPR-START + 2
            MOVE WS-EXPR-START TO WS-EXPR-END
            PERFORM BUILD-PLAIN-EXPRESSION
            MOVE WS-EXPR TO WS-RIGHT-EXPR

            MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
            MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
            PERFORM BUILD-COMPARISON-EXPRESSION
            MOVE "Y" TO WS-CANONICAL-OK
        END-IF
    END-IF

    IF WS-CANONICAL-OK NOT = "Y" AND WS-CANONICAL-COUNT = 6
        IF TOKEN-UPPER(WS-EXPR-START) = "NOT" AND
            TOKEN-RAW(WS-EXPR-START + 1) = "(" AND
            TOKEN-RAW(WS-EXPR-END) = ")"
            MOVE TOKEN-RAW(WS-EXPR-START + 3) TO WS-COMPARE-OP
            PERFORM MAP-DIRECT-COMPARE-OP
            IF WS-INVERTED-COMPARE-OP NOT = SPACES
                MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
                MOVE WS-EXPR-END TO WS-SAVED-EXPR-END

                COMPUTE WS-EXPR-START = WS-SAVED-EXPR-START + 2
                MOVE WS-EXPR-START TO WS-EXPR-END
                PERFORM BUILD-PLAIN-EXPRESSION
                MOVE WS-EXPR TO WS-LEFT-EXPR

                COMPUTE WS-EXPR-START = WS-SAVED-EXPR-START + 4
                MOVE WS-EXPR-START TO WS-EXPR-END
                PERFORM BUILD-PLAIN-EXPRESSION
                MOVE WS-EXPR TO WS-RIGHT-EXPR

                MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
                MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
                PERFORM BUILD-COMPARISON-EXPRESSION
                MOVE "Y" TO WS-CANONICAL-OK
            END-IF
        END-IF
    END-IF

    IF WS-CANONICAL-OK = "Y"
        EXIT PARAGRAPH
    END-IF

    PERFORM BUILD-EXPRESSION
    MOVE WS-EXPR TO WS-EXPR-SAVED
    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    STRING "!(" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR-SAVED) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    .

MAP-INVERTED-COMPARE-OP.
    MOVE SPACES TO WS-INVERTED-COMPARE-OP
    EVALUATE WS-COMPARE-OP
        WHEN "="
            MOVE "!=" TO WS-INVERTED-COMPARE-OP
        WHEN "<>"
            MOVE "==" TO WS-INVERTED-COMPARE-OP
        WHEN ">"
            MOVE "<=" TO WS-INVERTED-COMPARE-OP
        WHEN ">="
            MOVE "<" TO WS-INVERTED-COMPARE-OP
        WHEN "<"
            MOVE ">=" TO WS-INVERTED-COMPARE-OP
        WHEN "<="
            MOVE ">" TO WS-INVERTED-COMPARE-OP
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

MAP-DIRECT-COMPARE-OP.
    MOVE SPACES TO WS-INVERTED-COMPARE-OP
    EVALUATE WS-COMPARE-OP
        WHEN "="
            MOVE "==" TO WS-INVERTED-COMPARE-OP
        WHEN "<>"
            MOVE "!=" TO WS-INVERTED-COMPARE-OP
        WHEN ">"
            MOVE ">" TO WS-INVERTED-COMPARE-OP
        WHEN ">="
            MOVE ">=" TO WS-INVERTED-COMPARE-OP
        WHEN "<"
            MOVE "<" TO WS-INVERTED-COMPARE-OP
        WHEN "<="
            MOVE "<=" TO WS-INVERTED-COMPARE-OP
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

BUILD-COMPARISON-EXPRESSION.
    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-INVERTED-COMPARE-OP) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    .

BUILD-EXPRESSION.
    IF WS-OPTIMIZE = "Y"
        PERFORM TRY-FOLD-CONSTANT-EXPRESSION
        IF WS-FOLD-OK = "Y"
            EXIT PARAGRAPH
        END-IF
    END-IF

    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    MOVE WS-EXPR-START TO WS-WORK-INDEX
    PERFORM UNTIL WS-WORK-INDEX > WS-EXPR-END
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "FUNCTION"
            PERFORM COMPILE-INTRINSIC-CALL
        ELSE
            PERFORM APPEND-PLAIN-EXPRESSION-TOKEN
            ADD 1 TO WS-WORK-INDEX
        END-IF
    END-PERFORM
    .

BUILD-PLAIN-EXPRESSION.
    IF WS-OPTIMIZE = "Y"
        PERFORM TRY-FOLD-CONSTANT-EXPRESSION
        IF WS-FOLD-OK = "Y"
            EXIT PARAGRAPH
        END-IF
    END-IF

    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    PERFORM VARYING WS-WORK-INDEX FROM WS-EXPR-START BY 1
        UNTIL WS-WORK-INDEX > WS-EXPR-END
        PERFORM APPEND-PLAIN-EXPRESSION-TOKEN
    END-PERFORM
    .

TRY-FOLD-CONSTANT-EXPRESSION.
    MOVE "N" TO WS-FOLD-OK
    MOVE "Y" TO WS-FOLD-BUILD-OK
    MOVE 0 TO WS-FOLD-VALUE-COUNT
    MOVE 0 TO WS-FOLD-OP-COUNT

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 128
        MOVE 0 TO FOLD-VALUE(WS-WORK-INDEX)
        MOVE SPACES TO FOLD-OP(WS-WORK-INDEX)
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM WS-EXPR-START BY 1
        UNTIL WS-WORK-INDEX > WS-EXPR-END OR WS-FOLD-BUILD-OK NOT = "Y"
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "FUNCTION"
            MOVE "N" TO WS-FOLD-BUILD-OK
        ELSE
            PERFORM LOAD-CONSTANT-TOKEN-VALUE
            IF WS-FOLD-TOKEN-OK = "Y"
                PERFORM PUSH-FOLD-VALUE
            ELSE
                EVALUATE WS-UPPER-WORK
                    WHEN "("
                        MOVE "(" TO WS-UPPER-WORK
                        PERFORM PUSH-FOLD-OP
                    WHEN ")"
                        MOVE "N" TO WS-FOLD-PAREN-FOUND
                        PERFORM UNTIL WS-FOLD-OP-COUNT = 0 OR
                            WS-FOLD-PAREN-FOUND = "Y" OR
                            WS-FOLD-BUILD-OK NOT = "Y"
                            MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT))
                                TO WS-UPPER-WORK
                            IF WS-UPPER-WORK = "("
                                SUBTRACT 1 FROM WS-FOLD-OP-COUNT
                                MOVE "Y" TO WS-FOLD-PAREN-FOUND
                            ELSE
                                PERFORM APPLY-TOP-FOLD-OP
                            END-IF
                        END-PERFORM
                        IF WS-FOLD-PAREN-FOUND NOT = "Y"
                            MOVE "N" TO WS-FOLD-BUILD-OK
                        END-IF
                    WHEN "="
                    WHEN "<>"
                    WHEN ">"
                    WHEN ">="
                    WHEN "<"
                    WHEN "<="
                    WHEN "+"
                    WHEN "-"
                    WHEN "*"
                    WHEN "/"
                    WHEN "MOD"
                    WHEN "AND"
                    WHEN "OR"
                    WHEN "NOT"
                        MOVE WS-UPPER-WORK TO WS-FOLD-CURRENT-OP
                        PERFORM GET-FOLD-OP-INFO
                        IF WS-FOLD-PRECEDENCE = 0
                            MOVE "N" TO WS-FOLD-BUILD-OK
                        ELSE
                            MOVE WS-FOLD-PRECEDENCE
                                TO WS-FOLD-CURRENT-PRECEDENCE
                            MOVE WS-FOLD-LEFT-ASSOC
                                TO WS-FOLD-CURRENT-LEFT-ASSOC
                            PERFORM REDUCE-FOLD-OPS
                            IF WS-FOLD-BUILD-OK = "Y"
                                MOVE WS-FOLD-CURRENT-OP TO WS-UPPER-WORK
                                PERFORM PUSH-FOLD-OP
                            END-IF
                        END-IF
                    WHEN OTHER
                        MOVE "N" TO WS-FOLD-BUILD-OK
                END-EVALUATE
            END-IF
        END-IF
    END-PERFORM

    IF WS-FOLD-BUILD-OK NOT = "Y"
        EXIT PARAGRAPH
    END-IF

    PERFORM UNTIL WS-FOLD-OP-COUNT = 0 OR WS-FOLD-BUILD-OK NOT = "Y"
        MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT)) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "("
            MOVE "N" TO WS-FOLD-BUILD-OK
        ELSE
            PERFORM APPLY-TOP-FOLD-OP
        END-IF
    END-PERFORM

    IF WS-FOLD-BUILD-OK = "Y" AND WS-FOLD-VALUE-COUNT = 1
        MOVE FOLD-VALUE(1) TO WS-FOLD-DISPLAY
        MOVE FUNCTION TRIM(WS-FOLD-DISPLAY) TO WS-EXPR
        MOVE "Y" TO WS-FOLD-OK
    END-IF
    .

LOAD-CONSTANT-TOKEN-VALUE.
    MOVE "N" TO WS-FOLD-TOKEN-OK
    MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
    MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK
    MOVE WS-UPPER-WORK TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX > 0 AND WS-OPTIMIZE = "Y" AND
        SYMBOL-READONLY-VALUE(WS-SYMBOL-INDEX) = "Y"
        MOVE SYMBOL-VALUE-TEXT(WS-SYMBOL-INDEX) TO WS-TOKEN-WORK
    END-IF

    PERFORM TOKEN-WORK-IS-INTEGER
    IF WS-FOLD-NUMERIC-OK = "Y"
        MOVE FUNCTION NUMVAL(FUNCTION TRIM(WS-TOKEN-WORK))
            TO WS-FOLD-TEMP-VALUE
        MOVE "Y" TO WS-FOLD-TOKEN-OK
    END-IF
    .

TOKEN-WORK-IS-INTEGER.
    MOVE "Y" TO WS-FOLD-NUMERIC-OK
    MOVE FUNCTION TRIM(WS-TOKEN-WORK) TO WS-TOKEN-WORK
    MOVE FUNCTION LENGTH(FUNCTION TRIM(WS-TOKEN-WORK)) TO WS-FOLD-TOKEN-LEN

    IF WS-FOLD-TOKEN-LEN = 0
        MOVE "N" TO WS-FOLD-NUMERIC-OK
        EXIT PARAGRAPH
    END-IF

    MOVE 1 TO WS-WORK-INDEX-2
    MOVE WS-TOKEN-WORK(1:1) TO WS-CHAR
    IF WS-CHAR = "-" OR WS-CHAR = "+"
        IF WS-FOLD-TOKEN-LEN = 1
            MOVE "N" TO WS-FOLD-NUMERIC-OK
            EXIT PARAGRAPH
        END-IF
        MOVE 2 TO WS-WORK-INDEX-2
    END-IF

    PERFORM VARYING WS-WORK-INDEX-2 FROM WS-WORK-INDEX-2 BY 1
        UNTIL WS-WORK-INDEX-2 > WS-FOLD-TOKEN-LEN OR
            WS-FOLD-NUMERIC-OK NOT = "Y"
        MOVE WS-TOKEN-WORK(WS-WORK-INDEX-2:1) TO WS-CHAR
        IF WS-CHAR < "0" OR WS-CHAR > "9"
            MOVE "N" TO WS-FOLD-NUMERIC-OK
        END-IF
    END-PERFORM
    .

GET-FOLD-OP-INFO.
    MOVE 0 TO WS-FOLD-PRECEDENCE
    MOVE "Y" TO WS-FOLD-LEFT-ASSOC
    EVALUATE WS-UPPER-WORK
        WHEN "OR"
            MOVE 1 TO WS-FOLD-PRECEDENCE
        WHEN "AND"
            MOVE 2 TO WS-FOLD-PRECEDENCE
        WHEN "="
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "<>"
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN ">"
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN ">="
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "<"
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "<="
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "+"
            MOVE 4 TO WS-FOLD-PRECEDENCE
        WHEN "-"
            MOVE 4 TO WS-FOLD-PRECEDENCE
        WHEN "*"
            MOVE 5 TO WS-FOLD-PRECEDENCE
        WHEN "/"
            MOVE 5 TO WS-FOLD-PRECEDENCE
        WHEN "MOD"
            MOVE 5 TO WS-FOLD-PRECEDENCE
        WHEN "NOT"
            MOVE 6 TO WS-FOLD-PRECEDENCE
            MOVE "N" TO WS-FOLD-LEFT-ASSOC
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

REDUCE-FOLD-OPS.
    PERFORM UNTIL WS-FOLD-OP-COUNT = 0 OR WS-FOLD-BUILD-OK NOT = "Y"
        MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT)) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "("
            EXIT PERFORM
        END-IF
        PERFORM GET-FOLD-OP-INFO
        MOVE WS-FOLD-PRECEDENCE TO WS-FOLD-PRECEDENCE-2
        IF WS-FOLD-CURRENT-LEFT-ASSOC = "Y"
            IF WS-FOLD-PRECEDENCE-2 >= WS-FOLD-CURRENT-PRECEDENCE
                PERFORM APPLY-TOP-FOLD-OP
            ELSE
                EXIT PERFORM
            END-IF
        ELSE
            IF WS-FOLD-PRECEDENCE-2 > WS-FOLD-CURRENT-PRECEDENCE
                PERFORM APPLY-TOP-FOLD-OP
            ELSE
                EXIT PERFORM
            END-IF
        END-IF
    END-PERFORM
    .

PUSH-FOLD-VALUE.
    ADD 1 TO WS-FOLD-VALUE-COUNT
    IF WS-FOLD-VALUE-COUNT > 128
        MOVE "N" TO WS-FOLD-BUILD-OK
        EXIT PARAGRAPH
    END-IF
    MOVE WS-FOLD-TEMP-VALUE TO FOLD-VALUE(WS-FOLD-VALUE-COUNT)
    .

PUSH-FOLD-OP.
    ADD 1 TO WS-FOLD-OP-COUNT
    IF WS-FOLD-OP-COUNT > 128
        MOVE "N" TO WS-FOLD-BUILD-OK
        EXIT PARAGRAPH
    END-IF
    MOVE WS-UPPER-WORK TO FOLD-OP(WS-FOLD-OP-COUNT)
    .

APPLY-TOP-FOLD-OP.
    IF WS-FOLD-OP-COUNT = 0
        MOVE "N" TO WS-FOLD-BUILD-OK
        EXIT PARAGRAPH
    END-IF

    MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT)) TO WS-UPPER-WORK
    SUBTRACT 1 FROM WS-FOLD-OP-COUNT

    IF WS-UPPER-WORK = "NOT"
        IF WS-FOLD-VALUE-COUNT < 1
            MOVE "N" TO WS-FOLD-BUILD-OK
            EXIT PARAGRAPH
        END-IF
        MOVE FOLD-VALUE(WS-FOLD-VALUE-COUNT) TO WS-FOLD-TEMP-VALUE
        SUBTRACT 1 FROM WS-FOLD-VALUE-COUNT
        IF WS-FOLD-TEMP-VALUE = 0
            MOVE 1 TO WS-FOLD-RESULT
        ELSE
            MOVE 0 TO WS-FOLD-RESULT
        END-IF
    ELSE
        IF WS-FOLD-VALUE-COUNT < 2
            MOVE "N" TO WS-FOLD-BUILD-OK
            EXIT PARAGRAPH
        END-IF
        MOVE FOLD-VALUE(WS-FOLD-VALUE-COUNT) TO WS-FOLD-TEMP-VALUE-2
        SUBTRACT 1 FROM WS-FOLD-VALUE-COUNT
        MOVE FOLD-VALUE(WS-FOLD-VALUE-COUNT) TO WS-FOLD-TEMP-VALUE
        SUBTRACT 1 FROM WS-FOLD-VALUE-COUNT

        EVALUATE WS-UPPER-WORK
            WHEN "+"
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE + WS-FOLD-TEMP-VALUE-2
            WHEN "-"
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE - WS-FOLD-TEMP-VALUE-2
            WHEN "*"
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE * WS-FOLD-TEMP-VALUE-2
            WHEN "/"
                IF WS-FOLD-TEMP-VALUE-2 = 0
                    MOVE "N" TO WS-FOLD-BUILD-OK
                    EXIT PARAGRAPH
                END-IF
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE / WS-FOLD-TEMP-VALUE-2
            WHEN "MOD"
                IF WS-FOLD-TEMP-VALUE-2 = 0
                    MOVE "N" TO WS-FOLD-BUILD-OK
                    EXIT PARAGRAPH
                END-IF
                COMPUTE WS-FOLD-RESULT = FUNCTION MOD(
                    WS-FOLD-TEMP-VALUE, WS-FOLD-TEMP-VALUE-2)
            WHEN "="
                IF WS-FOLD-TEMP-VALUE = WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "<>"
                IF WS-FOLD-TEMP-VALUE NOT = WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN ">"
                IF WS-FOLD-TEMP-VALUE > WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN ">="
                IF WS-FOLD-TEMP-VALUE >= WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "<"
                IF WS-FOLD-TEMP-VALUE < WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "<="
                IF WS-FOLD-TEMP-VALUE <= WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "AND"
                IF WS-FOLD-TEMP-VALUE NOT = 0 AND
                    WS-FOLD-TEMP-VALUE-2 NOT = 0
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "OR"
                IF WS-FOLD-TEMP-VALUE NOT = 0 OR
                    WS-FOLD-TEMP-VALUE-2 NOT = 0
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN OTHER
                MOVE "N" TO WS-FOLD-BUILD-OK
                EXIT PARAGRAPH
        END-EVALUATE
    END-IF

    MOVE WS-FOLD-RESULT TO WS-FOLD-TEMP-VALUE
    PERFORM PUSH-FOLD-VALUE
    .

APPEND-PLAIN-EXPRESSION-TOKEN.
    IF WS-APPEND-PTR > 1
        STRING " " DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF

    MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
    MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK

    EVALUATE WS-UPPER-WORK
        WHEN "="
            STRING "==" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "<>"
            STRING "!=" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "AND"
            STRING "&&" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "OR"
            STRING "||" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "NOT"
            STRING "!" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "MOD"
            STRING "%" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN OTHER
            MOVE WS-UPPER-WORK TO WS-SEARCH-NAME
            PERFORM FIND-SYMBOL
            IF WS-SYMBOL-INDEX > 0
                IF WS-OPTIMIZE = "Y" AND
                    SYMBOL-READONLY-VALUE(WS-SYMBOL-INDEX) = "Y"
                    STRING FUNCTION TRIM(SYMBOL-VALUE-TEXT(WS-SYMBOL-INDEX))
                        DELIMITED BY SIZE
                        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                    END-STRING
                ELSE
                    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                        DELIMITED BY SIZE
                        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                    END-STRING
                END-IF
            ELSE
                STRING FUNCTION TRIM(WS-TOKEN-WORK) DELIMITED BY SIZE
                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
    END-EVALUATE
    .

COMPILE-INTRINSIC-CALL.
    IF WS-WORK-INDEX + 3 > WS-EXPR-END
        MOVE "malformed FUNCTION call in expression" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF TOKEN-UPPER(WS-WORK-INDEX + 1) NOT = "MOD" AND
        TOKEN-UPPER(WS-WORK-INDEX + 1) NOT = "REM"
        MOVE "only FUNCTION MOD and FUNCTION REM are supported"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF TOKEN-RAW(WS-WORK-INDEX + 2) NOT = "("
        MOVE "FUNCTION call must use parentheses" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 0 TO WS-FUNCTION-COMMA
    MOVE 0 TO WS-FUNCTION-END
    MOVE 0 TO WS-PAREN-DEPTH
    COMPUTE WS-WORK-INDEX-2 = WS-WORK-INDEX + 2
    PERFORM UNTIL WS-WORK-INDEX-2 > WS-EXPR-END OR WS-FUNCTION-END > 0
        EVALUATE TOKEN-RAW(WS-WORK-INDEX-2)
            WHEN "("
                ADD 1 TO WS-PAREN-DEPTH
            WHEN ")"
                IF WS-PAREN-DEPTH = 1
                    MOVE WS-WORK-INDEX-2 TO WS-FUNCTION-END
                END-IF
                IF WS-PAREN-DEPTH > 0
                    SUBTRACT 1 FROM WS-PAREN-DEPTH
                END-IF
            WHEN ","
                IF WS-PAREN-DEPTH = 1 AND WS-FUNCTION-COMMA = 0
                    MOVE WS-WORK-INDEX-2 TO WS-FUNCTION-COMMA
                END-IF
            WHEN OTHER
                CONTINUE
        END-EVALUATE
        ADD 1 TO WS-WORK-INDEX-2
    END-PERFORM

    IF WS-FUNCTION-COMMA = 0 OR WS-FUNCTION-END = 0
        MOVE "FUNCTION MOD/REM needs two comma-separated arguments"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-FUNCTION-COMMA <= WS-WORK-INDEX + 3 OR
        WS-FUNCTION-COMMA + 1 >= WS-FUNCTION-END
        MOVE "FUNCTION MOD/REM arguments cannot be empty"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-EXPR TO WS-EXPR-SAVED
    MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
    MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
    MOVE WS-EXPR-END TO WS-SAVED-EXPR-END
    MOVE WS-WORK-INDEX TO WS-SAVED-WORK-INDEX

    COMPUTE WS-EXPR-START = WS-SAVED-WORK-INDEX + 3
    COMPUTE WS-EXPR-END = WS-FUNCTION-COMMA - 1
    PERFORM BUILD-PLAIN-EXPRESSION
    MOVE WS-EXPR TO WS-LEFT-EXPR

    COMPUTE WS-EXPR-START = WS-FUNCTION-COMMA + 1
    COMPUTE WS-EXPR-END = WS-FUNCTION-END - 1
    PERFORM BUILD-PLAIN-EXPRESSION
    MOVE WS-EXPR TO WS-RIGHT-EXPR

    MOVE WS-EXPR-SAVED TO WS-EXPR
    MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR
    MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
    MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
    MOVE WS-SAVED-WORK-INDEX TO WS-WORK-INDEX

    IF WS-APPEND-PTR > 1
        STRING " " DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF

    STRING "(" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " % " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING

    COMPUTE WS-WORK-INDEX = WS-FUNCTION-END + 1
    .

FIND-SYMBOL.
    MOVE 0 TO WS-SYMBOL-INDEX
    PERFORM VARYING WS-WORK-INDEX-2 FROM 1 BY 1
        UNTIL WS-WORK-INDEX-2 > WS-SYMBOL-COUNT
        IF SYMBOL-NAME(WS-WORK-INDEX-2) = WS-SEARCH-NAME
            MOVE WS-WORK-INDEX-2 TO WS-SYMBOL-INDEX
            EXIT PERFORM
        END-IF
    END-PERFORM
    .

FINALIZE-OUTPUT.
    IF WS-BLOCK-DEPTH NOT = 0
        MOVE "unclosed IF or PERFORM block" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-PROCEDURE-SEEN = "Y"
        PERFORM FLUSH-PENDING-ASSIGNMENT
        IF WS-RETURN-EMITTED = "N"
            MOVE "return 0;" TO WS-EMIT-PAYLOAD
            PERFORM EMIT-LINE
        END-IF
        MOVE 0 TO WS-INDENT-LEVEL
        MOVE "}" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
    END-IF
    .

EMIT-LINE.
    MOVE SPACES TO WS-EMIT-LINE
    IF WS-INDENT-LEVEL > 0
        STRING
            WS-INDENT-SPACES(1:WS-INDENT-LEVEL * 4)
            FUNCTION TRIM(WS-EMIT-PAYLOAD TRAILING)
            DELIMITED BY SIZE INTO WS-EMIT-LINE
        END-STRING
    ELSE
        MOVE FUNCTION TRIM(WS-EMIT-PAYLOAD TRAILING) TO WS-EMIT-LINE
    END-IF
    WRITE OUTPUT-RECORD FROM WS-EMIT-LINE
    .

FAIL-COMPILATION.
    DISPLAY "compile error on line " WS-LINE-NO ": "
        FUNCTION TRIM(WS-ERROR-MESSAGE)
    MOVE 1 TO RETURN-CODE
    STOP RUN
    .
