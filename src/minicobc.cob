                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING " = (" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(SYMBOL-C-TYPE(WS-WORK-INDEX-2))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ") strtoll(minicobc_group_field, NULL, 10);" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            PERFORM EMIT-LINE

            ADD SYMBOL-DISPLAY-WIDTH(WS-WORK-INDEX-2) TO WS-GROUP-TARGET-WIDTH
        END-IF
    END-PERFORM
    .

CAPTURE-PIC-WIDTH.
    MOVE 0 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
    MOVE SPACES TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
    MOVE "Y" TO SYMBOL-ZERO-FILL(WS-SYMBOL-COUNT)
    MOVE TOKEN-UPPER(WS-PIC-POS + 1) TO WS-TOKEN-WORK
    IF WS-TOKEN-WORK(1:1) = "X"
        MOVE "A" TO SYMBOL-KIND(WS-SYMBOL-COUNT)
    ELSE
        IF WS-TOKEN-WORK(1:1) = "9" OR
            FUNCTION TRIM(WS-TOKEN-WORK) = "S9" OR
            WS-TOKEN-WORK(1:1) = "Z"
            MOVE "N" TO SYMBOL-KIND(WS-SYMBOL-COUNT)
            IF WS-TOKEN-WORK(1:1) = "Z"
                MOVE "N" TO SYMBOL-ZERO-FILL(WS-SYMBOL-COUNT)
            END-IF
        ELSE
            MOVE "unsupported PIC clause" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
    END-IF

    IF WS-TOKEN-WORK(1:1) = "Z"
        IF WS-TOKEN-WORK(2:1) = "("
            MOVE SPACES TO WS-PIC-WIDTH-TEXT
            MOVE 1 TO WS-APPEND-PTR
            MOVE 3 TO WS-WORK-INDEX
            PERFORM UNTIL WS-WORK-INDEX > 128 OR
                WS-TOKEN-WORK(WS-WORK-INDEX:1) = ")"
                STRING WS-TOKEN-WORK(WS-WORK-INDEX:1) DELIMITED BY SIZE
                    INTO WS-PIC-WIDTH-TEXT WITH POINTER WS-APPEND-PTR
                END-STRING
                ADD 1 TO WS-WORK-INDEX
            END-PERFORM
            MOVE FUNCTION NUMVAL(FUNCTION TRIM(WS-PIC-WIDTH-TEXT))
                TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            ADD 1 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            MOVE SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            MOVE FUNCTION TRIM(WS-PLAIN-TEXT)
                TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
            EXIT PARAGRAPH
        END-IF

        IF WS-PIC-POS + 5 <= WS-TOKEN-COUNT AND
            TOKEN-RAW(WS-PIC-POS + 2) = "(" AND
            TOKEN-RAW(WS-PIC-POS + 4) = ")" AND
            TOKEN-UPPER(WS-PIC-POS + 5) = "9"
            MOVE FUNCTION NUMVAL(FUNCTION TRIM(TOKEN-RAW(WS-PIC-POS + 3)))
                TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            ADD 1 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            MOVE SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            MOVE FUNCTION TRIM(WS-PLAIN-TEXT)
                TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
            EXIT PARAGRAPH
        END-IF

        MOVE 2 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
        MOVE "2" TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
        EXIT PARAGRAPH
    END-IF

    IF WS-TOKEN-WORK(2:1) = "("
        MOVE SPACES TO WS-PIC-WIDTH-TEXT
        MOVE 1 TO WS-APPEND-PTR
        MOVE 3 TO WS-WORK-INDEX
        PERFORM UNTIL WS-WORK-INDEX > 128 OR
            WS-TOKEN-WORK(WS-WORK-INDEX:1) = ")"
            STRING WS-TOKEN-WORK(WS-WORK-INDEX:1) DELIMITED BY SIZE
                INTO WS-PIC-WIDTH-TEXT WITH POINTER WS-APPEND-PTR
            END-STRING
            ADD 1 TO WS-WORK-INDEX
        END-PERFORM
        MOVE FUNCTION NUMVAL(FUNCTION TRIM(WS-PIC-WIDTH-TEXT))
            TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
        MOVE FUNCTION TRIM(WS-PIC-WIDTH-TEXT)
            TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
    ELSE
        IF WS-PIC-POS + 4 <= WS-TOKEN-COUNT AND
            TOKEN-RAW(WS-PIC-POS + 2) = "(" AND
            TOKEN-RAW(WS-PIC-POS + 4) = ")"
            MOVE FUNCTION NUMVAL(FUNCTION TRIM(TOKEN-RAW(WS-PIC-POS + 3)))
                TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            MOVE FUNCTION TRIM(TOKEN-RAW(WS-PIC-POS + 3))
                TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
        ELSE
            MOVE 1 TO SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT)
            MOVE "1" TO SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT)
        END-IF
    END-IF
    .

CAPTURE-C-TYPE.
    IF SYMBOL-KIND(WS-SYMBOL-COUNT) = "A"
        MOVE "char" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
        MOVE SPACES TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
        MOVE 1 TO WS-APPEND-PTR
        STRING "%" DELIMITED BY SIZE
            INTO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT) WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(SYMBOL-DISPLAY-TEXT(WS-SYMBOL-COUNT))
            DELIMITED BY SIZE
            INTO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT) WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "s" DELIMITED BY SIZE
            INTO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT) WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        MOVE "long long" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
        MOVE "%lld" TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)

        IF SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) <= 4
            MOVE "short" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
            MOVE "%hd" TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
        ELSE
            IF SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) <= 9
                MOVE "int" TO SYMBOL-C-TYPE(WS-SYMBOL-COUNT)
                MOVE "%d" TO SYMBOL-SCANF-FMT(WS-SYMBOL-COUNT)
            END-IF
        END-IF
    END-IF
    .

EMIT-NUMERIC-DECL.
    MOVE WS-SYMBOL-COUNT TO WS-SYMBOL-INDEX
    PERFORM LOAD-EFFECTIVE-OCCURS

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "static " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-C-TYPE(WS-SYMBOL-COUNT)) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-COUNT)) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF WS-EFFECTIVE-OCCURS > 1
        STRING "[" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        MOVE WS-EFFECTIVE-OCCURS TO WS-PLAIN-NUMERIC
        PERFORM LOAD-PLAIN-INTEGER-TEXT
        STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "] = {0};" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        IF SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT) = "Y"
            MOVE "Y" TO WS-HAS-DATA-INIT
        END-IF
    ELSE
        STRING " = " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        IF SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT) = "Y"
            STRING FUNCTION TRIM(SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        ELSE
            STRING "0" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        END-IF
        STRING ";" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    PERFORM EMIT-LINE
    .

EMIT-ALPHA-DECL.
    MOVE WS-SYMBOL-COUNT TO WS-SYMBOL-INDEX
    PERFORM LOAD-EFFECTIVE-OCCURS
    IF WS-EFFECTIVE-OCCURS > 1 AND SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT) = "Y"
        MOVE "VALUE on OCCURS PIC X items is not supported yet"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "static char " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-COUNT)) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF WS-EFFECTIVE-OCCURS > 1
        STRING "[" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        MOVE WS-EFFECTIVE-OCCURS TO WS-PLAIN-NUMERIC
        PERFORM LOAD-PLAIN-INTEGER-TEXT
        STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "][" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        STRING "[" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    COMPUTE WS-WORK-INDEX-2 = SYMBOL-DISPLAY-WIDTH(WS-SYMBOL-COUNT) + 1
    MOVE WS-WORK-INDEX-2 TO WS-PLAIN-NUMERIC
    PERFORM LOAD-PLAIN-INTEGER-TEXT
    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF WS-EFFECTIVE-OCCURS > 1
        STRING "] = {{0}};" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        STRING "] = " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        IF SYMBOL-HAS-VALUE(WS-SYMBOL-COUNT) = "Y"
            STRING FUNCTION TRIM(SYMBOL-VALUE-TEXT(WS-SYMBOL-COUNT))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        ELSE
            STRING '""' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        END-IF
        STRING ";" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    PERFORM EMIT-LINE
    .

COMPILE-ACCEPT.
    IF WS-TOKEN-COUNT < 2
        MOVE "ACCEPT expects a target variable" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 2 TO WS-REF-START
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y"
        MOVE "ACCEPT target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-REF-NEXT-POS = 3 AND WS-TOKEN-COUNT = 4 AND
        TOKEN-UPPER(3) = "FROM" AND TOKEN-UPPER(4) = "COMMAND-LINE"
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "A"
            MOVE "ACCEPT FROM COMMAND-LINE currently requires PIC X target"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING "minicobc_join_command_line(" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-REF-C-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ", " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ");" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
        IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
            PERFORM EMIT-OVERLAY-SYNC-CALL
        END-IF
        EXIT PARAGRAPH
    END-IF

    IF WS-REF-NEXT-POS NOT = WS-TOKEN-COUNT + 1
        IF WS-REF-HAS-INDEX = "Y" AND
            WS-REF-NEXT-POS = WS-TOKEN-COUNT AND
            TOKEN-RAW(WS-TOKEN-COUNT) = ")"
            CONTINUE
        ELSE
            MOVE "ACCEPT target syntax is not supported yet"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
    END-IF

    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
        PERFORM FLUSH-PENDING-ASSIGNMENT
        PERFORM SAVE-GROUP-REF-AS-TARGET
        PERFORM SET-CURRENT-GROUP-INDEX-FROM-TARGET
        PERFORM MEASURE-GROUP-PACKED-WIDTH
        IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
            MOVE "memset(minicobc_group_buffer, 0, sizeof(minicobc_group_buffer));"
                TO WS-EMIT-PAYLOAD
            PERFORM EMIT-LINE
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING 'if (scanf("%' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            MOVE WS-GROUP-PACKED-WIDTH TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING 's", minicobc_group_buffer) != 1) ' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            IF WS-HAS-PARAGRAPHS = "Y"
                STRING 'exit(1);' DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            ELSE
                STRING 'return 1;' DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            PERFORM EMIT-LINE
            PERFORM EMIT-STORE-GROUP-BUFFER-INTO-OVERLAY
        ELSE
            MOVE "memset(minicobc_group_buffer, 0, sizeof(minicobc_group_buffer));"
                TO WS-EMIT-PAYLOAD
            PERFORM EMIT-LINE
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING 'if (scanf("%' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            MOVE WS-GROUP-PACKED-WIDTH TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING 's", minicobc_group_buffer) != 1) ' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            IF WS-HAS-PARAGRAPHS = "Y"
                STRING 'exit(1);' DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            ELSE
                STRING 'return 1;' DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            PERFORM EMIT-LINE
            PERFORM EMIT-GROUP-UNPACK
        END-IF
        EXIT PARAGRAPH
    END-IF

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING 'if (scanf("' DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(SYMBOL-SCANF-FMT(WS-SYMBOL-INDEX))
        DELIMITED BY SIZE INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING '", ' DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
        STRING FUNCTION TRIM(WS-REF-C-EXPR)
            DELIMITED BY SIZE INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        STRING '&' DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-REF-C-EXPR)
            DELIMITED BY SIZE INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    IF WS-HAS-PARAGRAPHS = "Y"
        STRING ') != 1) exit(1);' DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    ELSE
        STRING ') != 1) return 1;' DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    PERFORM EMIT-LINE
    IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
        PERFORM EMIT-OVERLAY-SYNC-CALL
    END-IF
    .

COMPILE-UNSTRING.
    IF WS-TOKEN-COUNT < 8
        MOVE "UNSTRING statement is incomplete" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 2 TO WS-REF-START
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y" OR SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "A"
        MOVE "UNSTRING source must be a PIC X item" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-REF-C-EXPR TO WS-SOURCE-C-EXPR
    IF WS-REF-HAS-SLICE = "Y"
        MOVE WS-REF-LENGTH-TOKEN TO WS-SOURCE-LENGTH-EXPR
    ELSE
        MOVE SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX) TO WS-SOURCE-LENGTH-EXPR
    END-IF

    MOVE 0 TO WS-WORK-INDEX
    IF WS-REF-NEXT-POS + 3 > WS-TOKEN-COUNT OR
        TOKEN-UPPER(WS-REF-NEXT-POS) NOT = "DELIMITED" OR
        TOKEN-UPPER(WS-REF-NEXT-POS + 1) NOT = "BY"
        MOVE "UNSTRING currently supports only DELIMITED BY SPACE/SPACES INTO"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF TOKEN-UPPER(WS-REF-NEXT-POS + 2) = "ALL"
        IF WS-REF-NEXT-POS + 4 > WS-TOKEN-COUNT OR
            TOKEN-UPPER(WS-REF-NEXT-POS + 3) NOT = "SPACES" OR
            TOKEN-UPPER(WS-REF-NEXT-POS + 4) NOT = "INTO"
            MOVE
                "UNSTRING currently supports only DELIMITED BY SPACE/SPACES INTO"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        COMPUTE WS-WORK-INDEX = WS-REF-NEXT-POS + 5
    ELSE
        IF (TOKEN-UPPER(WS-REF-NEXT-POS + 2) = "SPACE" OR
            TOKEN-UPPER(WS-REF-NEXT-POS + 2) = "SPACES") AND
            TOKEN-UPPER(WS-REF-NEXT-POS + 3) = "INTO"
            COMPUTE WS-WORK-INDEX = WS-REF-NEXT-POS + 4
        ELSE
            MOVE
                "UNSTRING currently supports only DELIMITED BY SPACE/SPACES INTO"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
    END-IF

    MOVE "minicobc_unstring_pos = 0;" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE

    PERFORM UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = "END-UNSTRING"
            EXIT PERFORM
        END-IF

        MOVE WS-WORK-INDEX TO WS-REF-START
        PERFORM RESOLVE-REFERENCE
        IF WS-REF-OK NOT = "Y" OR SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "A"
            MOVE "UNSTRING targets must be PIC X items" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME
        IF WS-REF-HAS-SLICE = "Y"
            MOVE "UNSTRING targets cannot use reference modification yet"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX) TO WS-TARGET-LENGTH-EXPR

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING "minicobc_next_word(" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-SOURCE-C-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ", " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-SOURCE-LENGTH-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ", &minicobc_unstring_pos, " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ", " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-TARGET-LENGTH-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ");" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE

        IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
            PERFORM EMIT-OVERLAY-SYNC-CALL
        END-IF
        COMPUTE WS-WORK-INDEX = WS-REF-NEXT-POS
    END-PERFORM
    .

COMPILE-ADD.
    MOVE 0 TO WS-FOUND-POS
    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = "GIVING"
            MOVE WS-WORK-INDEX TO WS-FOUND-POS
            EXIT PERFORM
        END-IF
    END-PERFORM

    IF WS-FOUND-POS = 0
        MOVE "TO" TO WS-UPDATE-KEYWORD
        MOVE "+=" TO WS-UPDATE-OP
        PERFORM COMPILE-ARITHMETIC-UPDATE
        EXIT PARAGRAPH
    END-IF

    IF WS-FOUND-POS = 2 OR WS-FOUND-POS = WS-TOKEN-COUNT
        MOVE "ADD ... GIVING requires sources and a target"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-FOUND-POS TO WS-REF-START
    ADD 1 TO WS-REF-START
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-TOKEN-COUNT + 1
        MOVE "ADD GIVING target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "N"
        MOVE "ADD GIVING target must be numeric" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
    MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME

    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    MOVE 2 TO WS-WORK-INDEX
    PERFORM UNTIL WS-WORK-INDEX >= WS-FOUND-POS
        IF WS-APPEND-PTR > 1
            STRING " + " DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        END-IF

        MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
        MOVE WS-WORK-INDEX TO WS-REF-START
        PERFORM RESOLVE-REFERENCE
        MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR

        IF WS-REF-OK = "Y"
            IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G" OR
                SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                MOVE "ADD GIVING sources must be numeric"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
            STRING FUNCTION TRIM(WS-REF-C-EXPR) DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            MOVE WS-REF-NEXT-POS TO WS-WORK-INDEX
        ELSE
            STRING FUNCTION TRIM(TOKEN-RAW(WS-WORK-INDEX)) DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            ADD 1 TO WS-WORK-INDEX
        END-IF
    END-PERFORM

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
        PERFORM FLUSH-PENDING-ASSIGNMENT
        PERFORM EMIT-LINE
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM EMIT-OVERLAY-SYNC-CALL
    ELSE
        PERFORM QUEUE-ASSIGNMENT
    END-IF
    .

COMPILE-INITIALIZE.
    IF WS-TOKEN-COUNT <> 2
        MOVE "INITIALIZE currently expects one target"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    PERFORM FLUSH-PENDING-ASSIGNMENT
    MOVE 2 TO WS-REF-START
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = 3
        MOVE "INITIALIZE target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
        MOVE SYMBOL-FIRST-CHILD(WS-SYMBOL-INDEX) TO WS-WORK-INDEX
        PERFORM UNTIL WS-WORK-INDEX = 0 OR
            WS-WORK-INDEX > SYMBOL-LAST-CHILD(WS-SYMBOL-INDEX)
            IF SYMBOL-KIND(WS-WORK-INDEX) NOT = "G"
                IF SYMBOL-KIND(WS-WORK-INDEX) = "A"
                    MOVE "INITIALIZE on groups with PIC X fields is not supported yet"
                        TO WS-ERROR-MESSAGE
                    PERFORM FAIL-COMPILATION
                END-IF
                MOVE SPACES TO WS-EMIT-PAYLOAD
                MOVE 1 TO WS-APPEND-PTR
                STRING "memset(" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-WORK-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ", 0, sizeof(" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-WORK-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING "));" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                PERFORM EMIT-LINE
            END-IF
            ADD 1 TO WS-WORK-INDEX
        END-PERFORM
        EXIT PARAGRAPH
    END-IF

    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
        MOVE "INITIALIZE on PIC X targets is not supported yet"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-REF-C-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = 0;" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
        PERFORM EMIT-OVERLAY-SYNC-CALL
    END-IF
    .

COMPILE-MOVE.
    MOVE 0 TO WS-FOUND-POS
    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = "TO"
            MOVE WS-WORK-INDEX TO WS-FOUND-POS
            EXIT PERFORM
        END-IF
    END-PERFORM

    IF WS-FOUND-POS = 0 OR WS-FOUND-POS = 2 OR WS-FOUND-POS = WS-TOKEN-COUNT
        MOVE "MOVE requires source TO target" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-FOUND-POS = 3 AND WS-TOKEN-COUNT > 4 AND
        (TOKEN-UPPER(2) = "SPACE" OR TOKEN-UPPER(2) = "SPACES")
        PERFORM FLUSH-PENDING-ASSIGNMENT
        PERFORM VARYING WS-WORK-INDEX FROM 4 BY 1
            UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
            MOVE WS-WORK-INDEX TO WS-REF-START
            PERFORM RESOLVE-REFERENCE
            IF WS-REF-OK NOT = "Y" OR
                WS-REF-NEXT-POS NOT = WS-WORK-INDEX + 1
                MOVE "MOVE SPACES multi-target syntax is not supported yet"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
            IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "A"
                MOVE "MOVE SPACES currently requires PIC X targets"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF

            MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
            MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME
            MOVE WS-REF-HAS-SLICE TO WS-TARGET-HAS-SLICE
            IF WS-TARGET-HAS-SLICE = "Y"
                MOVE WS-REF-LENGTH-TOKEN TO WS-TARGET-LENGTH-EXPR
            ELSE
                MOVE SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX)
                    TO WS-TARGET-LENGTH-EXPR
            END-IF
            MOVE '""' TO WS-SOURCE-C-EXPR
            MOVE "0" TO WS-SOURCE-LENGTH-EXPR
            PERFORM EMIT-ALNUM-COPY-CALL
            IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
                MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
                PERFORM EMIT-OVERLAY-SYNC-CALL
            END-IF
        END-PERFORM
        EXIT PARAGRAPH
    END-IF

    MOVE WS-FOUND-POS TO WS-REF-START
    ADD 1 TO WS-REF-START
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y"
        MOVE "MOVE target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    IF WS-REF-NEXT-POS NOT = WS-TOKEN-COUNT + 1
        IF WS-REF-HAS-INDEX = "Y" AND
            WS-REF-NEXT-POS = WS-TOKEN-COUNT AND
            TOKEN-RAW(WS-TOKEN-COUNT) = ")"
            CONTINUE
        ELSE
            PERFORM TRY-COMPILE-MULTI-TARGET-MOVE
            IF WS-MOVE-MULTI-OK = "Y"
                EXIT PARAGRAPH
            END-IF
            MOVE "MOVE target syntax is not supported yet"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
    END-IF
    MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
    PERFORM SAVE-GROUP-REF-AS-TARGET
    MOVE SYMBOL-NAME(WS-SYMBOL-INDEX) TO WS-TARGET-NAME
    MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME
    MOVE "N" TO WS-TARGET-HAS-SLICE
    MOVE SPACES TO WS-TARGET-LENGTH-EXPR
    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
        MOVE WS-REF-HAS-SLICE TO WS-TARGET-HAS-SLICE
        IF WS-TARGET-HAS-SLICE = "Y"
            MOVE WS-REF-LENGTH-TOKEN TO WS-TARGET-LENGTH-EXPR
        ELSE
            MOVE SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX)
                TO WS-TARGET-LENGTH-EXPR
        END-IF
    END-IF

    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
        PERFORM FLUSH-PENDING-ASSIGNMENT
        MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM MEASURE-GROUP-PACKED-WIDTH
        MOVE WS-GROUP-PACKED-WIDTH TO WS-GROUP-TARGET-WIDTH
        IF WS-FOUND-POS - 2 = 1 AND TOKEN-RAW(2)(1:1) = QUOTE
            MOVE "memset(minicobc_group_buffer, 0, sizeof(minicobc_group_buffer));"
                TO WS-EMIT-PAYLOAD
            PERFORM EMIT-LINE
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING "snprintf(minicobc_group_buffer, " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            COMPUTE WS-WORK-INDEX = WS-GROUP-TARGET-WIDTH + 1
            MOVE WS-WORK-INDEX TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ', "%-*.*s", ' DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            MOVE WS-GROUP-TARGET-WIDTH TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ", " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            MOVE WS-GROUP-TARGET-WIDTH TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ", " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(TOKEN-RAW(2)) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ");" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-LINE
        ELSE
            MOVE 2 TO WS-REF-START
            PERFORM RESOLVE-REFERENCE
            IF WS-REF-OK = "Y" AND WS-REF-NEXT-POS = WS-FOUND-POS
                PERFORM SAVE-GROUP-REF-AS-SOURCE
                MOVE WS-SYMBOL-INDEX TO WS-GROUP-SOURCE-INDEX
                MOVE WS-GROUP-SOURCE-INDEX TO WS-SYMBOL-INDEX
                PERFORM MEASURE-GROUP-PACKED-WIDTH
                MOVE WS-GROUP-PACKED-WIDTH TO WS-GROUP-SOURCE-WIDTH
                IF WS-GROUP-SOURCE-WIDTH NOT = WS-GROUP-TARGET-WIDTH
                    MOVE "packed MOVE variable sources require matching widths"
                        TO WS-ERROR-MESSAGE
                    PERFORM FAIL-COMPILATION
                END-IF
                MOVE WS-GROUP-SOURCE-INDEX TO WS-SYMBOL-INDEX
                PERFORM SET-CURRENT-GROUP-INDEX-FROM-SOURCE
                IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G" AND
                    SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
                    PERFORM EMIT-LOAD-OVERLAY-GROUP-BUFFER
                ELSE
                    PERFORM EMIT-GROUP-PACK
                END-IF
            ELSE
                MOVE "packed MOVE currently requires a string literal or single variable source"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
        END-IF
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM SET-CURRENT-GROUP-INDEX-FROM-TARGET
        IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
            PERFORM EMIT-STORE-GROUP-BUFFER-INTO-OVERLAY
        ELSE
            PERFORM EMIT-GROUP-UNPACK
        END-IF
        EXIT PARAGRAPH
    END-IF

    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
        PERFORM FLUSH-PENDING-ASSIGNMENT

        MOVE "N" TO WS-SOURCE-HAS-SLICE
        MOVE SPACES TO WS-SOURCE-C-EXPR
        MOVE SPACES TO WS-SOURCE-LENGTH-EXPR
        MOVE TOKEN-RAW(2) TO WS-TOKEN-WORK
        IF TOKEN-UPPER(2) = "SPACE" OR TOKEN-UPPER(2) = "SPACES"
            MOVE '""' TO WS-SOURCE-C-EXPR
            MOVE "0" TO WS-SOURCE-LENGTH-EXPR
            PERFORM EMIT-ALNUM-COPY-CALL
            IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
                MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
                PERFORM EMIT-OVERLAY-SYNC-CALL
            END-IF
            EXIT PARAGRAPH
        END-IF
        IF WS-TOKEN-WORK(1:1) = QUOTE
            MOVE FUNCTION TRIM(WS-TOKEN-WORK) TO WS-SOURCE-C-EXPR
            MOVE 1 TO WS-APPEND-PTR
            MOVE SPACES TO WS-SOURCE-LENGTH-EXPR
            STRING "((int) strlen(" DELIMITED BY SIZE
                INTO WS-SOURCE-LENGTH-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(WS-SOURCE-C-EXPR) DELIMITED BY SIZE
                INTO WS-SOURCE-LENGTH-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING "))" DELIMITED BY SIZE
                INTO WS-SOURCE-LENGTH-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-ALNUM-COPY-CALL
            IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
                MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
                PERFORM EMIT-OVERLAY-SYNC-CALL
            END-IF
            EXIT PARAGRAPH
        END-IF

        MOVE 2 TO WS-REF-START
        PERFORM RESOLVE-REFERENCE
        IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-FOUND-POS
            MOVE "alphanumeric MOVE source must be a string literal or variable"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
            MOVE WS-SYMBOL-INDEX TO WS-GROUP-SOURCE-INDEX
            PERFORM MEASURE-GROUP-PACKED-WIDTH
            MOVE WS-GROUP-PACKED-WIDTH TO WS-GROUP-SOURCE-WIDTH
            PERFORM SAVE-GROUP-REF-AS-SOURCE
            PERFORM SET-CURRENT-GROUP-INDEX-FROM-SOURCE
            IF SYMBOL-OVERLAY-ROOT(WS-SYMBOL-INDEX) > 0
                PERFORM EMIT-LOAD-OVERLAY-GROUP-BUFFER
            ELSE
                PERFORM EMIT-GROUP-PACK
            END-IF
            MOVE "minicobc_group_buffer" TO WS-SOURCE-C-EXPR
            MOVE WS-GROUP-SOURCE-WIDTH TO WS-PLAIN-NUMERIC
            PERFORM LOAD-PLAIN-INTEGER-TEXT
            MOVE WS-PLAIN-TEXT TO WS-SOURCE-LENGTH-EXPR
            PERFORM EMIT-ALNUM-COPY-CALL
            IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
                MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
                PERFORM EMIT-OVERLAY-SYNC-CALL
            END-IF
            EXIT PARAGRAPH
        END-IF
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "N"
            MOVE SPACES TO WS-EMIT-PAYLOAD
            MOVE 1 TO WS-APPEND-PTR
            STRING "snprintf(minicobc_group_field, sizeof(minicobc_group_field), ""%"
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            IF SYMBOL-ZERO-FILL(WS-SYMBOL-INDEX) = "Y"
                STRING "0" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            STRING "*lld"", " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX))
                DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ", (long long) " DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(WS-REF-C-EXPR) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ");" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
            PERFORM EMIT-LINE
            MOVE "minicobc_group_field" TO WS-SOURCE-C-EXPR
            MOVE SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX)
                TO WS-SOURCE-LENGTH-EXPR
            PERFORM EMIT-ALNUM-COPY-CALL
            IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
                MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
                PERFORM EMIT-OVERLAY-SYNC-CALL
            END-IF
            EXIT PARAGRAPH
        END-IF
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "A"
            MOVE "alphanumeric MOVE source must be PIC X"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE WS-REF-HAS-SLICE TO WS-SOURCE-HAS-SLICE
        MOVE WS-REF-C-EXPR TO WS-SOURCE-C-EXPR
        IF WS-SOURCE-HAS-SLICE = "Y"
            MOVE WS-REF-LENGTH-TOKEN TO WS-SOURCE-LENGTH-EXPR
        ELSE
            MOVE SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX)
                TO WS-SOURCE-LENGTH-EXPR
        END-IF
        PERFORM EMIT-ALNUM-COPY-CALL
        IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
            MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
            PERFORM EMIT-OVERLAY-SYNC-CALL
        END-IF
        EXIT PARAGRAPH
    END-IF

    MOVE 2 TO WS-EXPR-START
    COMPUTE WS-EXPR-END = WS-FOUND-POS - 1
    PERFORM CHECK-EXPRESSION-USES-TARGET
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
        PERFORM FLUSH-PENDING-ASSIGNMENT
        PERFORM EMIT-LINE
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM EMIT-OVERLAY-SYNC-CALL
    ELSE
        PERFORM QUEUE-ASSIGNMENT
    END-IF
    .

TRY-COMPILE-MULTI-TARGET-MOVE.
    MOVE "N" TO WS-MOVE-MULTI-OK

    IF WS-FOUND-POS + 2 > WS-TOKEN-COUNT
        EXIT PARAGRAPH
    END-IF

    IF WS-FOUND-POS = 3
        MOVE TOKEN-RAW(2) TO WS-TOKEN-WORK
        IF WS-TOKEN-WORK(1:1) = QUOTE OR
            TOKEN-UPPER(2) = "SPACE" OR TOKEN-UPPER(2) = "SPACES"
            EXIT PARAGRAPH
        END-IF
        PERFORM NORMALIZE-SIMPLE-TOKEN
        MOVE FUNCTION TRIM(WS-TOKEN-WORK) TO WS-EXPR
    ELSE
        MOVE 2 TO WS-REF-START
        PERFORM RESOLVE-REFERENCE
        IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-FOUND-POS
            EXIT PARAGRAPH
        END-IF
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "N" OR
            WS-REF-HAS-INDEX = "Y" OR WS-REF-HAS-SLICE = "Y"
            EXIT PARAGRAPH
        END-IF
        MOVE WS-REF-C-EXPR TO WS-EXPR
    END-IF

    MOVE "Y" TO WS-MOVE-MULTI-OK
    COMPUTE WS-WORK-INDEX = WS-FOUND-POS + 1
    PERFORM UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        MOVE WS-WORK-INDEX TO WS-REF-START
        PERFORM RESOLVE-REFERENCE
        IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-WORK-INDEX + 1
            MOVE "N" TO WS-MOVE-MULTI-OK
            EXIT PERFORM
        END-IF
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "N" OR
            WS-REF-HAS-INDEX = "Y" OR WS-REF-HAS-SLICE = "Y"
            MOVE "N" TO WS-MOVE-MULTI-OK
            EXIT PERFORM
        END-IF

        MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
        MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME
        MOVE "N" TO WS-EXPR-USES-TARGET
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " = " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ";" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
            PERFORM FLUSH-PENDING-ASSIGNMENT
            PERFORM EMIT-LINE
            MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
            PERFORM EMIT-OVERLAY-SYNC-CALL
        ELSE
            PERFORM QUEUE-ASSIGNMENT
        END-IF
        MOVE WS-REF-NEXT-POS TO WS-WORK-INDEX
    END-PERFORM

    IF WS-MOVE-MULTI-OK NOT = "Y"
        PERFORM FLUSH-PENDING-ASSIGNMENT
    END-IF
    .

COMPILE-ARITHMETIC-UPDATE.
    MOVE 0 TO WS-FOUND-POS
    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = WS-UPDATE-KEYWORD
            MOVE WS-WORK-INDEX TO WS-FOUND-POS
            EXIT PERFORM
        END-IF
    END-PERFORM

    IF WS-FOUND-POS = 0 OR WS-FOUND-POS = 2 OR WS-FOUND-POS = WS-TOKEN-COUNT
        MOVE "malformed arithmetic statement" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-FOUND-POS TO WS-REF-START
    ADD 1 TO WS-REF-START
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-TOKEN-COUNT + 1
        MOVE "arithmetic target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "N"
        MOVE "arithmetic targets must be numeric" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
    MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME

    MOVE 2 TO WS-EXPR-START
    COMPUTE WS-EXPR-END = WS-FOUND-POS - 1
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING WS-UPDATE-OP DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM EMIT-OVERLAY-SYNC-CALL
    END-IF
    .

COMPILE-DIVIDE.
    MOVE 0 TO WS-VALUE-POS
    MOVE 0 TO WS-OCCURS-POS
    MOVE 0 TO WS-REDEFINES-POS
    PERFORM VARYING WS-WORK-INDEX FROM 2 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        EVALUATE TOKEN-UPPER(WS-WORK-INDEX)
            WHEN "BY"
                MOVE WS-WORK-INDEX TO WS-OCCURS-POS
            WHEN "GIVING"
                MOVE WS-WORK-INDEX TO WS-VALUE-POS
            WHEN "REMAINDER"
                MOVE WS-WORK-INDEX TO WS-REDEFINES-POS
            WHEN OTHER
                CONTINUE
        END-EVALUATE
    END-PERFORM

    IF WS-VALUE-POS = 0
        MOVE "INTO" TO WS-UPDATE-KEYWORD
        MOVE "/=" TO WS-UPDATE-OP
        PERFORM COMPILE-ARITHMETIC-UPDATE
        EXIT PARAGRAPH
    END-IF

    IF WS-OCCURS-POS = 0 OR WS-OCCURS-POS <= 2 OR
        WS-VALUE-POS <= WS-OCCURS-POS + 1 OR
        WS-VALUE-POS = WS-TOKEN-COUNT
        MOVE "malformed DIVIDE statement" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    COMPUTE WS-EXPR-START = 2
    COMPUTE WS-EXPR-END = WS-OCCURS-POS - 1
    PERFORM BUILD-EXPRESSION
    MOVE WS-EXPR TO WS-LEFT-EXPR

    COMPUTE WS-EXPR-START = WS-OCCURS-POS + 1
    IF WS-REDEFINES-POS > 0
        COMPUTE WS-EXPR-END = WS-VALUE-POS - 1
    ELSE
        COMPUTE WS-EXPR-END = WS-VALUE-POS - 1
    END-IF
    PERFORM BUILD-EXPRESSION
    MOVE WS-EXPR TO WS-RIGHT-EXPR

    COMPUTE WS-REF-START = WS-VALUE-POS + 1
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y"
        MOVE "DIVIDE GIVING target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    IF WS-REDEFINES-POS > 0
        IF WS-REF-NEXT-POS NOT = WS-REDEFINES-POS
            MOVE "DIVIDE GIVING target syntax is not supported yet"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
    ELSE
        IF WS-REF-NEXT-POS NOT = WS-TOKEN-COUNT + 1
            MOVE "DIVIDE GIVING target syntax is not supported yet"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
    END-IF
    MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
    MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME

    PERFORM FLUSH-PENDING-ASSIGNMENT
    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " / " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM EMIT-OVERLAY-SYNC-CALL
    END-IF

    IF WS-REDEFINES-POS > 0
        COMPUTE WS-REF-START = WS-REDEFINES-POS + 1
        PERFORM RESOLVE-REFERENCE
        IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-TOKEN-COUNT + 1
            MOVE "DIVIDE REMAINDER target was not declared"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
        MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " = " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " % " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ";" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
        IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
            MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
            PERFORM EMIT-OVERLAY-SYNC-CALL
        END-IF
    END-IF
    .

COMPILE-COMPUTE.
    IF WS-TOKEN-COUNT < 4
        MOVE "COMPUTE expects COMPUTE name = expression" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 2 TO WS-REF-START
    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS > WS-TOKEN-COUNT OR
        TOKEN-UPPER(WS-REF-NEXT-POS) NOT = "="
        MOVE "COMPUTE target was not declared" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "N"
        MOVE "COMPUTE target must be numeric" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
    MOVE SYMBOL-NAME(WS-SYMBOL-INDEX) TO WS-TARGET-NAME
    MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME

    COMPUTE WS-EXPR-START = WS-REF-NEXT-POS + 1
    MOVE WS-TOKEN-COUNT TO WS-EXPR-END
    PERFORM CHECK-EXPRESSION-USES-TARGET
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    IF SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
        PERFORM FLUSH-PENDING-ASSIGNMENT
        PERFORM EMIT-LINE
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM EMIT-OVERLAY-SYNC-CALL
    ELSE
        PERFORM QUEUE-ASSIGNMENT
    END-IF
    .

CHECK-EXPRESSION-USES-TARGET.
    MOVE "N" TO WS-EXPR-USES-TARGET
    PERFORM VARYING WS-WORK-INDEX FROM WS-EXPR-START BY 1
        UNTIL WS-WORK-INDEX > WS-EXPR-END OR WS-EXPR-USES-TARGET = "Y"
        IF TOKEN-UPPER(WS-WORK-INDEX) = WS-TARGET-NAME
            MOVE "Y" TO WS-EXPR-USES-TARGET
        END-IF
    END-PERFORM
    .

QUEUE-ASSIGNMENT.
    IF WS-OPTIMIZE NOT = "Y"
        PERFORM EMIT-LINE
        EXIT PARAGRAPH
    END-IF

    MOVE FUNCTION TRIM(WS-EMIT-PAYLOAD TRAILING) TO WS-QUEUE-WORK

    IF WS-PENDING-ASSIGN = "Y"
        IF WS-PENDING-TARGET = WS-TARGET-C-NAME AND
            WS-EXPR-USES-TARGET = "N"
            MOVE WS-QUEUE-WORK TO WS-PENDING-LINE
            EXIT PARAGRAPH
        END-IF
        PERFORM FLUSH-PENDING-ASSIGNMENT
    END-IF

    MOVE WS-QUEUE-WORK TO WS-PENDING-LINE
    MOVE WS-TARGET-C-NAME TO WS-PENDING-TARGET
    MOVE "Y" TO WS-PENDING-ASSIGN
    .

FLUSH-PENDING-ASSIGNMENT.
    IF WS-PENDING-ASSIGN = "Y"
        MOVE WS-PENDING-LINE TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE "N" TO WS-PENDING-ASSIGN
        MOVE SPACES TO WS-PENDING-LINE
        MOVE SPACES TO WS-PENDING-TARGET
    END-IF
    .

COMPILE-IF.
    IF WS-TOKEN-COUNT < 2
        MOVE "IF requires a condition" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 0 TO WS-WHEN-BODY-START
    MOVE 0 TO WS-WHEN-EXPR-END
    MOVE "N" TO WS-INLINE-END-IF
    PERFORM VARYING WS-WORK-INDEX FROM 3 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT OR WS-WHEN-BODY-START > 0
        EVALUATE TOKEN-UPPER(WS-WORK-INDEX)
            WHEN "DISPLAY"
            WHEN "ACCEPT"
            WHEN "MOVE"
            WHEN "ADD"
            WHEN "SUBTRACT"
            WHEN "MULTIPLY"
            WHEN "DIVIDE"
            WHEN "COMPUTE"
            WHEN "IF"
            WHEN "ELSE"
            WHEN "END-IF"
            WHEN "EVALUATE"
            WHEN "WHEN"
            WHEN "END-EVALUATE"
            WHEN "PERFORM"
            WHEN "END-PERFORM"
            WHEN "CALL"
            WHEN "STOP"
            WHEN "GOBACK"
            WHEN "EXIT"
            WHEN "CONTINUE"
                MOVE WS-WORK-INDEX TO WS-WHEN-BODY-START
            WHEN OTHER
                CONTINUE
        END-EVALUATE
    END-PERFORM

    MOVE 2 TO WS-EXPR-START
    IF WS-WHEN-BODY-START > 0
        COMPUTE WS-WHEN-EXPR-END = WS-WHEN-BODY-START - 1
        IF TOKEN-UPPER(WS-TOKEN-COUNT) = "END-IF"
            MOVE "Y" TO WS-INLINE-END-IF
        END-IF
        MOVE WS-WHEN-EXPR-END TO WS-EXPR-END
    ELSE
        MOVE WS-TOKEN-COUNT TO WS-EXPR-END
    END-IF
    PERFORM BUILD-EXPRESSION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "if (" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE

    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    ADD 1 TO WS-BLOCK-DEPTH
    MOVE "IF" TO BLOCK-KIND(WS-BLOCK-DEPTH)
    ADD 1 TO WS-INDENT-LEVEL

    IF WS-WHEN-BODY-START > 0
        IF WS-INLINE-END-IF = "Y"
            COMPUTE WS-WHEN-EXPR-END = WS-TOKEN-COUNT - 1
        ELSE
            MOVE WS-TOKEN-COUNT TO WS-WHEN-EXPR-END
        END-IF
        MOVE 1 TO WS-WORK-INDEX-2
        PERFORM VARYING WS-WORK-INDEX FROM WS-WHEN-BODY-START BY 1
            UNTIL WS-WORK-INDEX > WS-WHEN-EXPR-END
            MOVE TOKEN-RAW(WS-WORK-INDEX) TO TOKEN-RAW(WS-WORK-INDEX-2)
            MOVE TOKEN-UPPER(WS-WORK-INDEX) TO TOKEN-UPPER(WS-WORK-INDEX-2)
            ADD 1 TO WS-WORK-INDEX-2
        END-PERFORM
        COMPUTE WS-TOKEN-COUNT = WS-WORK-INDEX-2 - 1
        PERFORM VARYING WS-WORK-INDEX FROM WS-WORK-INDEX-2 BY 1
            UNTIL WS-WORK-INDEX > 128
            MOVE SPACES TO TOKEN-RAW(WS-WORK-INDEX)
            MOVE SPACES TO TOKEN-UPPER(WS-WORK-INDEX)
        END-PERFORM
        PERFORM HANDLE-PROCEDURE-LINE
        IF WS-INLINE-END-IF = "Y"
            PERFORM COMPILE-END-IF
        END-IF
    END-IF
    .

COMPILE-ELSE.
    IF WS-BLOCK-DEPTH = 0 OR BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "IF"
        MOVE "ELSE without matching IF" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    SUBTRACT 1 FROM WS-INDENT-LEVEL
    IF WS-TOKEN-COUNT > 1 AND TOKEN-UPPER(2) = "IF"
        MOVE 3 TO WS-EXPR-START
        MOVE WS-TOKEN-COUNT TO WS-EXPR-END
        PERFORM BUILD-EXPRESSION
        MOVE "} else {" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        ADD 1 TO WS-INDENT-LEVEL
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING "if (" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ")" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
        MOVE "{" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        ADD 1 TO WS-INDENT-LEVEL
        ADD 1 TO WS-BLOCK-DEPTH
        MOVE "IF" TO BLOCK-KIND(WS-BLOCK-DEPTH)
    ELSE
        MOVE "} else {" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        ADD 1 TO WS-INDENT-LEVEL
    END-IF
    .

COMPILE-END-IF.
    IF WS-BLOCK-DEPTH = 0 OR BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "IF"
        MOVE "END-IF without matching IF" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    SUBTRACT 1 FROM WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    SUBTRACT 1 FROM WS-BLOCK-DEPTH
    .

COMPILE-EVALUATE.
    IF WS-TOKEN-COUNT < 2
        MOVE "EVALUATE requires a subject or condition"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    ADD 1 TO WS-BLOCK-DEPTH
    IF WS-BLOCK-DEPTH > 128
        MOVE "block nesting too deep" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE "EVAL" TO BLOCK-KIND(WS-BLOCK-DEPTH)

    ADD 1 TO WS-EVALUATE-DEPTH
    IF WS-EVALUATE-DEPTH > 64
        MOVE "EVALUATE nesting too deep" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-BLOCK-DEPTH TO EVALUATE-BLOCK-DEPTH(WS-EVALUATE-DEPTH)
    MOVE "N" TO EVALUATE-HAS-WHEN(WS-EVALUATE-DEPTH)
    MOVE "N" TO EVALUATE-WHEN-OPEN(WS-EVALUATE-DEPTH)
    MOVE SPACES TO EVALUATE-SUBJECT-EXPR(WS-EVALUATE-DEPTH)
    MOVE SPACES TO EVALUATE-SUBJECT-LEN(WS-EVALUATE-DEPTH)
    MOVE SPACES TO EVALUATE-C-NAME(WS-EVALUATE-DEPTH)

    IF WS-TOKEN-COUNT = 2 AND TOKEN-UPPER(2) = "TRUE"
        MOVE "TRUE" TO EVALUATE-MODE(WS-EVALUATE-DEPTH)
        EXIT PARAGRAPH
    END-IF

    MOVE 2 TO WS-REF-START
    PERFORM LOAD-ALNUM-OPERAND
    IF WS-REF-OK = "Y" AND WS-REF-NEXT-POS = WS-TOKEN-COUNT + 1
        MOVE "ALPHA" TO EVALUATE-MODE(WS-EVALUATE-DEPTH)
        MOVE WS-OPERAND-C-EXPR TO EVALUATE-SUBJECT-EXPR(WS-EVALUATE-DEPTH)
        MOVE WS-OPERAND-LENGTH-EXPR TO EVALUATE-SUBJECT-LEN(WS-EVALUATE-DEPTH)
        EXIT PARAGRAPH
    END-IF

    MOVE "VALUE" TO EVALUATE-MODE(WS-EVALUATE-DEPTH)
    MOVE 2 TO WS-EXPR-START
    MOVE WS-TOKEN-COUNT TO WS-EXPR-END
    PERFORM BUILD-EXPRESSION
    MOVE WS-EXPR TO EVALUATE-SUBJECT-EXPR(WS-EVALUATE-DEPTH)

    ADD 1 TO WS-EVALUATE-ID
    MOVE SPACES TO WS-EVALUATE-C-NAME-WORK
    MOVE SPACES TO WS-PIC-WIDTH-TEXT
    MOVE WS-EVALUATE-ID TO WS-PIC-WIDTH-TEXT
    MOVE FUNCTION TRIM(WS-PIC-WIDTH-TEXT) TO WS-EVALUATE-C-NAME-WORK
    STRING "evaluate_subject_" DELIMITED BY SIZE
        FUNCTION TRIM(WS-EVALUATE-C-NAME-WORK) DELIMITED BY SIZE
        INTO EVALUATE-C-NAME(WS-EVALUATE-DEPTH)
    END-STRING

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "long long " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(EVALUATE-C-NAME(WS-EVALUATE-DEPTH))
        DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " = " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(EVALUATE-SUBJECT-EXPR(WS-EVALUATE-DEPTH))
        DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ";" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    .

COMPILE-WHEN.
    IF WS-BLOCK-DEPTH = 0 OR BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "EVAL"
        MOVE "WHEN without matching EVALUATE" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-EVALUATE-DEPTH = 0
        MOVE "WHEN without active EVALUATE context" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-TOKEN-COUNT < 2
        MOVE "WHEN requires a selector or OTHER" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF EVALUATE-WHEN-OPEN(WS-EVALUATE-DEPTH) = "Y"
        SUBTRACT 1 FROM WS-INDENT-LEVEL
        MOVE "}" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE "N" TO EVALUATE-WHEN-OPEN(WS-EVALUATE-DEPTH)
    END-IF

    MOVE 0 TO WS-WHEN-BODY-START
    MOVE 0 TO WS-WHEN-EXPR-END
    PERFORM FIND-WHEN-BODY-START

    IF TOKEN-UPPER(2) = "OTHER"
        IF EVALUATE-HAS-WHEN(WS-EVALUATE-DEPTH) = "Y"
            MOVE "else" TO WS-EMIT-PAYLOAD
        ELSE
            MOVE "if (1)" TO WS-EMIT-PAYLOAD
        END-IF
    ELSE
        IF WS-WHEN-BODY-START > 0
            COMPUTE WS-WHEN-EXPR-END = WS-WHEN-BODY-START - 1
        ELSE
            MOVE WS-TOKEN-COUNT TO WS-WHEN-EXPR-END
        END-IF

        IF WS-WHEN-EXPR-END < 2
            MOVE "WHEN requires a selector expression"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE 2 TO WS-EXPR-START
        IF EVALUATE-MODE(WS-EVALUATE-DEPTH) = "ALPHA"
            MOVE 2 TO WS-REF-START
            PERFORM LOAD-ALNUM-OPERAND
            IF WS-REF-OK NOT = "Y" OR
                WS-REF-NEXT-POS NOT = WS-WHEN-EXPR-END + 1
                MOVE "WHEN requires a simple alphanumeric selector"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
            MOVE WS-OPERAND-C-EXPR TO WS-EXPR
            MOVE WS-OPERAND-LENGTH-EXPR TO WS-SOURCE-LENGTH-EXPR
        ELSE
            MOVE WS-WHEN-EXPR-END TO WS-EXPR-END
            PERFORM BUILD-EXPRESSION
        END-IF

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        IF EVALUATE-HAS-WHEN(WS-EVALUATE-DEPTH) = "Y"
            STRING "else if (" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        ELSE
            STRING "if (" DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        END-IF

        IF EVALUATE-MODE(WS-EVALUATE-DEPTH) = "TRUE"
            STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
            END-STRING
        ELSE
            IF EVALUATE-MODE(WS-EVALUATE-DEPTH) = "ALPHA"
                STRING "minicobc_cmp_span(" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(EVALUATE-SUBJECT-EXPR(WS-EVALUATE-DEPTH))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ", " DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(EVALUATE-SUBJECT-LEN(WS-EVALUATE-DEPTH))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ", " DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ", " DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-SOURCE-LENGTH-EXPR) DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ") == 0" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            ELSE
                STRING FUNCTION TRIM(EVALUATE-C-NAME(WS-EVALUATE-DEPTH))
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING " == " DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
        END-IF
        STRING ")" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    PERFORM EMIT-LINE

    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    ADD 1 TO WS-INDENT-LEVEL
    MOVE "Y" TO EVALUATE-HAS-WHEN(WS-EVALUATE-DEPTH)
    MOVE "Y" TO EVALUATE-WHEN-OPEN(WS-EVALUATE-DEPTH)

    IF WS-WHEN-BODY-START > 0
        PERFORM REBASE-TOKENS-FROM-WHEN-BODY
        PERFORM HANDLE-PROCEDURE-LINE
    END-IF
    .

FIND-WHEN-BODY-START.
    PERFORM VARYING WS-WORK-INDEX FROM 3 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT OR WS-WHEN-BODY-START > 0
        EVALUATE TOKEN-UPPER(WS-WORK-INDEX)
            WHEN "DISPLAY"
            WHEN "ACCEPT"
            WHEN "MOVE"
            WHEN "ADD"
            WHEN "SUBTRACT"
            WHEN "MULTIPLY"
            WHEN "DIVIDE"
            WHEN "COMPUTE"
            WHEN "IF"
            WHEN "ELSE"
            WHEN "END-IF"
            WHEN "EVALUATE"
            WHEN "WHEN"
            WHEN "END-EVALUATE"
            WHEN "PERFORM"
            WHEN "END-PERFORM"
            WHEN "CALL"
            WHEN "STOP"
                MOVE WS-WORK-INDEX TO WS-WHEN-BODY-START
            WHEN OTHER
                CONTINUE
        END-EVALUATE
    END-PERFORM
    .

REBASE-TOKENS-FROM-WHEN-BODY.
    MOVE 1 TO WS-WORK-INDEX-2
    PERFORM VARYING WS-WORK-INDEX FROM WS-WHEN-BODY-START BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        MOVE TOKEN-RAW(WS-WORK-INDEX) TO TOKEN-RAW(WS-WORK-INDEX-2)
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO TOKEN-UPPER(WS-WORK-INDEX-2)
        ADD 1 TO WS-WORK-INDEX-2
    END-PERFORM

    COMPUTE WS-TOKEN-COUNT = WS-WORK-INDEX-2 - 1
    PERFORM VARYING WS-WORK-INDEX FROM WS-WORK-INDEX-2 BY 1
        UNTIL WS-WORK-INDEX > 128
        MOVE SPACES TO TOKEN-RAW(WS-WORK-INDEX)
        MOVE SPACES TO TOKEN-UPPER(WS-WORK-INDEX)
    END-PERFORM
    .

COMPILE-END-EVALUATE.
    IF WS-BLOCK-DEPTH = 0 OR BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "EVAL"
        MOVE "END-EVALUATE without matching EVALUATE"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-EVALUATE-DEPTH = 0
        MOVE "END-EVALUATE without active EVALUATE context"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF EVALUATE-WHEN-OPEN(WS-EVALUATE-DEPTH) = "Y"
        SUBTRACT 1 FROM WS-INDENT-LEVEL
        MOVE "}" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
    END-IF

    MOVE 0 TO EVALUATE-BLOCK-DEPTH(WS-EVALUATE-DEPTH)
    MOVE SPACES TO EVALUATE-MODE(WS-EVALUATE-DEPTH)
    MOVE "N" TO EVALUATE-HAS-WHEN(WS-EVALUATE-DEPTH)
    MOVE "N" TO EVALUATE-WHEN-OPEN(WS-EVALUATE-DEPTH)
    MOVE SPACES TO EVALUATE-C-NAME(WS-EVALUATE-DEPTH)
    MOVE SPACES TO EVALUATE-SUBJECT-EXPR(WS-EVALUATE-DEPTH)
    MOVE SPACES TO EVALUATE-SUBJECT-LEN(WS-EVALUATE-DEPTH)
    SUBTRACT 1 FROM WS-EVALUATE-DEPTH
    SUBTRACT 1 FROM WS-BLOCK-DEPTH
    .

COMPILE-PERFORM.
    IF WS-TOKEN-COUNT = 2 AND TOKEN-UPPER(2) NOT = "UNTIL"
        MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
        PERFORM FIND-PARAGRAPH
        IF WS-PARAGRAPH-INDEX = 0
            MOVE "PERFORM paragraph was not declared" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(PARAGRAPH-C-NAME(WS-PARAGRAPH-INDEX))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "();" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
        EXIT PARAGRAPH
    END-IF

    IF WS-TOKEN-COUNT >= 4 AND TOKEN-UPPER(3) = "UNTIL"
        MOVE TOKEN-UPPER(2) TO WS-SEARCH-NAME
        PERFORM FIND-PARAGRAPH
        IF WS-PARAGRAPH-INDEX = 0
            MOVE "PERFORM paragraph was not declared" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE 4 TO WS-EXPR-START
        MOVE WS-TOKEN-COUNT TO WS-EXPR-END
        PERFORM BUILD-LOOP-CONDITION

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING "while (" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ")" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE

        MOVE "{" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        ADD 1 TO WS-INDENT-LEVEL

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(PARAGRAPH-C-NAME(WS-PARAGRAPH-INDEX))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "();" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE

        SUBTRACT 1 FROM WS-INDENT-LEVEL
        MOVE "}" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        EXIT PARAGRAPH
    END-IF

    IF WS-TOKEN-COUNT >= 8 AND TOKEN-UPPER(2) = "VARYING"
        MOVE 0 TO WS-VALUE-POS
        MOVE 0 TO WS-OCCURS-POS
        MOVE 0 TO WS-REDEFINES-POS
        PERFORM VARYING WS-WORK-INDEX FROM 4 BY 1
            UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
            EVALUATE TOKEN-UPPER(WS-WORK-INDEX)
                WHEN "FROM"
                    MOVE WS-WORK-INDEX TO WS-VALUE-POS
                WHEN "BY"
                    MOVE WS-WORK-INDEX TO WS-OCCURS-POS
                WHEN "UNTIL"
                    MOVE WS-WORK-INDEX TO WS-REDEFINES-POS
                    EXIT PERFORM
                WHEN OTHER
                    CONTINUE
            END-EVALUATE
        END-PERFORM

        IF WS-VALUE-POS = 0 OR WS-OCCURS-POS = 0 OR WS-REDEFINES-POS = 0 OR
            WS-VALUE-POS <= 3 OR WS-OCCURS-POS <= WS-VALUE-POS + 1 OR
            WS-REDEFINES-POS <= WS-OCCURS-POS + 1 OR
            WS-REDEFINES-POS = WS-TOKEN-COUNT
            MOVE "malformed PERFORM VARYING statement" TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE 3 TO WS-REF-START
        PERFORM RESOLVE-REFERENCE
        IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-VALUE-POS
            MOVE "PERFORM VARYING requires a simple numeric variable"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "N" OR
            WS-REF-HAS-INDEX = "Y"
            MOVE "PERFORM VARYING requires a simple numeric variable"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-REF-C-EXPR TO WS-TARGET-C-NAME

        COMPUTE WS-EXPR-START = WS-VALUE-POS + 1
        COMPUTE WS-EXPR-END = WS-OCCURS-POS - 1
        PERFORM BUILD-EXPRESSION
        MOVE WS-EXPR TO WS-TARGET-INIT

        COMPUTE WS-EXPR-START = WS-OCCURS-POS + 1
        COMPUTE WS-EXPR-END = WS-REDEFINES-POS - 1
        PERFORM BUILD-EXPRESSION
        MOVE WS-EXPR TO WS-VARYING-STEP-EXPR

        COMPUTE WS-EXPR-START = WS-REDEFINES-POS + 1
        MOVE WS-TOKEN-COUNT TO WS-EXPR-END
        PERFORM BUILD-LOOP-CONDITION

        PERFORM FLUSH-PENDING-ASSIGNMENT

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(WS-TARGET-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " = " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-TARGET-INIT) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ";" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING "while (" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ")" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE

        MOVE "{" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        ADD 1 TO WS-BLOCK-DEPTH
        MOVE "PERFVARY" TO BLOCK-KIND(WS-BLOCK-DEPTH)
        MOVE WS-TARGET-C-NAME TO BLOCK-VARYING-TARGET(WS-BLOCK-DEPTH)
        MOVE WS-VARYING-STEP-EXPR TO BLOCK-VARYING-STEP(WS-BLOCK-DEPTH)
        ADD 1 TO WS-INDENT-LEVEL
        EXIT PARAGRAPH
    END-IF

    IF WS-TOKEN-COUNT < 3 OR TOKEN-UPPER(2) NOT = "UNTIL"
        MOVE "only PERFORM UNTIL, PERFORM paragraph, and PERFORM paragraph UNTIL are supported"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE 3 TO WS-EXPR-START
    MOVE WS-TOKEN-COUNT TO WS-EXPR-END
    PERFORM BUILD-LOOP-CONDITION

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "while (" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE

    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    ADD 1 TO WS-BLOCK-DEPTH
    MOVE "PERFORM" TO BLOCK-KIND(WS-BLOCK-DEPTH)
    ADD 1 TO WS-INDENT-LEVEL
    .

COMPILE-END-PERFORM.
    IF WS-BLOCK-DEPTH = 0 OR
        (BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "PERFORM" AND
        BLOCK-KIND(WS-BLOCK-DEPTH) NOT = "PERFVARY")
        MOVE "END-PERFORM without matching PERFORM" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF BLOCK-KIND(WS-BLOCK-DEPTH) = "PERFVARY"
        PERFORM FLUSH-PENDING-ASSIGNMENT
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(BLOCK-VARYING-TARGET(WS-BLOCK-DEPTH))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " = " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(BLOCK-VARYING-TARGET(WS-BLOCK-DEPTH))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " + (" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(BLOCK-VARYING-STEP(WS-BLOCK-DEPTH))
            DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ");" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
        MOVE SPACES TO BLOCK-VARYING-TARGET(WS-BLOCK-DEPTH)
        MOVE SPACES TO BLOCK-VARYING-STEP(WS-BLOCK-DEPTH)
    END-IF

    SUBTRACT 1 FROM WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    SUBTRACT 1 FROM WS-BLOCK-DEPTH
    .

COMPILE-CALL.
    IF WS-TOKEN-COUNT < 2
        MOVE "CALL requires a target name" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-RAW(2) TO WS-TOKEN-WORK
    MOVE FUNCTION LENGTH(FUNCTION TRIM(WS-TOKEN-WORK))
        TO WS-CALL-NAME-LEN
    IF WS-CALL-NAME-LEN < 3 OR WS-TOKEN-WORK(1:1) NOT = QUOTE OR
        WS-TOKEN-WORK(WS-CALL-NAME-LEN:1) NOT = QUOTE
        MOVE "only quoted external CALL targets are supported"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE SPACES TO WS-CALL-NAME-WORK
    MOVE WS-TOKEN-WORK(2:WS-CALL-NAME-LEN - 2) TO WS-CALL-NAME-WORK
    MOVE FUNCTION TRIM(WS-CALL-NAME-WORK) TO WS-CALL-NAME-WORK
    MOVE 0 TO WS-CALL-USING-POS
    MOVE 0 TO WS-CALL-RETURNING-POS

    PERFORM VARYING WS-WORK-INDEX FROM 3 BY 1
        UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT
        IF TOKEN-UPPER(WS-WORK-INDEX) = "USING"
            MOVE WS-WORK-INDEX TO WS-CALL-USING-POS
        END-IF
        IF TOKEN-UPPER(WS-WORK-INDEX) = "RETURNING"
            MOVE WS-WORK-INDEX TO WS-CALL-RETURNING-POS
        END-IF
    END-PERFORM

    PERFORM DETECT-INTERNAL-CALL-TARGET
    IF WS-INTERNAL-CALL = "Y"
        PERFORM BUILD-INTERNAL-CALL-TARGET-NAME
        PERFORM COMPILE-INTERNAL-CALL
        EXIT PARAGRAPH
    END-IF

    MOVE "void" TO WS-CALL-RETURN-TYPE
    MOVE SPACES TO WS-CALL-TARGET-C-NAME
    IF WS-CALL-RETURNING-POS > 0
        IF WS-CALL-RETURNING-POS = WS-TOKEN-COUNT
            MOVE "CALL RETURNING needs a target variable"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE TOKEN-UPPER(WS-CALL-RETURNING-POS + 1) TO WS-SEARCH-NAME
        PERFORM FIND-SYMBOL
        IF WS-SYMBOL-INDEX = 0
            MOVE "CALL RETURNING target was not declared"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-SYMBOL-INDEX TO WS-GROUP-TARGET-INDEX
        MOVE SYMBOL-C-NAME(WS-SYMBOL-INDEX) TO WS-CALL-TARGET-C-NAME
        PERFORM MAP-CALL-RETURN-TYPE
    END-IF

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "extern " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-CALL-RETURN-TYPE) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-CALL-NAME-WORK) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "(" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING

    IF WS-CALL-USING-POS > 0
        IF WS-CALL-RETURNING-POS > 0
            COMPUTE WS-CALL-ARG-END = WS-CALL-RETURNING-POS - 1
        ELSE
            MOVE WS-TOKEN-COUNT TO WS-CALL-ARG-END
        END-IF

        MOVE "REFERENCE" TO WS-CALL-ARG-MODE
        MOVE "Y" TO WS-CALL-FIRST-ARG
        MOVE WS-CALL-USING-POS TO WS-WORK-INDEX
        ADD 1 TO WS-WORK-INDEX
        PERFORM UNTIL WS-WORK-INDEX > WS-CALL-ARG-END
            IF TOKEN-UPPER(WS-WORK-INDEX) = "BY" AND
                WS-WORK-INDEX < WS-CALL-ARG-END
                IF TOKEN-UPPER(WS-WORK-INDEX + 1) = "VALUE"
                    MOVE "VALUE" TO WS-CALL-ARG-MODE
                    ADD 2 TO WS-WORK-INDEX
                ELSE
                    IF TOKEN-UPPER(WS-WORK-INDEX + 1) = "REFERENCE"
                        MOVE "REFERENCE" TO WS-CALL-ARG-MODE
                        ADD 2 TO WS-WORK-INDEX
                    END-IF
                END-IF
            END-IF

            IF WS-WORK-INDEX <= WS-CALL-ARG-END
                IF WS-CALL-FIRST-ARG = "Y"
                    MOVE "N" TO WS-CALL-FIRST-ARG
                ELSE
                    STRING ", " DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                END-IF

                MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
                MOVE SPACES TO WS-ARG-WORK
                MOVE 1 TO WS-APPEND-PTR
                MOVE WS-WORK-INDEX TO WS-REF-START
                PERFORM RESOLVE-REFERENCE

                IF WS-REF-OK = "Y" AND
                    WS-REF-NEXT-POS <= WS-CALL-ARG-END + 1
                    MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
                    MOVE 1 TO WS-APPEND-PTR
                    IF WS-CALL-ARG-MODE = "REFERENCE"
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                            MOVE "CALL BY REFERENCE does not support groups yet"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                            STRING "char" DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                        ELSE
                            STRING FUNCTION TRIM(
                                SYMBOL-C-TYPE(WS-SYMBOL-INDEX))
                                DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                        END-IF
                        STRING " *" DELIMITED BY SIZE
                            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                        END-STRING
                    ELSE
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                            MOVE "CALL BY VALUE does not support groups yet"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                            MOVE
                                "CALL BY VALUE currently only supports numeric items"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF
                        STRING FUNCTION TRIM(SYMBOL-C-TYPE(WS-SYMBOL-INDEX))
                            DELIMITED BY SIZE
                            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                        END-STRING
                    END-IF
                    MOVE WS-REF-NEXT-POS TO WS-WORK-INDEX
                ELSE
                    MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
                    PERFORM FIND-SYMBOL

                    IF WS-CALL-ARG-MODE = "REFERENCE"
                        MOVE "CALL BY REFERENCE needs a declared variable"
                            TO WS-ERROR-MESSAGE
                        PERFORM FAIL-COMPILATION
                    ELSE
                        MOVE 1 TO WS-APPEND-PTR
                        IF WS-SYMBOL-INDEX > 0
                            IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                                MOVE
                                    "CALL BY VALUE does not support groups yet"
                                    TO WS-ERROR-MESSAGE
                                PERFORM FAIL-COMPILATION
                            END-IF
                            IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                                MOVE
                                    "CALL BY VALUE currently only supports numeric items"
                                    TO WS-ERROR-MESSAGE
                                PERFORM FAIL-COMPILATION
                            END-IF
                            STRING FUNCTION TRIM(
                                SYMBOL-C-TYPE(WS-SYMBOL-INDEX))
                                DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                        ELSE
                            STRING "int" DELIMITED BY SIZE
                                INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                            END-STRING
                        END-IF
                        ADD 1 TO WS-WORK-INDEX
                    END-IF
                END-IF
                MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR
                STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
        END-PERFORM
    ELSE
        STRING "void" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF

    STRING ");" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    IF WS-CALL-RETURNING-POS > 0
        STRING FUNCTION TRIM(WS-CALL-TARGET-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING " = " DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    STRING FUNCTION TRIM(WS-CALL-NAME-WORK) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "(" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING

    IF WS-CALL-USING-POS > 0
        IF WS-CALL-RETURNING-POS > 0
            COMPUTE WS-CALL-ARG-END = WS-CALL-RETURNING-POS - 1
        ELSE
            MOVE WS-TOKEN-COUNT TO WS-CALL-ARG-END
        END-IF

        MOVE "REFERENCE" TO WS-CALL-ARG-MODE
        MOVE "Y" TO WS-CALL-FIRST-ARG
        MOVE WS-CALL-USING-POS TO WS-WORK-INDEX
        ADD 1 TO WS-WORK-INDEX
        PERFORM UNTIL WS-WORK-INDEX > WS-CALL-ARG-END
            IF TOKEN-UPPER(WS-WORK-INDEX) = "BY" AND
                WS-WORK-INDEX < WS-CALL-ARG-END
                IF TOKEN-UPPER(WS-WORK-INDEX + 1) = "VALUE"
                    MOVE "VALUE" TO WS-CALL-ARG-MODE
                    ADD 2 TO WS-WORK-INDEX
                ELSE
                    IF TOKEN-UPPER(WS-WORK-INDEX + 1) = "REFERENCE"
                        MOVE "REFERENCE" TO WS-CALL-ARG-MODE
                        ADD 2 TO WS-WORK-INDEX
                    END-IF
                END-IF
            END-IF

            IF WS-WORK-INDEX <= WS-CALL-ARG-END
                IF WS-CALL-FIRST-ARG = "Y"
                    MOVE "N" TO WS-CALL-FIRST-ARG
                ELSE
                    STRING ", " DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                END-IF

                MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
                MOVE SPACES TO WS-ARG-WORK
                MOVE 1 TO WS-APPEND-PTR
                MOVE WS-WORK-INDEX TO WS-REF-START
                PERFORM RESOLVE-REFERENCE

                IF WS-REF-OK = "Y" AND
                    WS-REF-NEXT-POS <= WS-CALL-ARG-END + 1
                    MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
                    MOVE 1 TO WS-APPEND-PTR
                    IF WS-CALL-ARG-MODE = "REFERENCE"
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                            MOVE "CALL BY REFERENCE does not support groups yet"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                            STRING FUNCTION TRIM(WS-REF-C-EXPR)
                                DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                        ELSE
                            STRING "&" DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                            STRING FUNCTION TRIM(WS-REF-C-EXPR)
                                DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                        END-IF
                    ELSE
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                            MOVE "CALL BY VALUE does not support groups yet"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF
                        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                            MOVE
                                "CALL BY VALUE currently only supports numeric items"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF
                        STRING FUNCTION TRIM(WS-REF-C-EXPR)
                            DELIMITED BY SIZE
                            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                        END-STRING
                    END-IF
                    MOVE WS-REF-NEXT-POS TO WS-WORK-INDEX
                ELSE
                    IF WS-CALL-ARG-MODE = "REFERENCE"
                        MOVE "CALL BY REFERENCE needs a declared variable"
                            TO WS-ERROR-MESSAGE
                        PERFORM FAIL-COMPILATION
                    ELSE
                        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
                        PERFORM FIND-SYMBOL
                        MOVE 1 TO WS-APPEND-PTR
                        IF WS-SYMBOL-INDEX > 0
                            IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                                MOVE
                                    "CALL BY VALUE does not support groups yet"
                                    TO WS-ERROR-MESSAGE
                                PERFORM FAIL-COMPILATION
                            END-IF
                            IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A"
                                MOVE
                                    "CALL BY VALUE currently only supports numeric items"
                                    TO WS-ERROR-MESSAGE
                                PERFORM FAIL-COMPILATION
                            END-IF
                            STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                                DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                        ELSE
                            STRING FUNCTION TRIM(TOKEN-RAW(WS-WORK-INDEX))
                                DELIMITED BY SIZE
                                INTO WS-ARG-WORK
                                WITH POINTER WS-APPEND-PTR
                            END-STRING
                        END-IF
                        ADD 1 TO WS-WORK-INDEX
                    END-IF
                END-IF
                MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR
                STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
        END-PERFORM
    END-IF

    STRING ");" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE
    IF WS-CALL-RETURNING-POS > 0 AND
        SYMBOL-OVERLAY-ROOT(WS-GROUP-TARGET-INDEX) > 0
        MOVE WS-GROUP-TARGET-INDEX TO WS-SYMBOL-INDEX
        PERFORM EMIT-OVERLAY-SYNC-CALL
    END-IF
    .

COMPILE-INTERNAL-CALL.
    IF WS-CALL-RETURNING-POS > 0
        MOVE "internal CALL RETURNING is not supported yet"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE SPACES TO WS-EMIT-PAYLOAD
    MOVE 1 TO WS-APPEND-PTR
    STRING "extern void " DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-CALL-PROGRAM-C-NAME) DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING "(void **);" DELIMITED BY SIZE
        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
    END-STRING
    PERFORM EMIT-LINE

    MOVE "{" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    ADD 1 TO WS-INDENT-LEVEL

    IF WS-CALL-USING-POS > 0
        IF WS-CALL-RETURNING-POS > 0
            COMPUTE WS-CALL-ARG-END = WS-CALL-RETURNING-POS - 1
        ELSE
            MOVE WS-TOKEN-COUNT TO WS-CALL-ARG-END
        END-IF

        MOVE "void *minicobc_call_args[32];" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        MOVE "REFERENCE" TO WS-CALL-ARG-MODE
        MOVE 0 TO WS-USING-INDEX
        MOVE WS-CALL-USING-POS TO WS-WORK-INDEX-3
        ADD 1 TO WS-WORK-INDEX-3

        PERFORM UNTIL WS-WORK-INDEX-3 > WS-CALL-ARG-END
            IF TOKEN-UPPER(WS-WORK-INDEX-3) = "BY" AND
                WS-WORK-INDEX-3 < WS-CALL-ARG-END
                IF TOKEN-UPPER(WS-WORK-INDEX-3 + 1) = "VALUE"
                    MOVE "VALUE" TO WS-CALL-ARG-MODE
                    ADD 2 TO WS-WORK-INDEX-3
                ELSE
                    IF TOKEN-UPPER(WS-WORK-INDEX-3 + 1) = "REFERENCE"
                        MOVE "REFERENCE" TO WS-CALL-ARG-MODE
                        ADD 2 TO WS-WORK-INDEX-3
                    END-IF
                END-IF
            END-IF

            IF WS-WORK-INDEX-3 <= WS-CALL-ARG-END
                IF WS-CALL-ARG-MODE NOT = "REFERENCE"
                    MOVE "internal CALL currently only supports BY REFERENCE"
                        TO WS-ERROR-MESSAGE
                    PERFORM FAIL-COMPILATION
                END-IF

                MOVE TOKEN-UPPER(WS-WORK-INDEX-3) TO WS-SEARCH-NAME
                PERFORM FIND-SYMBOL
                IF WS-SYMBOL-INDEX > 0 AND
                    (WS-WORK-INDEX-3 = WS-CALL-ARG-END OR
                        (TOKEN-RAW(WS-WORK-INDEX-3 + 1) NOT = "(" AND
                        TOKEN-UPPER(WS-WORK-INDEX-3 + 1) NOT = "OF"))
                    MOVE "Y" TO WS-REF-OK
                    MOVE "N" TO WS-REF-HAS-INDEX
                    MOVE "N" TO WS-REF-HAS-SLICE
                    MOVE WS-SYMBOL-INDEX TO WS-REF-SYMBOL-INDEX
                    MOVE FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                        TO WS-REF-C-EXPR
                    COMPUTE WS-REF-NEXT-POS = WS-WORK-INDEX-3 + 1
                ELSE
                    MOVE WS-WORK-INDEX-3 TO WS-REF-START
                    PERFORM RESOLVE-REFERENCE
                END-IF
                IF WS-REF-OK NOT = "Y" OR
                    WS-REF-NEXT-POS > WS-CALL-ARG-END + 1
                    MOVE TOKEN-RAW(WS-WORK-INDEX-3) TO WS-TOKEN-WORK
                    PERFORM NORMALIZE-SIMPLE-TOKEN
                    PERFORM TOKEN-WORK-IS-INTEGER
                    IF WS-FOLD-NUMERIC-OK NOT = "Y"
                        MOVE
                            "internal CALL needs declared variable arguments"
                            TO WS-ERROR-MESSAGE
                        PERFORM FAIL-COMPILATION
                    END-IF

                    ADD 1 TO WS-USING-INDEX
                    IF WS-USING-INDEX > 32
                        MOVE "too many internal CALL arguments"
                            TO WS-ERROR-MESSAGE
                        PERFORM FAIL-COMPILATION
                    END-IF

                    MOVE SPACES TO WS-ARG-WORK
                    MOVE 1 TO WS-APPEND-PTR
                    STRING "minicobc_call_value_" DELIMITED BY SIZE
                        INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                    END-STRING
                    MOVE WS-USING-INDEX TO WS-PLAIN-NUMERIC
                    PERFORM LOAD-PLAIN-INTEGER-TEXT
                    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                        INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                    END-STRING

                    MOVE SPACES TO WS-EMIT-PAYLOAD
                    MOVE 1 TO WS-APPEND-PTR
                    STRING "int " DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING " = " DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING FUNCTION TRIM(WS-TOKEN-WORK) DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING ";" DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    PERFORM EMIT-LINE

                    MOVE SPACES TO WS-EMIT-PAYLOAD
                    MOVE 1 TO WS-APPEND-PTR
                    STRING "minicobc_call_args[" DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    MOVE WS-USING-INDEX TO WS-PLAIN-NUMERIC
                    SUBTRACT 1 FROM WS-PLAIN-NUMERIC
                    PERFORM LOAD-PLAIN-INTEGER-TEXT
                    STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING "] = &" DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    STRING ";" DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                    PERFORM EMIT-LINE
                    ADD 1 TO WS-WORK-INDEX-3
                ELSE
                    ADD 1 TO WS-USING-INDEX
                    IF WS-USING-INDEX > 32
                        MOVE "too many internal CALL arguments"
                            TO WS-ERROR-MESSAGE
                        PERFORM FAIL-COMPILATION
                    END-IF

                    MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
                    IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
                        IF WS-REF-HAS-INDEX = "Y"
                            MOVE "indexed group actuals are not supported yet"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF

                        PERFORM BUILD-GROUP-TYPE-NAME
                        MOVE SPACES TO WS-ARG-WORK
                        MOVE 1 TO WS-APPEND-PTR
                        STRING "minicobc_call_group_" DELIMITED BY SIZE
                            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                        END-STRING
                        MOVE WS-USING-INDEX TO WS-PLAIN-NUMERIC
                        PERFORM LOAD-PLAIN-INTEGER-TEXT
                        STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
                        END-STRING

                        MOVE SPACES TO WS-EMIT-PAYLOAD
                        MOVE 1 TO WS-APPEND-PTR
                        STRING FUNCTION TRIM(WS-GROUP-TYPE-NAME) DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING " " DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING ";" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        PERFORM EMIT-LINE

                        MOVE WS-SYMBOL-INDEX TO WS-SAVED-SYMBOL-INDEX
                        PERFORM VARYING WS-WORK-INDEX-2
                            FROM SYMBOL-FIRST-CHILD(WS-SAVED-SYMBOL-INDEX) BY 1
                            UNTIL WS-WORK-INDEX-2 >
                                SYMBOL-LAST-CHILD(WS-SAVED-SYMBOL-INDEX)
                            IF SYMBOL-KIND(WS-WORK-INDEX-2) NOT = "G"
                                MOVE WS-WORK-INDEX-2 TO WS-SYMBOL-INDEX
                                PERFORM LOAD-EFFECTIVE-OCCURS
                                MOVE SPACES TO WS-EMIT-PAYLOAD
                                MOVE 1 TO WS-APPEND-PTR
                                STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING "." DELIMITED BY SIZE
                                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING "m_" DELIMITED BY SIZE
                                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                                    DELIMITED BY SIZE
                                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING " = " DELIMITED BY SIZE
                                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                END-STRING
                                IF WS-EFFECTIVE-OCCURS = 1
                                    STRING "&" DELIMITED BY SIZE
                                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                    END-STRING
                                END-IF
                                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                                    DELIMITED BY SIZE
                                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING ";" DELIMITED BY SIZE
                                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                                END-STRING
                                PERFORM EMIT-LINE
                            END-IF
                        END-PERFORM
                        MOVE WS-SAVED-SYMBOL-INDEX TO WS-SYMBOL-INDEX

                        MOVE SPACES TO WS-EMIT-PAYLOAD
                        MOVE 1 TO WS-APPEND-PTR
                        STRING "minicobc_call_args[" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        MOVE WS-USING-INDEX TO WS-PLAIN-NUMERIC
                        SUBTRACT 1 FROM WS-PLAIN-NUMERIC
                        PERFORM LOAD-PLAIN-INTEGER-TEXT
                        STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING "] = &" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING ";" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        PERFORM EMIT-LINE
                    ELSE
                        IF WS-REF-HAS-SLICE = "Y"
                            MOVE
                                "internal CALL does not support sliced alphanumeric actuals yet"
                                TO WS-ERROR-MESSAGE
                            PERFORM FAIL-COMPILATION
                        END-IF
                        PERFORM LOAD-EFFECTIVE-OCCURS
                        MOVE SPACES TO WS-EMIT-PAYLOAD
                        MOVE 1 TO WS-APPEND-PTR
                        STRING "minicobc_call_args[" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        MOVE WS-USING-INDEX TO WS-PLAIN-NUMERIC
                        SUBTRACT 1 FROM WS-PLAIN-NUMERIC
                        PERFORM LOAD-PLAIN-INTEGER-TEXT
                        STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING "] = " DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        IF WS-REF-HAS-INDEX = "Y" OR WS-EFFECTIVE-OCCURS = 1
                            STRING "&" DELIMITED BY SIZE
                                INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                            END-STRING
                        END-IF
                        STRING FUNCTION TRIM(WS-REF-C-EXPR) DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        STRING ";" DELIMITED BY SIZE
                            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                        END-STRING
                        PERFORM EMIT-LINE
                    END-IF
                    MOVE WS-REF-NEXT-POS TO WS-WORK-INDEX-3
                END-IF
            END-IF
        END-PERFORM

        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(WS-CALL-PROGRAM-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "(minicobc_call_args);" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
    ELSE
        MOVE SPACES TO WS-EMIT-PAYLOAD
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(WS-CALL-PROGRAM-C-NAME) DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "(NULL);" DELIMITED BY SIZE
            INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
        END-STRING
        PERFORM EMIT-LINE
    END-IF

    SUBTRACT 1 FROM WS-INDENT-LEVEL
    MOVE "}" TO WS-EMIT-PAYLOAD
    PERFORM EMIT-LINE
    .

MAP-CALL-RETURN-TYPE.
    MOVE FUNCTION TRIM(SYMBOL-C-TYPE(WS-SYMBOL-INDEX))
        TO WS-CALL-RETURN-TYPE
    IF FUNCTION TRIM(WS-CALL-RETURN-TYPE) = SPACES
        MOVE "int" TO WS-CALL-RETURN-TYPE
    END-IF
    .

COMPILE-GOBACK.
    IF WS-TOKEN-COUNT > 1
        MOVE "only bare GOBACK is supported" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    IF WS-IS-SUBPROGRAM = "Y" AND WS-HAS-PARAGRAPHS NOT = "Y"
        MOVE "goto minicobc_return;" TO WS-EMIT-PAYLOAD
    ELSE
        IF WS-IS-SUBPROGRAM = "Y" OR WS-HAS-PARAGRAPHS = "Y"
            MOVE "return;" TO WS-EMIT-PAYLOAD
        ELSE
            MOVE "return 0;" TO WS-EMIT-PAYLOAD
        END-IF
    END-IF
    PERFORM EMIT-LINE
    MOVE "Y" TO WS-RETURN-EMITTED
    .

COMPILE-EXIT.
    IF WS-TOKEN-COUNT = 2 AND TOKEN-UPPER(2) = "PARAGRAPH"
        MOVE "return;" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        EXIT PARAGRAPH
    END-IF
    IF WS-TOKEN-COUNT = 2 AND TOKEN-UPPER(2) = "PERFORM"
        MOVE 0 TO WS-FOUND-POS
        PERFORM VARYING WS-WORK-INDEX FROM WS-BLOCK-DEPTH BY -1
            UNTIL WS-WORK-INDEX < 1 OR WS-FOUND-POS > 0
            IF BLOCK-KIND(WS-WORK-INDEX) = "PERFORM" OR
                BLOCK-KIND(WS-WORK-INDEX) = "PERFVARY"
                MOVE WS-WORK-INDEX TO WS-FOUND-POS
            END-IF
        END-PERFORM
        IF WS-FOUND-POS = 0
            MOVE "EXIT PERFORM without matching PERFORM"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        PERFORM FLUSH-PENDING-ASSIGNMENT
        MOVE "break;" TO WS-EMIT-PAYLOAD
        PERFORM EMIT-LINE
        EXIT PARAGRAPH
    END-IF
    MOVE "only EXIT PARAGRAPH is supported" TO WS-ERROR-MESSAGE
    PERFORM FAIL-COMPILATION
    .

COMPILE-STOP.
    IF WS-TOKEN-COUNT >= 2 AND TOKEN-UPPER(2) = "RUN"
        IF WS-IS-SUBPROGRAM = "Y" OR WS-HAS-PARAGRAPHS = "Y"
            MOVE "exit(0);" TO WS-EMIT-PAYLOAD
        ELSE
            MOVE "return 0;" TO WS-EMIT-PAYLOAD
        END-IF
        PERFORM EMIT-LINE
        MOVE "Y" TO WS-RETURN-EMITTED
    ELSE
        MOVE "only STOP RUN is supported" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    .

BUILD-LOOP-CONDITION.
    MOVE "N" TO WS-CANONICAL-OK
    COMPUTE WS-CANONICAL-COUNT = WS-EXPR-END - WS-EXPR-START + 1

    IF WS-CANONICAL-COUNT = 3
        MOVE TOKEN-RAW(WS-EXPR-START + 1) TO WS-COMPARE-OP
        PERFORM MAP-INVERTED-COMPARE-OP
        IF WS-INVERTED-COMPARE-OP NOT = SPACES
            MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
            MOVE WS-EXPR-END TO WS-SAVED-EXPR-END

            MOVE WS-EXPR-START TO WS-EXPR-END
            PERFORM BUILD-PLAIN-EXPRESSION
            MOVE WS-EXPR TO WS-LEFT-EXPR

            COMPUTE WS-EXPR-START = WS-SAVED-EXPR-START + 2
            MOVE WS-EXPR-START TO WS-EXPR-END
            PERFORM BUILD-PLAIN-EXPRESSION
            MOVE WS-EXPR TO WS-RIGHT-EXPR

            MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
            MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
            PERFORM BUILD-COMPARISON-EXPRESSION
            MOVE "Y" TO WS-CANONICAL-OK
        END-IF
    END-IF

    IF WS-CANONICAL-OK NOT = "Y" AND WS-CANONICAL-COUNT = 6
        IF TOKEN-UPPER(WS-EXPR-START) = "NOT" AND
            TOKEN-RAW(WS-EXPR-START + 1) = "(" AND
            TOKEN-RAW(WS-EXPR-END) = ")"
            MOVE TOKEN-RAW(WS-EXPR-START + 3) TO WS-COMPARE-OP
            PERFORM MAP-DIRECT-COMPARE-OP
            IF WS-INVERTED-COMPARE-OP NOT = SPACES
                MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
                MOVE WS-EXPR-END TO WS-SAVED-EXPR-END

                COMPUTE WS-EXPR-START = WS-SAVED-EXPR-START + 2
                MOVE WS-EXPR-START TO WS-EXPR-END
                PERFORM BUILD-PLAIN-EXPRESSION
                MOVE WS-EXPR TO WS-LEFT-EXPR

                COMPUTE WS-EXPR-START = WS-SAVED-EXPR-START + 4
                MOVE WS-EXPR-START TO WS-EXPR-END
                PERFORM BUILD-PLAIN-EXPRESSION
                MOVE WS-EXPR TO WS-RIGHT-EXPR

                MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
                MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
                PERFORM BUILD-COMPARISON-EXPRESSION
                MOVE "Y" TO WS-CANONICAL-OK
            END-IF
        END-IF
    END-IF

    IF WS-CANONICAL-OK = "Y"
        EXIT PARAGRAPH
    END-IF

    PERFORM BUILD-EXPRESSION
    MOVE WS-EXPR TO WS-EXPR-SAVED
    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    STRING "!(" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-EXPR-SAVED) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    .

MAP-INVERTED-COMPARE-OP.
    MOVE SPACES TO WS-INVERTED-COMPARE-OP
    EVALUATE WS-COMPARE-OP
        WHEN "="
            MOVE "!=" TO WS-INVERTED-COMPARE-OP
        WHEN "<>"
            MOVE "==" TO WS-INVERTED-COMPARE-OP
        WHEN ">"
            MOVE "<=" TO WS-INVERTED-COMPARE-OP
        WHEN ">="
            MOVE "<" TO WS-INVERTED-COMPARE-OP
        WHEN "<"
            MOVE ">=" TO WS-INVERTED-COMPARE-OP
        WHEN "<="
            MOVE ">" TO WS-INVERTED-COMPARE-OP
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

MAP-DIRECT-COMPARE-OP.
    MOVE SPACES TO WS-INVERTED-COMPARE-OP
    EVALUATE WS-COMPARE-OP
        WHEN "="
            MOVE "==" TO WS-INVERTED-COMPARE-OP
        WHEN "<>"
            MOVE "!=" TO WS-INVERTED-COMPARE-OP
        WHEN ">"
            MOVE ">" TO WS-INVERTED-COMPARE-OP
        WHEN ">="
            MOVE ">=" TO WS-INVERTED-COMPARE-OP
        WHEN "<"
            MOVE "<" TO WS-INVERTED-COMPARE-OP
        WHEN "<="
            MOVE "<=" TO WS-INVERTED-COMPARE-OP
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

BUILD-COMPARISON-EXPRESSION.
    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-INVERTED-COMPARE-OP) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    .

LOAD-ALNUM-OPERAND.
    MOVE "N" TO WS-REF-OK
    MOVE SPACES TO WS-OPERAND-C-EXPR
    MOVE SPACES TO WS-OPERAND-LENGTH-EXPR

    MOVE TOKEN-RAW(WS-REF-START) TO WS-TOKEN-WORK
    IF TOKEN-UPPER(WS-REF-START) = "SPACE" OR
        TOKEN-UPPER(WS-REF-START) = "SPACES"
        MOVE '" "' TO WS-OPERAND-C-EXPR
        MOVE "1" TO WS-OPERAND-LENGTH-EXPR
        COMPUTE WS-REF-NEXT-POS = WS-REF-START + 1
        MOVE "Y" TO WS-REF-OK
        EXIT PARAGRAPH
    END-IF
    IF WS-TOKEN-WORK(1:1) = QUOTE
        MOVE FUNCTION TRIM(WS-TOKEN-WORK) TO WS-OPERAND-C-EXPR
        MOVE 1 TO WS-APPEND-PTR
        STRING "((int) strlen(" DELIMITED BY SIZE
            INTO WS-OPERAND-LENGTH-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-OPERAND-C-EXPR) DELIMITED BY SIZE
            INTO WS-OPERAND-LENGTH-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "))" DELIMITED BY SIZE
            INTO WS-OPERAND-LENGTH-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        COMPUTE WS-REF-NEXT-POS = WS-REF-START + 1
        MOVE "Y" TO WS-REF-OK
        EXIT PARAGRAPH
    END-IF

    PERFORM RESOLVE-REFERENCE
    IF WS-REF-OK NOT = "Y" OR SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "A"
        MOVE "N" TO WS-REF-OK
        EXIT PARAGRAPH
    END-IF

    MOVE WS-REF-C-EXPR TO WS-OPERAND-C-EXPR
    IF WS-REF-HAS-SLICE = "Y"
        MOVE WS-REF-LENGTH-TOKEN TO WS-OPERAND-LENGTH-EXPR
    ELSE
        MOVE SYMBOL-DISPLAY-TEXT(WS-SYMBOL-INDEX) TO WS-OPERAND-LENGTH-EXPR
    END-IF
    .

TRY-BUILD-ALNUM-COMPARISON.
    MOVE "N" TO WS-ALNUM-EXPR-OK
    MOVE WS-EXPR-START TO WS-REF-START
    PERFORM LOAD-ALNUM-OPERAND
    IF WS-REF-OK NOT = "Y"
        EXIT PARAGRAPH
    END-IF

    MOVE WS-OPERAND-C-EXPR TO WS-LEFT-EXPR
    MOVE WS-OPERAND-LENGTH-EXPR TO WS-TARGET-LENGTH-EXPR
    MOVE WS-REF-NEXT-POS TO WS-WORK-INDEX
    IF WS-WORK-INDEX >= WS-EXPR-END
        EXIT PARAGRAPH
    END-IF
    IF TOKEN-UPPER(WS-WORK-INDEX) = "NOT" AND
        WS-WORK-INDEX + 1 <= WS-EXPR-END AND
        TOKEN-UPPER(WS-WORK-INDEX + 1) = "="
        MOVE "<>" TO WS-COMPARE-OP
        ADD 2 TO WS-WORK-INDEX
    ELSE
        IF TOKEN-UPPER(WS-WORK-INDEX) NOT = "=" AND
            TOKEN-UPPER(WS-WORK-INDEX) NOT = "<>" AND
            TOKEN-UPPER(WS-WORK-INDEX) NOT = ">" AND
            TOKEN-UPPER(WS-WORK-INDEX) NOT = ">=" AND
            TOKEN-UPPER(WS-WORK-INDEX) NOT = "<" AND
            TOKEN-UPPER(WS-WORK-INDEX) NOT = "<="
            EXIT PARAGRAPH
        END-IF
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-COMPARE-OP
        ADD 1 TO WS-WORK-INDEX
    END-IF
    MOVE WS-WORK-INDEX TO WS-REF-START
    PERFORM LOAD-ALNUM-OPERAND
    IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-EXPR-END + 1
        EXIT PARAGRAPH
    END-IF

    MOVE WS-OPERAND-C-EXPR TO WS-RIGHT-EXPR
    MOVE WS-OPERAND-LENGTH-EXPR TO WS-SOURCE-LENGTH-EXPR
    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    STRING "(minicobc_cmp_span(" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ", " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-TARGET-LENGTH-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ", " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ", " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-SOURCE-LENGTH-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    EVALUATE WS-COMPARE-OP
        WHEN "="
            STRING ") == 0)" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "<>"
            STRING ") != 0)" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN ">"
            STRING ") > 0)" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN ">="
            STRING ") >= 0)" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "<"
            STRING ") < 0)" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "<="
            STRING ") <= 0)" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
    END-EVALUATE
    MOVE "Y" TO WS-ALNUM-EXPR-OK
    .

BUILD-EXPRESSION.
    MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
    MOVE WS-EXPR-END TO WS-SAVED-EXPR-END
    PERFORM TRY-BUILD-ALNUM-COMPARISON
    MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
    MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
    IF WS-ALNUM-EXPR-OK = "Y"
        EXIT PARAGRAPH
    END-IF

    IF WS-OPTIMIZE = "Y"
        PERFORM TRY-FOLD-CONSTANT-EXPRESSION
        IF WS-FOLD-OK = "Y"
            EXIT PARAGRAPH
        END-IF
    END-IF

    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    MOVE WS-EXPR-START TO WS-WORK-INDEX
    PERFORM UNTIL WS-WORK-INDEX > WS-EXPR-END
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "FUNCTION"
            PERFORM COMPILE-INTRINSIC-CALL
        ELSE
            PERFORM APPEND-PLAIN-EXPRESSION-TOKEN
            ADD 1 TO WS-WORK-INDEX
        END-IF
    END-PERFORM
    .

BUILD-PLAIN-EXPRESSION.
    MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
    MOVE WS-EXPR-END TO WS-SAVED-EXPR-END
    PERFORM TRY-BUILD-ALNUM-COMPARISON
    MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
    MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
    IF WS-ALNUM-EXPR-OK = "Y"
        EXIT PARAGRAPH
    END-IF

    IF WS-OPTIMIZE = "Y"
        PERFORM TRY-FOLD-CONSTANT-EXPRESSION
        IF WS-FOLD-OK = "Y"
            EXIT PARAGRAPH
        END-IF
    END-IF

    MOVE SPACES TO WS-EXPR
    MOVE 1 TO WS-APPEND-PTR
    PERFORM VARYING WS-WORK-INDEX FROM WS-EXPR-START BY 1
        UNTIL WS-WORK-INDEX > WS-EXPR-END
        PERFORM APPEND-PLAIN-EXPRESSION-TOKEN
    END-PERFORM
    .

TRY-FOLD-CONSTANT-EXPRESSION.
    MOVE "N" TO WS-FOLD-OK
    MOVE "Y" TO WS-FOLD-BUILD-OK
    MOVE 0 TO WS-FOLD-VALUE-COUNT
    MOVE 0 TO WS-FOLD-OP-COUNT

    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > 128
        MOVE 0 TO FOLD-VALUE(WS-WORK-INDEX)
        MOVE SPACES TO FOLD-OP(WS-WORK-INDEX)
    END-PERFORM

    PERFORM VARYING WS-WORK-INDEX FROM WS-EXPR-START BY 1
        UNTIL WS-WORK-INDEX > WS-EXPR-END OR WS-FOLD-BUILD-OK NOT = "Y"
        MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "FUNCTION"
            MOVE "N" TO WS-FOLD-BUILD-OK
        ELSE
            PERFORM LOAD-CONSTANT-TOKEN-VALUE
            IF WS-FOLD-TOKEN-OK = "Y"
                PERFORM PUSH-FOLD-VALUE
            ELSE
                EVALUATE WS-UPPER-WORK
                    WHEN "("
                        MOVE "(" TO WS-UPPER-WORK
                        PERFORM PUSH-FOLD-OP
                    WHEN ")"
                        MOVE "N" TO WS-FOLD-PAREN-FOUND
                        PERFORM UNTIL WS-FOLD-OP-COUNT = 0 OR
                            WS-FOLD-PAREN-FOUND = "Y" OR
                            WS-FOLD-BUILD-OK NOT = "Y"
                            MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT))
                                TO WS-UPPER-WORK
                            IF WS-UPPER-WORK = "("
                                SUBTRACT 1 FROM WS-FOLD-OP-COUNT
                                MOVE "Y" TO WS-FOLD-PAREN-FOUND
                            ELSE
                                PERFORM APPLY-TOP-FOLD-OP
                            END-IF
                        END-PERFORM
                        IF WS-FOLD-PAREN-FOUND NOT = "Y"
                            MOVE "N" TO WS-FOLD-BUILD-OK
                        END-IF
                    WHEN "="
                    WHEN "<>"
                    WHEN ">"
                    WHEN ">="
                    WHEN "<"
                    WHEN "<="
                    WHEN "+"
                    WHEN "-"
                    WHEN "*"
                    WHEN "/"
                    WHEN "MOD"
                    WHEN "AND"
                    WHEN "OR"
                    WHEN "NOT"
                        MOVE WS-UPPER-WORK TO WS-FOLD-CURRENT-OP
                        PERFORM GET-FOLD-OP-INFO
                        IF WS-FOLD-PRECEDENCE = 0
                            MOVE "N" TO WS-FOLD-BUILD-OK
                        ELSE
                            MOVE WS-FOLD-PRECEDENCE
                                TO WS-FOLD-CURRENT-PRECEDENCE
                            MOVE WS-FOLD-LEFT-ASSOC
                                TO WS-FOLD-CURRENT-LEFT-ASSOC
                            PERFORM REDUCE-FOLD-OPS
                            IF WS-FOLD-BUILD-OK = "Y"
                                MOVE WS-FOLD-CURRENT-OP TO WS-UPPER-WORK
                                PERFORM PUSH-FOLD-OP
                            END-IF
                        END-IF
                    WHEN OTHER
                        MOVE "N" TO WS-FOLD-BUILD-OK
                END-EVALUATE
            END-IF
        END-IF
    END-PERFORM

    IF WS-FOLD-BUILD-OK NOT = "Y"
        EXIT PARAGRAPH
    END-IF

    PERFORM UNTIL WS-FOLD-OP-COUNT = 0 OR WS-FOLD-BUILD-OK NOT = "Y"
        MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT)) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "("
            MOVE "N" TO WS-FOLD-BUILD-OK
        ELSE
            PERFORM APPLY-TOP-FOLD-OP
        END-IF
    END-PERFORM

    IF WS-FOLD-BUILD-OK = "Y" AND WS-FOLD-VALUE-COUNT = 1
        MOVE FOLD-VALUE(1) TO WS-FOLD-DISPLAY
        MOVE FUNCTION TRIM(WS-FOLD-DISPLAY) TO WS-EXPR
        MOVE "Y" TO WS-FOLD-OK
    END-IF
    .

LOAD-CONSTANT-TOKEN-VALUE.
    MOVE "N" TO WS-FOLD-TOKEN-OK
    MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
    MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK
    MOVE WS-UPPER-WORK TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX > 0 AND WS-OPTIMIZE = "Y" AND
        SYMBOL-READONLY-VALUE(WS-SYMBOL-INDEX) = "Y"
        MOVE SYMBOL-VALUE-TEXT(WS-SYMBOL-INDEX) TO WS-TOKEN-WORK
    END-IF

    PERFORM TOKEN-WORK-IS-INTEGER
    IF WS-FOLD-NUMERIC-OK = "Y"
        MOVE FUNCTION NUMVAL(FUNCTION TRIM(WS-TOKEN-WORK))
            TO WS-FOLD-TEMP-VALUE
        MOVE "Y" TO WS-FOLD-TOKEN-OK
    END-IF
    .

TOKEN-WORK-IS-INTEGER.
    MOVE "Y" TO WS-FOLD-NUMERIC-OK
    MOVE FUNCTION TRIM(WS-TOKEN-WORK) TO WS-TOKEN-WORK
    MOVE FUNCTION LENGTH(FUNCTION TRIM(WS-TOKEN-WORK)) TO WS-FOLD-TOKEN-LEN

    IF WS-FOLD-TOKEN-LEN = 0
        MOVE "N" TO WS-FOLD-NUMERIC-OK
        EXIT PARAGRAPH
    END-IF

    MOVE 1 TO WS-WORK-INDEX-2
    MOVE WS-TOKEN-WORK(1:1) TO WS-CHAR
    IF WS-CHAR = "-" OR WS-CHAR = "+"
        IF WS-FOLD-TOKEN-LEN = 1
            MOVE "N" TO WS-FOLD-NUMERIC-OK
            EXIT PARAGRAPH
        END-IF
        MOVE 2 TO WS-WORK-INDEX-2
    END-IF

    PERFORM VARYING WS-WORK-INDEX-2 FROM WS-WORK-INDEX-2 BY 1
        UNTIL WS-WORK-INDEX-2 > WS-FOLD-TOKEN-LEN OR
            WS-FOLD-NUMERIC-OK NOT = "Y"
        MOVE WS-TOKEN-WORK(WS-WORK-INDEX-2:1) TO WS-CHAR
        IF WS-CHAR < "0" OR WS-CHAR > "9"
            MOVE "N" TO WS-FOLD-NUMERIC-OK
        END-IF
    END-PERFORM
    .

GET-FOLD-OP-INFO.
    MOVE 0 TO WS-FOLD-PRECEDENCE
    MOVE "Y" TO WS-FOLD-LEFT-ASSOC
    EVALUATE WS-UPPER-WORK
        WHEN "OR"
            MOVE 1 TO WS-FOLD-PRECEDENCE
        WHEN "AND"
            MOVE 2 TO WS-FOLD-PRECEDENCE
        WHEN "="
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "<>"
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN ">"
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN ">="
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "<"
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "<="
            MOVE 3 TO WS-FOLD-PRECEDENCE
        WHEN "+"
            MOVE 4 TO WS-FOLD-PRECEDENCE
        WHEN "-"
            MOVE 4 TO WS-FOLD-PRECEDENCE
        WHEN "*"
            MOVE 5 TO WS-FOLD-PRECEDENCE
        WHEN "/"
            MOVE 5 TO WS-FOLD-PRECEDENCE
        WHEN "MOD"
            MOVE 5 TO WS-FOLD-PRECEDENCE
        WHEN "NOT"
            MOVE 6 TO WS-FOLD-PRECEDENCE
            MOVE "N" TO WS-FOLD-LEFT-ASSOC
        WHEN OTHER
            CONTINUE
    END-EVALUATE
    .

REDUCE-FOLD-OPS.
    PERFORM UNTIL WS-FOLD-OP-COUNT = 0 OR WS-FOLD-BUILD-OK NOT = "Y"
        MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT)) TO WS-UPPER-WORK
        IF WS-UPPER-WORK = "("
            EXIT PERFORM
        END-IF
        PERFORM GET-FOLD-OP-INFO
        MOVE WS-FOLD-PRECEDENCE TO WS-FOLD-PRECEDENCE-2
        IF WS-FOLD-CURRENT-LEFT-ASSOC = "Y"
            IF WS-FOLD-PRECEDENCE-2 >= WS-FOLD-CURRENT-PRECEDENCE
                PERFORM APPLY-TOP-FOLD-OP
            ELSE
                EXIT PERFORM
            END-IF
        ELSE
            IF WS-FOLD-PRECEDENCE-2 > WS-FOLD-CURRENT-PRECEDENCE
                PERFORM APPLY-TOP-FOLD-OP
            ELSE
                EXIT PERFORM
            END-IF
        END-IF
    END-PERFORM
    .

PUSH-FOLD-VALUE.
    ADD 1 TO WS-FOLD-VALUE-COUNT
    IF WS-FOLD-VALUE-COUNT > 128
        MOVE "N" TO WS-FOLD-BUILD-OK
        EXIT PARAGRAPH
    END-IF
    MOVE WS-FOLD-TEMP-VALUE TO FOLD-VALUE(WS-FOLD-VALUE-COUNT)
    .

PUSH-FOLD-OP.
    ADD 1 TO WS-FOLD-OP-COUNT
    IF WS-FOLD-OP-COUNT > 128
        MOVE "N" TO WS-FOLD-BUILD-OK
        EXIT PARAGRAPH
    END-IF
    MOVE WS-UPPER-WORK TO FOLD-OP(WS-FOLD-OP-COUNT)
    .

APPLY-TOP-FOLD-OP.
    IF WS-FOLD-OP-COUNT = 0
        MOVE "N" TO WS-FOLD-BUILD-OK
        EXIT PARAGRAPH
    END-IF

    MOVE FUNCTION TRIM(FOLD-OP(WS-FOLD-OP-COUNT)) TO WS-UPPER-WORK
    SUBTRACT 1 FROM WS-FOLD-OP-COUNT

    IF WS-UPPER-WORK = "NOT"
        IF WS-FOLD-VALUE-COUNT < 1
            MOVE "N" TO WS-FOLD-BUILD-OK
            EXIT PARAGRAPH
        END-IF
        MOVE FOLD-VALUE(WS-FOLD-VALUE-COUNT) TO WS-FOLD-TEMP-VALUE
        SUBTRACT 1 FROM WS-FOLD-VALUE-COUNT
        IF WS-FOLD-TEMP-VALUE = 0
            MOVE 1 TO WS-FOLD-RESULT
        ELSE
            MOVE 0 TO WS-FOLD-RESULT
        END-IF
    ELSE
        IF WS-FOLD-VALUE-COUNT < 2
            MOVE "N" TO WS-FOLD-BUILD-OK
            EXIT PARAGRAPH
        END-IF
        MOVE FOLD-VALUE(WS-FOLD-VALUE-COUNT) TO WS-FOLD-TEMP-VALUE-2
        SUBTRACT 1 FROM WS-FOLD-VALUE-COUNT
        MOVE FOLD-VALUE(WS-FOLD-VALUE-COUNT) TO WS-FOLD-TEMP-VALUE
        SUBTRACT 1 FROM WS-FOLD-VALUE-COUNT

        EVALUATE WS-UPPER-WORK
            WHEN "+"
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE + WS-FOLD-TEMP-VALUE-2
            WHEN "-"
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE - WS-FOLD-TEMP-VALUE-2
            WHEN "*"
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE * WS-FOLD-TEMP-VALUE-2
            WHEN "/"
                IF WS-FOLD-TEMP-VALUE-2 = 0
                    MOVE "N" TO WS-FOLD-BUILD-OK
                    EXIT PARAGRAPH
                END-IF
                COMPUTE WS-FOLD-RESULT =
                    WS-FOLD-TEMP-VALUE / WS-FOLD-TEMP-VALUE-2
            WHEN "MOD"
                IF WS-FOLD-TEMP-VALUE-2 = 0
                    MOVE "N" TO WS-FOLD-BUILD-OK
                    EXIT PARAGRAPH
                END-IF
                COMPUTE WS-FOLD-RESULT = FUNCTION MOD(
                    WS-FOLD-TEMP-VALUE, WS-FOLD-TEMP-VALUE-2)
            WHEN "="
                IF WS-FOLD-TEMP-VALUE = WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "<>"
                IF WS-FOLD-TEMP-VALUE NOT = WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN ">"
                IF WS-FOLD-TEMP-VALUE > WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN ">="
                IF WS-FOLD-TEMP-VALUE >= WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "<"
                IF WS-FOLD-TEMP-VALUE < WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "<="
                IF WS-FOLD-TEMP-VALUE <= WS-FOLD-TEMP-VALUE-2
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "AND"
                IF WS-FOLD-TEMP-VALUE NOT = 0 AND
                    WS-FOLD-TEMP-VALUE-2 NOT = 0
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN "OR"
                IF WS-FOLD-TEMP-VALUE NOT = 0 OR
                    WS-FOLD-TEMP-VALUE-2 NOT = 0
                    MOVE 1 TO WS-FOLD-RESULT
                ELSE
                    MOVE 0 TO WS-FOLD-RESULT
                END-IF
            WHEN OTHER
                MOVE "N" TO WS-FOLD-BUILD-OK
                EXIT PARAGRAPH
        END-EVALUATE
    END-IF

    MOVE WS-FOLD-RESULT TO WS-FOLD-TEMP-VALUE
    PERFORM PUSH-FOLD-VALUE
    .

APPEND-PLAIN-EXPRESSION-TOKEN.
    IF WS-APPEND-PTR > 1
        STRING " " DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF

    MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
    MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-UPPER-WORK

    EVALUATE WS-UPPER-WORK
        WHEN "="
            STRING "==" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "<>"
            STRING "!=" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "AND"
            STRING "&&" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "OR"
            STRING "||" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN "NOT"
            IF WS-WORK-INDEX < WS-EXPR-END AND
                TOKEN-UPPER(WS-WORK-INDEX + 1) = "="
                STRING "!=" DELIMITED BY SIZE
                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                ADD 1 TO WS-WORK-INDEX
            ELSE
                STRING "!" DELIMITED BY SIZE
                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
        WHEN "MOD"
            STRING "%" DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        WHEN OTHER
            MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
            MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
            PERFORM FIND-SYMBOL
            IF WS-TOKEN-WORK(1:1) = QUOTE OR
                TOKEN-UPPER(WS-WORK-INDEX) = "SPACE" OR
                TOKEN-UPPER(WS-WORK-INDEX) = "SPACES" OR
                (WS-SYMBOL-INDEX > 0 AND SYMBOL-KIND(WS-SYMBOL-INDEX) = "A")
                MOVE WS-WORK-INDEX TO WS-SAVED-WORK-INDEX
                MOVE WS-WORK-INDEX TO WS-REF-START
                MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
                PERFORM LOAD-ALNUM-OPERAND
                MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR
                IF WS-REF-OK = "Y"
                    MOVE WS-OPERAND-C-EXPR TO WS-LEFT-EXPR
                    MOVE WS-OPERAND-LENGTH-EXPR TO WS-TARGET-LENGTH-EXPR
                    MOVE WS-REF-NEXT-POS TO WS-WORK-INDEX-2
                    IF WS-WORK-INDEX-2 <= WS-EXPR-END
                        IF TOKEN-UPPER(WS-WORK-INDEX-2) = "NOT" AND
                            WS-WORK-INDEX-2 + 1 <= WS-EXPR-END AND
                            TOKEN-UPPER(WS-WORK-INDEX-2 + 1) = "="
                            MOVE "<>" TO WS-COMPARE-OP
                            ADD 2 TO WS-WORK-INDEX-2
                        ELSE
                            IF TOKEN-UPPER(WS-WORK-INDEX-2) = "=" OR
                                TOKEN-UPPER(WS-WORK-INDEX-2) = "<>" OR
                                TOKEN-UPPER(WS-WORK-INDEX-2) = ">" OR
                                TOKEN-UPPER(WS-WORK-INDEX-2) = ">=" OR
                                TOKEN-UPPER(WS-WORK-INDEX-2) = "<" OR
                                TOKEN-UPPER(WS-WORK-INDEX-2) = "<="
                                MOVE TOKEN-UPPER(WS-WORK-INDEX-2)
                                    TO WS-COMPARE-OP
                                ADD 1 TO WS-WORK-INDEX-2
                            ELSE
                                MOVE SPACES TO WS-COMPARE-OP
                            END-IF
                        END-IF
                        IF WS-COMPARE-OP NOT = SPACES
                            MOVE WS-WORK-INDEX-2 TO WS-REF-START
                            MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
                            PERFORM LOAD-ALNUM-OPERAND
                            MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR
                            IF WS-REF-OK = "Y"
                                MOVE WS-OPERAND-C-EXPR TO WS-RIGHT-EXPR
                                MOVE WS-OPERAND-LENGTH-EXPR
                                    TO WS-SOURCE-LENGTH-EXPR
                                STRING "(minicobc_cmp_span(" DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING FUNCTION TRIM(WS-LEFT-EXPR)
                                    DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING ", " DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING FUNCTION TRIM(WS-TARGET-LENGTH-EXPR)
                                    DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING ", " DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING FUNCTION TRIM(WS-RIGHT-EXPR)
                                    DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING ", " DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                STRING FUNCTION TRIM(WS-SOURCE-LENGTH-EXPR)
                                    DELIMITED BY SIZE
                                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                                END-STRING
                                EVALUATE WS-COMPARE-OP
                                    WHEN "="
                                        STRING ") == 0)" DELIMITED BY SIZE
                                            INTO WS-EXPR
                                            WITH POINTER WS-APPEND-PTR
                                        END-STRING
                                    WHEN "<>"
                                        STRING ") != 0)" DELIMITED BY SIZE
                                            INTO WS-EXPR
                                            WITH POINTER WS-APPEND-PTR
                                        END-STRING
                                    WHEN ">"
                                        STRING ") > 0)" DELIMITED BY SIZE
                                            INTO WS-EXPR
                                            WITH POINTER WS-APPEND-PTR
                                        END-STRING
                                    WHEN ">="
                                        STRING ") >= 0)" DELIMITED BY SIZE
                                            INTO WS-EXPR
                                            WITH POINTER WS-APPEND-PTR
                                        END-STRING
                                    WHEN "<"
                                        STRING ") < 0)" DELIMITED BY SIZE
                                            INTO WS-EXPR
                                            WITH POINTER WS-APPEND-PTR
                                        END-STRING
                                    WHEN "<="
                                        STRING ") <= 0)" DELIMITED BY SIZE
                                            INTO WS-EXPR
                                            WITH POINTER WS-APPEND-PTR
                                        END-STRING
                                END-EVALUATE
                                COMPUTE WS-WORK-INDEX = WS-REF-NEXT-POS - 1
                                EXIT PARAGRAPH
                            END-IF
                        END-IF
                    END-IF
                END-IF
                MOVE WS-SAVED-WORK-INDEX TO WS-WORK-INDEX
            END-IF
            MOVE "N" TO WS-INDEX-RESOLVE-OK
            MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
            PERFORM FIND-SYMBOL
            IF WS-SYMBOL-INDEX > 0
                MOVE WS-WORK-INDEX TO WS-APPEND-SPAN-END
                PERFORM LOAD-EFFECTIVE-OCCURS
                IF WS-EFFECTIVE-OCCURS > 1 AND
                    WS-WORK-INDEX + 1 <= WS-EXPR-END AND
                    TOKEN-RAW(WS-WORK-INDEX + 1) = "("
                    MOVE 0 TO WS-FUNCTION-END
                    MOVE 0 TO WS-PAREN-DEPTH
                    COMPUTE WS-WORK-INDEX-2 = WS-WORK-INDEX + 1
                    PERFORM UNTIL WS-WORK-INDEX-2 > WS-EXPR-END OR
                        WS-FUNCTION-END > 0
                        EVALUATE TOKEN-RAW(WS-WORK-INDEX-2)
                            WHEN "("
                                ADD 1 TO WS-PAREN-DEPTH
                            WHEN ")"
                                IF WS-PAREN-DEPTH = 1
                                    MOVE WS-WORK-INDEX-2 TO WS-FUNCTION-END
                                END-IF
                                IF WS-PAREN-DEPTH > 0
                                    SUBTRACT 1 FROM WS-PAREN-DEPTH
                                END-IF
                            WHEN OTHER
                                CONTINUE
                        END-EVALUATE
                        ADD 1 TO WS-WORK-INDEX-2
                    END-PERFORM
                END-IF
                IF WS-FUNCTION-END > 0
                    MOVE WS-FUNCTION-END TO WS-APPEND-SPAN-END
                END-IF
                MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
                MOVE WS-EXPR-START TO WS-SAVED-EXPR-START
                MOVE WS-EXPR-END TO WS-SAVED-EXPR-END
                MOVE WS-WORK-INDEX TO WS-SAVED-WORK-INDEX
                MOVE WS-WORK-INDEX TO WS-EXPR-START
                MOVE WS-APPEND-SPAN-END TO WS-EXPR-END
                PERFORM TRY-RESOLVE-INDEX-REFERENCE
                MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR
                MOVE WS-SAVED-EXPR-START TO WS-EXPR-START
                MOVE WS-SAVED-EXPR-END TO WS-EXPR-END
                MOVE WS-SAVED-WORK-INDEX TO WS-WORK-INDEX
            END-IF
            IF WS-INDEX-RESOLVE-OK = "Y"
                STRING FUNCTION TRIM(WS-REF-BUILD-RESULT)
                    DELIMITED BY SIZE
                    INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                MOVE WS-APPEND-SPAN-END TO WS-WORK-INDEX
            ELSE
                MOVE WS-APPEND-PTR TO WS-SAVED-APPEND-PTR
                MOVE WS-WORK-INDEX TO WS-REF-START
                PERFORM RESOLVE-REFERENCE
                MOVE WS-REF-RESULT-OK TO WS-APPEND-REF-OK
                MOVE WS-REF-RESULT-C-EXPR TO WS-APPEND-REF-C-EXPR
                MOVE WS-REF-RESULT-NEXT-POS TO WS-APPEND-REF-NEXT-POS
                MOVE WS-REF-RESULT-SYMBOL-INDEX TO WS-APPEND-SYMBOL-INDEX
                IF WS-APPEND-REF-OK NOT = "Y" AND
                    FUNCTION TRIM(WS-REF-C-EXPR) NOT = SPACES AND
                    WS-REF-NEXT-POS > WS-REF-START
                    MOVE "Y" TO WS-APPEND-REF-OK
                    MOVE WS-REF-C-EXPR TO WS-APPEND-REF-C-EXPR
                    MOVE WS-REF-NEXT-POS TO WS-APPEND-REF-NEXT-POS
                    MOVE WS-SYMBOL-INDEX TO WS-APPEND-SYMBOL-INDEX
                END-IF
                MOVE WS-SAVED-APPEND-PTR TO WS-APPEND-PTR
                IF WS-APPEND-REF-OK = "Y"
                    IF SYMBOL-KIND(WS-APPEND-SYMBOL-INDEX) = "G"
                        MOVE "group items cannot appear in expressions yet"
                            TO WS-ERROR-MESSAGE
                        PERFORM FAIL-COMPILATION
                    END-IF
                    IF SYMBOL-KIND(WS-APPEND-SYMBOL-INDEX) = "A"
                        MOVE SPACES TO WS-ERROR-MESSAGE
                        STRING "alphanumeric expressions are not supported yet: "
                            DELIMITED BY SIZE
                            FUNCTION TRIM(
                                SYMBOL-NAME(WS-APPEND-SYMBOL-INDEX))
                            DELIMITED BY SIZE
                            INTO WS-ERROR-MESSAGE
                        END-STRING
                        PERFORM FAIL-COMPILATION
                    END-IF
                    IF WS-OPTIMIZE = "Y" AND
                        SYMBOL-READONLY-VALUE(WS-APPEND-SYMBOL-INDEX) = "Y" AND
                        SYMBOL-OCCURS(WS-APPEND-SYMBOL-INDEX) = 1
                        STRING FUNCTION TRIM(
                            SYMBOL-VALUE-TEXT(WS-APPEND-SYMBOL-INDEX))
                            DELIMITED BY SIZE
                            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                        END-STRING
                    ELSE
                        STRING FUNCTION TRIM(WS-APPEND-REF-C-EXPR)
                            DELIMITED BY SIZE
                            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                        END-STRING
                    END-IF
                    COMPUTE WS-WORK-INDEX = WS-APPEND-REF-NEXT-POS - 1
                ELSE
                    STRING FUNCTION TRIM(WS-TOKEN-WORK) DELIMITED BY SIZE
                        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
                        END-STRING
                END-IF
            END-IF
    END-EVALUATE
    .

PUSH-REF-BUILD-STATE.
    ADD 1 TO WS-REF-BUILD-DEPTH
    IF WS-REF-BUILD-DEPTH > 8
        MOVE "reference expression nesting is too deep"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE WS-EXPR TO REF-BUILD-SAVE-EXPR(WS-REF-BUILD-DEPTH)
    MOVE WS-LEFT-EXPR TO REF-BUILD-SAVE-LEFT-EXPR(WS-REF-BUILD-DEPTH)
    MOVE WS-RIGHT-EXPR TO REF-BUILD-SAVE-RIGHT-EXPR(WS-REF-BUILD-DEPTH)
    MOVE WS-TOKEN-WORK TO REF-BUILD-SAVE-TOKEN-WORK(WS-REF-BUILD-DEPTH)
    MOVE WS-UPPER-WORK TO REF-BUILD-SAVE-UPPER-WORK(WS-REF-BUILD-DEPTH)
    MOVE WS-SEARCH-NAME TO REF-BUILD-SAVE-SEARCH-NAME(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-C-EXPR TO REF-BUILD-SAVE-REF-C-EXPR(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-INDEX-TOKEN TO REF-BUILD-SAVE-REF-INDEX(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-LENGTH-TOKEN TO REF-BUILD-SAVE-REF-LENGTH(WS-REF-BUILD-DEPTH)
    MOVE WS-APPEND-PTR TO REF-BUILD-SAVE-APPEND-PTR(WS-REF-BUILD-DEPTH)
    MOVE WS-EXPR-START TO REF-BUILD-SAVE-EXPR-START(WS-REF-BUILD-DEPTH)
    MOVE WS-EXPR-END TO REF-BUILD-SAVE-EXPR-END(WS-REF-BUILD-DEPTH)
    MOVE WS-WORK-INDEX TO REF-BUILD-SAVE-WORK-INDEX(WS-REF-BUILD-DEPTH)
    MOVE WS-SYMBOL-INDEX TO REF-BUILD-SAVE-SYMBOL-INDEX(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-START TO REF-BUILD-SAVE-REF-START(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-NEXT-POS TO REF-BUILD-SAVE-REF-NEXT(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-CLOSE-POS TO REF-BUILD-SAVE-REF-CLOSE(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-COMMA-POS TO REF-BUILD-SAVE-REF-COMMA(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-COLON-POS TO REF-BUILD-SAVE-REF-COLON(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-SYMBOL-INDEX TO REF-BUILD-SAVE-REF-SYMBOL(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-OK TO REF-BUILD-SAVE-REF-OK(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-HAS-INDEX TO
        REF-BUILD-SAVE-REF-HAS-INDEX(WS-REF-BUILD-DEPTH)
    MOVE WS-REF-HAS-SLICE TO
        REF-BUILD-SAVE-REF-HAS-SLICE(WS-REF-BUILD-DEPTH)
    .

POP-REF-BUILD-STATE.
    IF WS-REF-BUILD-DEPTH = 0
        MOVE "reference expression stack underflow"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF
    MOVE REF-BUILD-SAVE-EXPR(WS-REF-BUILD-DEPTH) TO WS-EXPR
    MOVE REF-BUILD-SAVE-LEFT-EXPR(WS-REF-BUILD-DEPTH) TO WS-LEFT-EXPR
    MOVE REF-BUILD-SAVE-RIGHT-EXPR(WS-REF-BUILD-DEPTH) TO WS-RIGHT-EXPR
    MOVE REF-BUILD-SAVE-TOKEN-WORK(WS-REF-BUILD-DEPTH) TO WS-TOKEN-WORK
    MOVE REF-BUILD-SAVE-UPPER-WORK(WS-REF-BUILD-DEPTH) TO WS-UPPER-WORK
    MOVE REF-BUILD-SAVE-SEARCH-NAME(WS-REF-BUILD-DEPTH) TO WS-SEARCH-NAME
    MOVE REF-BUILD-SAVE-REF-C-EXPR(WS-REF-BUILD-DEPTH) TO WS-REF-C-EXPR
    MOVE REF-BUILD-SAVE-REF-INDEX(WS-REF-BUILD-DEPTH) TO WS-REF-INDEX-TOKEN
    MOVE REF-BUILD-SAVE-REF-LENGTH(WS-REF-BUILD-DEPTH) TO WS-REF-LENGTH-TOKEN
    MOVE REF-BUILD-SAVE-APPEND-PTR(WS-REF-BUILD-DEPTH) TO WS-APPEND-PTR
    MOVE REF-BUILD-SAVE-EXPR-START(WS-REF-BUILD-DEPTH) TO WS-EXPR-START
    MOVE REF-BUILD-SAVE-EXPR-END(WS-REF-BUILD-DEPTH) TO WS-EXPR-END
    MOVE REF-BUILD-SAVE-WORK-INDEX(WS-REF-BUILD-DEPTH) TO WS-WORK-INDEX
    MOVE REF-BUILD-SAVE-SYMBOL-INDEX(WS-REF-BUILD-DEPTH) TO WS-SYMBOL-INDEX
    MOVE REF-BUILD-SAVE-REF-START(WS-REF-BUILD-DEPTH) TO WS-REF-START
    MOVE REF-BUILD-SAVE-REF-NEXT(WS-REF-BUILD-DEPTH) TO WS-REF-NEXT-POS
    MOVE REF-BUILD-SAVE-REF-CLOSE(WS-REF-BUILD-DEPTH) TO WS-REF-CLOSE-POS
    MOVE REF-BUILD-SAVE-REF-COMMA(WS-REF-BUILD-DEPTH) TO WS-REF-COMMA-POS
    MOVE REF-BUILD-SAVE-REF-COLON(WS-REF-BUILD-DEPTH) TO WS-REF-COLON-POS
    MOVE REF-BUILD-SAVE-REF-SYMBOL(WS-REF-BUILD-DEPTH) TO WS-REF-SYMBOL-INDEX
    MOVE REF-BUILD-SAVE-REF-OK(WS-REF-BUILD-DEPTH) TO WS-REF-OK
    MOVE REF-BUILD-SAVE-REF-HAS-INDEX(WS-REF-BUILD-DEPTH)
        TO WS-REF-HAS-INDEX
    MOVE REF-BUILD-SAVE-REF-HAS-SLICE(WS-REF-BUILD-DEPTH)
        TO WS-REF-HAS-SLICE
    SUBTRACT 1 FROM WS-REF-BUILD-DEPTH
    .

RESOLVE-SIMPLE-INDEX-TOKEN.
    MOVE TOKEN-RAW(WS-WORK-INDEX) TO WS-TOKEN-WORK
    MOVE TOKEN-UPPER(WS-WORK-INDEX) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX > 0
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "G"
            MOVE "group items cannot be used as indices"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE SYMBOL-C-NAME(WS-SYMBOL-INDEX) TO WS-REF-BUILD-RESULT
    ELSE
        MOVE WS-TOKEN-WORK TO WS-REF-BUILD-RESULT
    END-IF
    MOVE WS-REF-BUILD-RESULT TO WS-TOKEN-WORK
    PERFORM NORMALIZE-SIMPLE-TOKEN
    MOVE WS-TOKEN-WORK TO WS-REF-BUILD-RESULT
    .

TRY-RESOLVE-INDEX-REFERENCE.
    MOVE "N" TO WS-INDEX-RESOLVE-OK
    IF WS-EXPR-START > WS-EXPR-END
        EXIT PARAGRAPH
    END-IF

    MOVE TOKEN-UPPER(WS-EXPR-START) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX = 0 OR SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "N"
        EXIT PARAGRAPH
    END-IF

    MOVE WS-SYMBOL-INDEX TO WS-REF-SYMBOL-INDEX
    PERFORM LOAD-EFFECTIVE-OCCURS
    IF WS-EFFECTIVE-OCCURS = 1
        IF WS-EXPR-START = WS-EXPR-END
            MOVE SYMBOL-C-NAME(WS-SYMBOL-INDEX) TO WS-REF-BUILD-RESULT
            MOVE "Y" TO WS-INDEX-RESOLVE-OK
        END-IF
        EXIT PARAGRAPH
    END-IF

    IF WS-EXPR-START + 1 > WS-EXPR-END OR
        TOKEN-RAW(WS-EXPR-START + 1) NOT = "("
        EXIT PARAGRAPH
    END-IF

    MOVE 0 TO WS-FUNCTION-END
    MOVE 0 TO WS-REF-COMMA-POS
    MOVE 0 TO WS-PAREN-DEPTH
    COMPUTE WS-WORK-INDEX = WS-EXPR-START + 1
    PERFORM UNTIL WS-WORK-INDEX > WS-EXPR-END OR WS-FUNCTION-END > 0
        EVALUATE TOKEN-RAW(WS-WORK-INDEX)
            WHEN "("
                ADD 1 TO WS-PAREN-DEPTH
            WHEN ")"
                IF WS-PAREN-DEPTH = 1
                    MOVE WS-WORK-INDEX TO WS-FUNCTION-END
                END-IF
                IF WS-PAREN-DEPTH > 0
                    SUBTRACT 1 FROM WS-PAREN-DEPTH
                END-IF
            WHEN ","
                IF WS-PAREN-DEPTH = 1 AND WS-REF-COMMA-POS = 0
                    MOVE WS-WORK-INDEX TO WS-REF-COMMA-POS
                END-IF
            WHEN OTHER
                CONTINUE
        END-EVALUATE
        ADD 1 TO WS-WORK-INDEX
    END-PERFORM

    IF WS-FUNCTION-END NOT = WS-EXPR-END OR WS-REF-COMMA-POS > 0
        EXIT PARAGRAPH
    END-IF

    IF WS-FUNCTION-END = WS-EXPR-START + 3
        COMPUTE WS-WORK-INDEX = WS-EXPR-START + 2
        PERFORM RESOLVE-SIMPLE-INDEX-TOKEN
        MOVE SPACES TO WS-REF-BUILD-RESULT
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-REF-SYMBOL-INDEX))
            DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "[(" DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-TOKEN-WORK) DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ") - 1]" DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
        MOVE "Y" TO WS-INDEX-RESOLVE-OK
        EXIT PARAGRAPH
    END-IF

    PERFORM PUSH-REF-BUILD-STATE
    COMPUTE WS-EXPR-START = WS-EXPR-START + 2
    COMPUTE WS-EXPR-END = WS-FUNCTION-END - 1
    PERFORM TRY-RESOLVE-INDEX-REFERENCE
    PERFORM POP-REF-BUILD-STATE
    IF WS-INDEX-RESOLVE-OK = "Y"
        MOVE SPACES TO WS-LEFT-EXPR
        MOVE WS-REF-BUILD-RESULT TO WS-LEFT-EXPR
        MOVE SPACES TO WS-REF-BUILD-RESULT
        MOVE 1 TO WS-APPEND-PTR
        STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-REF-SYMBOL-INDEX))
            DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING "[(" DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ") - 1]" DELIMITED BY SIZE
            INTO WS-REF-BUILD-RESULT WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF
    .

RESOLVE-REFERENCE.
    MOVE "N" TO WS-REF-OK
    MOVE "N" TO WS-REF-RESULT-OK
    MOVE "N" TO WS-REF-HAS-INDEX
    MOVE "N" TO WS-REF-HAS-SLICE
    MOVE 0 TO WS-REF-NEXT-POS
    MOVE 0 TO WS-REF-SYMBOL-INDEX
    MOVE 0 TO WS-REF-RESULT-NEXT-POS
    MOVE 0 TO WS-REF-RESULT-SYMBOL-INDEX
    MOVE 0 TO WS-REF-COMMA-POS
    MOVE SPACES TO WS-REF-C-EXPR
    MOVE SPACES TO WS-REF-RESULT-C-EXPR
    MOVE SPACES TO WS-REF-INDEX-TOKEN
    MOVE SPACES TO WS-REF-LENGTH-TOKEN

    IF WS-REF-START < 1 OR WS-REF-START > WS-TOKEN-COUNT
        EXIT PARAGRAPH
    END-IF

    MOVE TOKEN-UPPER(WS-REF-START) TO WS-SEARCH-NAME
    PERFORM FIND-SYMBOL
    IF WS-SYMBOL-INDEX = 0
        EXIT PARAGRAPH
    END-IF

    MOVE WS-SYMBOL-INDEX TO WS-REF-SYMBOL-INDEX
    MOVE 0 TO WS-QUAL-SYMBOL-INDEX
    MOVE "N" TO WS-QUAL-HAS-INDEX
    MOVE 0 TO WS-QUAL-START
    MOVE 0 TO WS-QUAL-CLOSE-POS
    MOVE 0 TO WS-QUAL-NEXT-POS
    IF WS-REF-START + 1 <= WS-TOKEN-COUNT AND
        TOKEN-UPPER(WS-REF-START + 1) = "OF"
        MOVE WS-REF-SYMBOL-INDEX TO WS-SAVED-SYMBOL-INDEX
        MOVE WS-REF-START TO WS-WORK-INDEX
        PERFORM PARSE-QUALIFIER-REFERENCE
        IF WS-QUAL-SYMBOL-INDEX > 0
            PERFORM CHECK-QUALIFIER-ANCESTOR
            IF WS-QUAL-IS-ANCESTOR NOT = "Y"
                MOVE 0 TO WS-QUAL-SYMBOL-INDEX
                MOVE "N" TO WS-QUAL-HAS-INDEX
                MOVE 0 TO WS-QUAL-START
                MOVE 0 TO WS-QUAL-CLOSE-POS
                MOVE 0 TO WS-QUAL-NEXT-POS
            END-IF
        END-IF
    END-IF
    MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
    PERFORM LOAD-EFFECTIVE-OCCURS
    IF WS-EFFECTIVE-OCCURS > 1
        IF WS-REF-START + 1 > WS-TOKEN-COUNT OR
            TOKEN-RAW(WS-REF-START + 1) NOT = "("
            IF WS-QUAL-SYMBOL-INDEX = 0 OR
                WS-QUAL-HAS-INDEX NOT = "Y" OR
                SYMBOL-OCCURS-ANCESTOR(WS-REF-SYMBOL-INDEX) = 0
                MOVE "OCCURS items currently require an index"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF

            PERFORM BUILD-QUALIFIER-INDEX-TOKEN
            MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
            MOVE "Y" TO WS-REF-HAS-INDEX
            IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "G"
                MOVE SPACES TO WS-REF-C-EXPR
                MOVE 1 TO WS-APPEND-PTR
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING "[(" DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-REF-INDEX-TOKEN) DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ") - 1]" DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            MOVE WS-QUAL-NEXT-POS TO WS-REF-NEXT-POS
        ELSE

        MOVE 0 TO WS-FUNCTION-END
        MOVE 0 TO WS-REF-COMMA-POS
        MOVE 0 TO WS-PAREN-DEPTH
        COMPUTE WS-WORK-INDEX = WS-REF-START + 1
        PERFORM UNTIL WS-WORK-INDEX > WS-TOKEN-COUNT OR
            WS-FUNCTION-END > 0
            EVALUATE TOKEN-RAW(WS-WORK-INDEX)
                WHEN "("
                    ADD 1 TO WS-PAREN-DEPTH
                WHEN ")"
                    IF WS-PAREN-DEPTH = 1
                        MOVE WS-WORK-INDEX TO WS-FUNCTION-END
                    END-IF
                    IF WS-PAREN-DEPTH > 0
                        SUBTRACT 1 FROM WS-PAREN-DEPTH
                    END-IF
                WHEN ","
                    IF WS-PAREN-DEPTH = 1 AND WS-REF-COMMA-POS = 0
                        MOVE WS-WORK-INDEX TO WS-REF-COMMA-POS
                    END-IF
                WHEN OTHER
                    CONTINUE
            END-EVALUATE
            ADD 1 TO WS-WORK-INDEX
        END-PERFORM

        IF WS-FUNCTION-END = 0
            MOVE "OCCURS index is missing a closing parenthesis"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF
        MOVE WS-FUNCTION-END TO WS-REF-CLOSE-POS

        IF SYMBOL-OCCURS(WS-REF-SYMBOL-INDEX) > 1 AND
            SYMBOL-OCCURS-ANCESTOR(WS-REF-SYMBOL-INDEX) > 0
            IF WS-REF-COMMA-POS = 0 OR
                WS-REF-COMMA-POS <= WS-REF-START + 2 OR
                WS-REF-COMMA-POS >= WS-REF-CLOSE-POS - 1
                MOVE "nested OCCURS items require two indices"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF

            IF WS-REF-COMMA-POS = WS-REF-START + 3
                COMPUTE WS-WORK-INDEX = WS-REF-START + 2
                PERFORM RESOLVE-SIMPLE-INDEX-TOKEN
                MOVE WS-REF-BUILD-RESULT TO WS-LEFT-EXPR
            ELSE
                COMPUTE WS-EXPR-START = WS-REF-START + 2
                COMPUTE WS-EXPR-END = WS-REF-COMMA-POS - 1
                PERFORM PUSH-REF-BUILD-STATE
                PERFORM TRY-RESOLVE-INDEX-REFERENCE
                PERFORM POP-REF-BUILD-STATE
                IF WS-INDEX-RESOLVE-OK NOT = "Y"
                    PERFORM PUSH-REF-BUILD-STATE
                    PERFORM BUILD-EXPRESSION
                    MOVE WS-EXPR TO WS-REF-BUILD-RESULT
                    PERFORM POP-REF-BUILD-STATE
                END-IF
                MOVE WS-REF-BUILD-RESULT TO WS-LEFT-EXPR
            END-IF

            IF WS-REF-CLOSE-POS = WS-REF-COMMA-POS + 2
                COMPUTE WS-WORK-INDEX = WS-REF-COMMA-POS + 1
                PERFORM RESOLVE-SIMPLE-INDEX-TOKEN
                MOVE WS-REF-BUILD-RESULT TO WS-RIGHT-EXPR
            ELSE
                COMPUTE WS-EXPR-START = WS-REF-COMMA-POS + 1
                COMPUTE WS-EXPR-END = WS-REF-CLOSE-POS - 1
                PERFORM PUSH-REF-BUILD-STATE
                PERFORM TRY-RESOLVE-INDEX-REFERENCE
                PERFORM POP-REF-BUILD-STATE
                IF WS-INDEX-RESOLVE-OK NOT = "Y"
                    PERFORM PUSH-REF-BUILD-STATE
                    PERFORM BUILD-EXPRESSION
                    MOVE WS-EXPR TO WS-REF-BUILD-RESULT
                    PERFORM POP-REF-BUILD-STATE
                END-IF
                MOVE WS-REF-BUILD-RESULT TO WS-RIGHT-EXPR
            END-IF

            MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
            MOVE "Y" TO WS-REF-HAS-INDEX
            IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "G"
                MOVE SPACES TO WS-REF-C-EXPR
                MOVE 1 TO WS-APPEND-PTR
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING "[(((" DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ") - 1) * " DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                MOVE SYMBOL-OCCURS(WS-SYMBOL-INDEX) TO WS-PLAIN-NUMERIC
                PERFORM LOAD-PLAIN-INTEGER-TEXT
                STRING FUNCTION TRIM(WS-PLAIN-TEXT) DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ") + ((" DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ") - 1)]" DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            COMPUTE WS-REF-NEXT-POS = WS-REF-CLOSE-POS + 1
        ELSE
            IF WS-REF-COMMA-POS > 0
                MOVE "single-dimension OCCURS items take one index"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF
            IF WS-REF-CLOSE-POS <= WS-REF-START + 2
                MOVE "OCCURS items currently require an index expression"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF

            IF WS-REF-CLOSE-POS = WS-REF-START + 3
                COMPUTE WS-WORK-INDEX = WS-REF-START + 2
                PERFORM RESOLVE-SIMPLE-INDEX-TOKEN
                MOVE WS-REF-BUILD-RESULT TO WS-REF-INDEX-TOKEN
            ELSE
                COMPUTE WS-EXPR-START = WS-REF-START + 2
                COMPUTE WS-EXPR-END = WS-REF-CLOSE-POS - 1
                PERFORM PUSH-REF-BUILD-STATE
                PERFORM TRY-RESOLVE-INDEX-REFERENCE
                PERFORM POP-REF-BUILD-STATE
                IF WS-INDEX-RESOLVE-OK NOT = "Y"
                    PERFORM PUSH-REF-BUILD-STATE
                    PERFORM BUILD-EXPRESSION
                    MOVE WS-EXPR TO WS-REF-BUILD-RESULT
                    PERFORM POP-REF-BUILD-STATE
                END-IF
                MOVE WS-REF-BUILD-RESULT TO WS-REF-INDEX-TOKEN
            END-IF

            MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
            MOVE "Y" TO WS-REF-HAS-INDEX
            IF SYMBOL-KIND(WS-SYMBOL-INDEX) NOT = "G"
                MOVE SPACES TO WS-REF-C-EXPR
                MOVE 1 TO WS-APPEND-PTR
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING "[(" DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-REF-INDEX-TOKEN) DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING ") - 1]" DELIMITED BY SIZE
                    INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            COMPUTE WS-REF-NEXT-POS = WS-REF-CLOSE-POS + 1
        END-IF
    ELSE
        IF SYMBOL-KIND(WS-SYMBOL-INDEX) = "A" AND
            WS-REF-START + 3 <= WS-TOKEN-COUNT AND
            TOKEN-RAW(WS-REF-START + 1) = "(" AND
            TOKEN-RAW(WS-REF-START + 3) = ")"
            MOVE TOKEN-RAW(WS-REF-START + 2) TO WS-TOKEN-WORK
            MOVE FUNCTION LENGTH(FUNCTION TRIM(WS-TOKEN-WORK))
                TO WS-WORK-INDEX-2
            MOVE WS-WORK-INDEX-2 TO WS-SAVED-WORK-INDEX
            MOVE 0 TO WS-REF-COLON-POS
            PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
                UNTIL WS-WORK-INDEX > WS-SAVED-WORK-INDEX OR
                    WS-REF-COLON-POS > 0
                IF WS-TOKEN-WORK(WS-WORK-INDEX:1) = ":"
                    MOVE WS-WORK-INDEX TO WS-REF-COLON-POS
                END-IF
            END-PERFORM
            IF WS-REF-COLON-POS = 0 OR WS-REF-COLON-POS = 1 OR
                WS-REF-COLON-POS = WS-SAVED-WORK-INDEX
                MOVE "reference modification requires start:length"
                    TO WS-ERROR-MESSAGE
                PERFORM FAIL-COMPILATION
            END-IF

            MOVE SPACES TO WS-ARG-WORK
            MOVE WS-TOKEN-WORK(1:WS-REF-COLON-POS - 1) TO WS-ARG-WORK
            MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-ARG-WORK))
                TO WS-SEARCH-NAME
            PERFORM FIND-SYMBOL
            MOVE SPACES TO WS-REF-INDEX-TOKEN
            IF WS-SYMBOL-INDEX > 0
                MOVE 1 TO WS-APPEND-PTR
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-REF-INDEX-TOKEN WITH POINTER WS-APPEND-PTR
                END-STRING
            ELSE
                MOVE 1 TO WS-APPEND-PTR
                STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                    INTO WS-REF-INDEX-TOKEN WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF

            MOVE SPACES TO WS-ARG-WORK
            MOVE WS-TOKEN-WORK(WS-REF-COLON-POS + 1:
                WS-SAVED-WORK-INDEX - WS-REF-COLON-POS)
                TO WS-ARG-WORK
            MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-ARG-WORK))
                TO WS-SEARCH-NAME
            PERFORM FIND-SYMBOL
            MOVE SPACES TO WS-REF-LENGTH-TOKEN
            IF WS-SYMBOL-INDEX > 0
                MOVE 1 TO WS-APPEND-PTR
                STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                    DELIMITED BY SIZE
                    INTO WS-REF-LENGTH-TOKEN WITH POINTER WS-APPEND-PTR
                END-STRING
            ELSE
                MOVE 1 TO WS-APPEND-PTR
                STRING FUNCTION TRIM(WS-ARG-WORK) DELIMITED BY SIZE
                    INTO WS-REF-LENGTH-TOKEN WITH POINTER WS-APPEND-PTR
                END-STRING
            END-IF
            MOVE WS-REF-LENGTH-TOKEN TO WS-TOKEN-WORK
            PERFORM NORMALIZE-SIMPLE-TOKEN
            MOVE WS-TOKEN-WORK TO WS-REF-LENGTH-TOKEN
            MOVE WS-REF-INDEX-TOKEN TO WS-TOKEN-WORK
            PERFORM NORMALIZE-SIMPLE-TOKEN
            MOVE WS-TOKEN-WORK TO WS-REF-INDEX-TOKEN

            MOVE WS-REF-SYMBOL-INDEX TO WS-SYMBOL-INDEX
            MOVE "Y" TO WS-REF-HAS-SLICE
            MOVE SPACES TO WS-REF-C-EXPR
            MOVE 1 TO WS-APPEND-PTR
            STRING FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                DELIMITED BY SIZE
                INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING " + ((" DELIMITED BY SIZE
                INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING FUNCTION TRIM(WS-REF-INDEX-TOKEN) DELIMITED BY SIZE
                INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            STRING ") - 1)" DELIMITED BY SIZE
                INTO WS-REF-C-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
            COMPUTE WS-REF-NEXT-POS = WS-REF-START + 4
        ELSE
            MOVE FUNCTION TRIM(SYMBOL-C-NAME(WS-SYMBOL-INDEX))
                TO WS-REF-C-EXPR
            IF WS-QUAL-SYMBOL-INDEX > 0
                MOVE WS-QUAL-NEXT-POS TO WS-REF-NEXT-POS
            ELSE
                COMPUTE WS-REF-NEXT-POS = WS-REF-START + 1
            END-IF
        END-IF
    END-IF

    MOVE "Y" TO WS-REF-OK
    MOVE WS-REF-OK TO WS-REF-RESULT-OK
    MOVE WS-REF-C-EXPR TO WS-REF-RESULT-C-EXPR
    MOVE WS-REF-NEXT-POS TO WS-REF-RESULT-NEXT-POS
    MOVE WS-SYMBOL-INDEX TO WS-REF-RESULT-SYMBOL-INDEX
    .

NORMALIZE-SIMPLE-TOKEN.
    MOVE FUNCTION TRIM(WS-TOKEN-WORK) TO WS-TOKEN-WORK
    MOVE SPACES TO WS-ARG-WORK
    MOVE 1 TO WS-APPEND-PTR
    MOVE FUNCTION LENGTH(FUNCTION TRIM(WS-TOKEN-WORK))
        TO WS-WORK-INDEX-2
    PERFORM VARYING WS-WORK-INDEX FROM 1 BY 1
        UNTIL WS-WORK-INDEX > WS-WORK-INDEX-2 OR
            WS-TOKEN-WORK(WS-WORK-INDEX:1) = SPACE
        STRING WS-TOKEN-WORK(WS-WORK-INDEX:1) DELIMITED BY SIZE
            INTO WS-ARG-WORK WITH POINTER WS-APPEND-PTR
        END-STRING
    END-PERFORM
    MOVE WS-ARG-WORK TO WS-TOKEN-WORK
    .

COMPILE-INTRINSIC-CALL.
    IF WS-WORK-INDEX + 3 > WS-EXPR-END
        MOVE "malformed FUNCTION call in expression" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE TOKEN-UPPER(WS-WORK-INDEX + 1) TO WS-CALL-NAME-WORK
    IF FUNCTION TRIM(WS-CALL-NAME-WORK) NOT = "MOD" AND
        FUNCTION TRIM(WS-CALL-NAME-WORK) NOT = "REM" AND
        FUNCTION TRIM(WS-CALL-NAME-WORK) NOT = "SQRT" AND
        FUNCTION TRIM(WS-CALL-NAME-WORK) NOT = "NUMVAL"
        MOVE "only FUNCTION MOD, FUNCTION REM, FUNCTION SQRT, and FUNCTION NUMVAL are supported"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF TOKEN-RAW(WS-WORK-INDEX + 2) NOT = "("
        MOVE "FUNCTION call must use parentheses" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF FUNCTION TRIM(WS-CALL-NAME-WORK) = "NUMVAL"
        MOVE 0 TO WS-FUNCTION-END
        MOVE 0 TO WS-PAREN-DEPTH
        COMPUTE WS-WORK-INDEX-2 = WS-WORK-INDEX + 2
        PERFORM UNTIL WS-WORK-INDEX-2 > WS-EXPR-END OR WS-FUNCTION-END > 0
            EVALUATE TOKEN-RAW(WS-WORK-INDEX-2)
                WHEN "("
                    ADD 1 TO WS-PAREN-DEPTH
                WHEN ")"
                    IF WS-PAREN-DEPTH = 1
                        MOVE WS-WORK-INDEX-2 TO WS-FUNCTION-END
                    END-IF
                    IF WS-PAREN-DEPTH > 0
                        SUBTRACT 1 FROM WS-PAREN-DEPTH
                    END-IF
                WHEN OTHER
                    CONTINUE
            END-EVALUATE
            ADD 1 TO WS-WORK-INDEX-2
        END-PERFORM

        IF WS-FUNCTION-END = 0 OR WS-FUNCTION-END <= WS-WORK-INDEX + 3
            MOVE "FUNCTION NUMVAL needs one argument"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        COMPUTE WS-REF-START = WS-WORK-INDEX + 3
        PERFORM LOAD-ALNUM-OPERAND
        IF WS-REF-OK NOT = "Y" OR WS-REF-NEXT-POS NOT = WS-FUNCTION-END
            MOVE "FUNCTION NUMVAL currently expects one alphanumeric operand"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        IF WS-APPEND-PTR > 1
            STRING " " DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        END-IF
        STRING "minicobc_numval_span(" DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-OPERAND-C-EXPR) DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ", " DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-OPERAND-LENGTH-EXPR) DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ")" DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING

        COMPUTE WS-WORK-INDEX = WS-FUNCTION-END + 1
        EXIT PARAGRAPH
    END-IF

    IF FUNCTION TRIM(WS-CALL-NAME-WORK) = "SQRT"
        MOVE 0 TO WS-FUNCTION-END
        MOVE 0 TO WS-PAREN-DEPTH
        COMPUTE WS-WORK-INDEX-2 = WS-WORK-INDEX + 2
        PERFORM UNTIL WS-WORK-INDEX-2 > WS-EXPR-END OR WS-FUNCTION-END > 0
            EVALUATE TOKEN-RAW(WS-WORK-INDEX-2)
                WHEN "("
                    ADD 1 TO WS-PAREN-DEPTH
                WHEN ")"
                    IF WS-PAREN-DEPTH = 1
                        MOVE WS-WORK-INDEX-2 TO WS-FUNCTION-END
                    END-IF
                    IF WS-PAREN-DEPTH > 0
                        SUBTRACT 1 FROM WS-PAREN-DEPTH
                    END-IF
                WHEN OTHER
                    CONTINUE
            END-EVALUATE
            ADD 1 TO WS-WORK-INDEX-2
        END-PERFORM

        IF WS-FUNCTION-END = 0 OR WS-FUNCTION-END <= WS-WORK-INDEX + 3
            MOVE "FUNCTION SQRT needs one argument"
                TO WS-ERROR-MESSAGE
            PERFORM FAIL-COMPILATION
        END-IF

        MOVE WS-EXPR TO WS-INTRINSIC-SAVED-EXPR
        MOVE WS-APPEND-PTR TO WS-INTRINSIC-SAVED-APPEND-PTR
        MOVE WS-EXPR-START TO WS-INTRINSIC-SAVED-EXPR-START
        MOVE WS-EXPR-END TO WS-INTRINSIC-SAVED-EXPR-END
        MOVE WS-WORK-INDEX TO WS-INTRINSIC-SAVED-WORK-INDEX

        COMPUTE WS-EXPR-START = WS-INTRINSIC-SAVED-WORK-INDEX + 3
        COMPUTE WS-EXPR-END = WS-FUNCTION-END - 1
        PERFORM BUILD-PLAIN-EXPRESSION
        MOVE WS-EXPR TO WS-LEFT-EXPR

        MOVE WS-INTRINSIC-SAVED-EXPR TO WS-EXPR
        MOVE WS-INTRINSIC-SAVED-APPEND-PTR TO WS-APPEND-PTR
        MOVE WS-INTRINSIC-SAVED-EXPR-START TO WS-EXPR-START
        MOVE WS-INTRINSIC-SAVED-EXPR-END TO WS-EXPR-END
        MOVE WS-INTRINSIC-SAVED-WORK-INDEX TO WS-WORK-INDEX

        IF WS-APPEND-PTR > 1
            STRING " " DELIMITED BY SIZE
                INTO WS-EXPR WITH POINTER WS-APPEND-PTR
            END-STRING
        END-IF

        STRING "minicobc_sqrt_ll(" DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
        STRING ")" DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING

        COMPUTE WS-WORK-INDEX = WS-FUNCTION-END + 1
        EXIT PARAGRAPH
    END-IF

    MOVE 0 TO WS-FUNCTION-COMMA
    MOVE 0 TO WS-FUNCTION-END
    MOVE 0 TO WS-PAREN-DEPTH
    COMPUTE WS-WORK-INDEX-2 = WS-WORK-INDEX + 2
    PERFORM UNTIL WS-WORK-INDEX-2 > WS-EXPR-END OR WS-FUNCTION-END > 0
        EVALUATE TOKEN-RAW(WS-WORK-INDEX-2)
            WHEN "("
                ADD 1 TO WS-PAREN-DEPTH
            WHEN ")"
                IF WS-PAREN-DEPTH = 1
                    MOVE WS-WORK-INDEX-2 TO WS-FUNCTION-END
                END-IF
                IF WS-PAREN-DEPTH > 0
                    SUBTRACT 1 FROM WS-PAREN-DEPTH
                END-IF
            WHEN ","
                IF WS-PAREN-DEPTH = 1 AND WS-FUNCTION-COMMA = 0
                    MOVE WS-WORK-INDEX-2 TO WS-FUNCTION-COMMA
                END-IF
            WHEN OTHER
                CONTINUE
        END-EVALUATE
        ADD 1 TO WS-WORK-INDEX-2
    END-PERFORM

    IF WS-FUNCTION-COMMA = 0 OR WS-FUNCTION-END = 0
        MOVE "FUNCTION MOD/REM needs two comma-separated arguments"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-FUNCTION-COMMA <= WS-WORK-INDEX + 3 OR
        WS-FUNCTION-COMMA + 1 >= WS-FUNCTION-END
        MOVE "FUNCTION MOD/REM arguments cannot be empty"
            TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    MOVE WS-EXPR TO WS-INTRINSIC-SAVED-EXPR
    MOVE WS-APPEND-PTR TO WS-INTRINSIC-SAVED-APPEND-PTR
    MOVE WS-EXPR-START TO WS-INTRINSIC-SAVED-EXPR-START
    MOVE WS-EXPR-END TO WS-INTRINSIC-SAVED-EXPR-END
    MOVE WS-WORK-INDEX TO WS-INTRINSIC-SAVED-WORK-INDEX

    COMPUTE WS-EXPR-START = WS-INTRINSIC-SAVED-WORK-INDEX + 3
    COMPUTE WS-EXPR-END = WS-FUNCTION-COMMA - 1
    PERFORM BUILD-PLAIN-EXPRESSION
    MOVE WS-EXPR TO WS-LEFT-EXPR

    COMPUTE WS-EXPR-START = WS-FUNCTION-COMMA + 1
    COMPUTE WS-EXPR-END = WS-FUNCTION-END - 1
    PERFORM BUILD-PLAIN-EXPRESSION
    MOVE WS-EXPR TO WS-RIGHT-EXPR

    MOVE WS-INTRINSIC-SAVED-EXPR TO WS-EXPR
    MOVE WS-INTRINSIC-SAVED-APPEND-PTR TO WS-APPEND-PTR
    MOVE WS-INTRINSIC-SAVED-EXPR-START TO WS-EXPR-START
    MOVE WS-INTRINSIC-SAVED-EXPR-END TO WS-EXPR-END
    MOVE WS-INTRINSIC-SAVED-WORK-INDEX TO WS-WORK-INDEX

    IF WS-APPEND-PTR > 1
        STRING " " DELIMITED BY SIZE
            INTO WS-EXPR WITH POINTER WS-APPEND-PTR
        END-STRING
    END-IF

    STRING "(" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-LEFT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING " % " DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING FUNCTION TRIM(WS-RIGHT-EXPR) DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING
    STRING ")" DELIMITED BY SIZE
        INTO WS-EXPR WITH POINTER WS-APPEND-PTR
    END-STRING

    COMPUTE WS-WORK-INDEX = WS-FUNCTION-END + 1
    .

FIND-SYMBOL.
    MOVE 0 TO WS-SYMBOL-INDEX
    PERFORM VARYING WS-WORK-INDEX-2 FROM 1 BY 1
        UNTIL WS-WORK-INDEX-2 > WS-SYMBOL-COUNT
        IF SYMBOL-NAME(WS-WORK-INDEX-2) = WS-SEARCH-NAME
            MOVE WS-WORK-INDEX-2 TO WS-SYMBOL-INDEX
            EXIT PERFORM
        END-IF
    END-PERFORM
    .

FINALIZE-OUTPUT.
    IF WS-BLOCK-DEPTH NOT = 0
        MOVE "unclosed IF or PERFORM block" TO WS-ERROR-MESSAGE
        PERFORM FAIL-COMPILATION
    END-IF

    IF WS-PROCEDURE-SEEN = "Y"
        IF WS-HAS-PARAGRAPHS = "Y"
            IF WS-PROCEDURE-FUNC-OPEN = "Y"
                PERFORM CLOSE-CURRENT-PROCEDURE-FUNCTION
            END-IF
            IF WS-IS-SUBPROGRAM = "Y"
                MOVE SPACES TO WS-EMIT-PAYLOAD
                MOVE 1 TO WS-APPEND-PTR
                STRING "void " DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING FUNCTION TRIM(WS-PROGRAM-C-NAME)
                    DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                STRING "(void **minicobc_args)" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                PERFORM EMIT-LINE
                MOVE "{" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
                MOVE 1 TO WS-INDENT-LEVEL
                PERFORM EMIT-UNIT-INIT-CALL
                PERFORM EMIT-SUBPROGRAM-STATE-PROLOGUE
                MOVE SPACES TO WS-EMIT-PAYLOAD
                MOVE 1 TO WS-APPEND-PTR
                IF WS-HAS-ENTRY-PARAGRAPH = "Y"
                    STRING FUNCTION TRIM(WS-ENTRY-PARAGRAPH-C-NAME)
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                ELSE
                    STRING FUNCTION TRIM(WS-FIRST-PARAGRAPH-C-NAME)
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                END-IF
                STRING "();" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                PERFORM EMIT-LINE
                PERFORM EMIT-SUBPROGRAM-RETURN-BLOCK
                MOVE 0 TO WS-INDENT-LEVEL
                MOVE "}" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
            ELSE
                MOVE "int main(int argc, char **argv)" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
                MOVE "{" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
                MOVE 1 TO WS-INDENT-LEVEL
                MOVE "minicobc_argc = argc;" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
                MOVE "minicobc_argv = argv;" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
                PERFORM EMIT-UNIT-INIT-CALL
                MOVE SPACES TO WS-EMIT-PAYLOAD
                MOVE 1 TO WS-APPEND-PTR
                IF WS-HAS-ENTRY-PARAGRAPH = "Y"
                    STRING FUNCTION TRIM(WS-ENTRY-PARAGRAPH-C-NAME)
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                ELSE
                    STRING FUNCTION TRIM(WS-FIRST-PARAGRAPH-C-NAME)
                        DELIMITED BY SIZE
                        INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                    END-STRING
                END-IF
                STRING "();" DELIMITED BY SIZE
                    INTO WS-EMIT-PAYLOAD WITH POINTER WS-APPEND-PTR
                END-STRING
                PERFORM EMIT-LINE
                MOVE "return 0;" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
                MOVE 0 TO WS-INDENT-LEVEL
                MOVE "}" TO WS-EMIT-PAYLOAD
                PERFORM EMIT-LINE
            END-IF
        ELSE
            PERFORM FLUSH-PENDING-ASSIGNMENT
            IF WS-IS-SUBPROGRAM = "Y"
                PERFORM EMIT-SUBPROGRAM-RETURN-BLOCK
            ELSE
                IF WS-RETURN-EMITTED = "N"
                    MOVE "return 0;" TO WS-EMIT-PAYLOAD
                    PERFORM EMIT-LINE
                END-IF
            END-IF
            MOVE 0 TO WS-INDENT-LEVEL
            MOVE "}" TO WS-EMIT-PAYLOAD
            PERFORM EMIT-LINE
        END-IF
    END-IF
    .

EMIT-LINE.
    MOVE SPACES TO WS-EMIT-LINE
    IF WS-INDENT-LEVEL > 0
        STRING
            WS-INDENT-SPACES(1:WS-INDENT-LEVEL * 4)
            FUNCTION TRIM(WS-EMIT-PAYLOAD TRAILING)
            DELIMITED BY SIZE INTO WS-EMIT-LINE
        END-STRING
    ELSE
        MOVE FUNCTION TRIM(WS-EMIT-PAYLOAD TRAILING) TO WS-EMIT-LINE
    END-IF
    WRITE OUTPUT-RECORD FROM WS-EMIT-LINE
    .

FAIL-COMPILATION.
    DISPLAY "compile error on line " WS-LINE-NO ": "
        FUNCTION TRIM(WS-ERROR-MESSAGE)
    MOVE 1 TO RETURN-CODE
    STOP RUN
    .
